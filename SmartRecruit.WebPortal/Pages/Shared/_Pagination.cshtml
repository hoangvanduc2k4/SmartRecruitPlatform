@model (int CurrentPage, int TotalPages, string UrlFormat)

@if (Model.TotalPages > 1)
{
    <div class="mt-10 flex justify-center items-center gap-4">
        <a href="@string.Format(Model.UrlFormat, Model.CurrentPage - 1)" 
           class="w-10 h-10 rounded-xl border border-slate-200 bg-white flex items-center justify-center text-slate-500 hover:text-indigo-600 hover:border-indigo-500 transition-all @(Model.CurrentPage <= 1 ? "opacity-50 pointer-events-none" : "")">
            <i class="fas fa-chevron-left"></i>
        </a>
        
        <div class="flex items-center gap-2">
            @{
                var startPage = Math.Max(1, Model.CurrentPage - 1);
                var endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 1);
                
                if (Model.CurrentPage <= 2) {
                    endPage = Math.Min(Model.TotalPages, 3);
                }
                if (Model.CurrentPage >= Model.TotalPages - 1) {
                    startPage = Math.Max(1, Model.TotalPages - 2);
                }
            }

            @if (startPage > 1) {
                <a href="@string.Format(Model.UrlFormat, 1)" 
                   class="w-10 h-10 rounded-xl border flex items-center justify-center text-xs font-black transition-all bg-white border-slate-200 text-slate-600 hover:text-indigo-600 hover:border-indigo-500">
                    1
                </a>
                @if (startPage > 2) {
                    <span class="text-slate-400 font-black tracking-widest px-1">...</span>
                }
            }

            @for (int i = startPage; i <= endPage; i++) {
                <a href="@string.Format(Model.UrlFormat, i)" 
                   class="w-10 h-10 rounded-xl border flex items-center justify-center text-xs font-black transition-all @(Model.CurrentPage == i ? "bg-indigo-600 border-indigo-600 text-white shadow-lg shadow-indigo-100" : "bg-white border-slate-200 text-slate-600 hover:text-indigo-600 hover:border-indigo-500")">
                    @i
                </a>
            }

            @if (endPage < Model.TotalPages) {
                @if (endPage < Model.TotalPages - 1) {
                    <span class="text-slate-400 font-black tracking-widest px-1">...</span>
                }
                <a href="@string.Format(Model.UrlFormat, Model.TotalPages)" 
                   class="w-10 h-10 rounded-xl border flex items-center justify-center text-xs font-black transition-all bg-white border-slate-200 text-slate-600 hover:text-indigo-600 hover:border-indigo-500">
                    @Model.TotalPages
                </a>
            }
        </div>

        <a href="@string.Format(Model.UrlFormat, Model.CurrentPage + 1)" 
           class="w-10 h-10 rounded-xl border border-slate-200 bg-white flex items-center justify-center text-slate-500 hover:text-indigo-600 hover:border-indigo-500 transition-all @(Model.CurrentPage >= Model.TotalPages ? "opacity-50 pointer-events-none" : "")">
            <i class="fas fa-chevron-right"></i>
        </a>
    </div>
}
