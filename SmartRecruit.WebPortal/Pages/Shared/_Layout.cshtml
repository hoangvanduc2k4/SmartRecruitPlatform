@using WebPortal.Services.Api
@using System.Security.Claims
@inject ITokenService TokenService
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartRecruit</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-slate-50 text-slate-900 font-sans min-h-screen flex flex-col selection:bg-indigo-100 selection:text-indigo-900">
    <header class="sticky top-0 z-[100] h-20 bg-white/70 backdrop-blur-2xl border-b border-slate-200/50 px-8 flex items-center justify-between">
        <div class="flex items-center gap-12">
            <a href="/" class="flex items-center gap-3 group">
                <div class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center font-black text-white shadow-lg shadow-indigo-200 group-hover:rotate-6 transition-transform">SR</div>
                <span class="font-black tracking-tighter text-xl uppercase text-slate-900">SmartRecruit</span>
            </a>

            <nav class="hidden lg:flex items-center gap-8">
                @{
                    var userPrincipal = TokenService.GetUserPrincipal();
                    var userRole = userPrincipal?.FindFirstValue(ClaimTypes.Role)?.ToUpper() ?? "";
                    var userName = userPrincipal?.FindFirstValue("Fullname") ?? "User";
                    var avatarUrl = userPrincipal?.FindFirstValue("AvatarUrl");
                }
                @if (userRole != "ADMIN")
                {
                    <a href="/Jobs" class="text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-indigo-600 transition-colors">Jobs Explorer</a>
                }
                
                @if (userRole == "RECRUITER")
                {
                    <a href="/RecruiterJobs" class="text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-indigo-600 transition-colors">Recruitment Hub</a>
                    <a href="/Wallet" class="text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-indigo-600 transition-colors">Ví Nexus</a>
                }

                @if (userRole == "CANDIDATE")
                {
                    <a href="/Dashboard" class="text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-indigo-600 transition-colors">My Applications</a>
                    <a href="/SavedJobs" class="text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-indigo-600 transition-colors">Saved Jobs</a>
                }

                @if (userRole == "ADMIN")
                {
                    <a href="/AdminDashboard" class="text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-indigo-600 transition-colors">Command Center</a>
                    <a href="/AdminUsers" class="text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-indigo-600 transition-colors">User Registry</a>
                    <a href="/AdminOversight" class="text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-indigo-600 transition-colors">Oversight & Audit</a>
                }
            </nav>
        </div>

        <div class="flex items-center gap-5">
            @if (string.IsNullOrEmpty(userRole))
            {
                <a href="/Auth">
                    <button class="h-11 px-6 text-[10px] bg-indigo-600 text-white font-bold rounded-2xl hover:bg-indigo-700 transition-colors">Access Terminal</button>
                </a>
            }
            else
            {
                @if (userRole == "RECRUITER")
                {
                    <a href="/Wallet" class="hidden md:flex items-center gap-3 px-4 py-2 bg-indigo-50 rounded-2xl border border-indigo-100 group hover:bg-indigo-600 transition-all">
                        <i class="fas fa-wallet text-indigo-600 group-hover:text-white"></i>
                        <span class="text-[11px] font-black text-indigo-900 group-hover:text-white tabular-nums">2,500,000 <span class="text-[9px] opacity-50">VND</span></span>
                    </a>
                }

                <div class="relative group/notif">
                    <button id="notif-btn" class="w-11 h-11 rounded-2xl bg-slate-100/50 flex items-center justify-center text-slate-500 hover:bg-slate-200/50 transition-all relative cursor-pointer">
                        <i class="fas fa-bell"></i>
                        <span id="notif-badge" class="absolute top-3 right-3 w-2 h-2 bg-red-500 rounded-full border-2 border-white animate-pulse hidden"></span>
                    </button>
                    <!-- Notifications Dropdown -->
                    <div class="absolute right-0 mt-2 w-80 bg-white rounded-3xl shadow-2xl border border-slate-100 p-6 invisible opacity-0 group-hover/notif:visible group-hover/notif:opacity-100 transition-all duration-300 z-50">
                        <div class="flex justify-between items-center mb-5">
                            <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-400">Incoming Data</h4>
                            <button onclick="clearAllNotifications()" class="text-[9px] font-bold text-indigo-600 uppercase">Clear All</button>
                        </div>
                        <div id="notification-list" class="space-y-3 max-h-[350px] overflow-y-auto custom-scrollbar pr-1 text-left">
                            <div class="text-center p-4 text-slate-400 text-xs" id="empty-notif" style="display: none;">No new notifications.</div>
                        </div>
                    </div>
                </div>

                <div class="relative group">
                    <button class="flex items-center gap-3 p-1.5 pr-4 bg-slate-100/50 rounded-2xl border border-slate-200/20 hover:border-indigo-500/30 transition-all">
                        <div class="w-8 h-8 rounded-xl bg-white text-slate-900 flex items-center justify-center font-bold text-xs shadow-sm overflow-hidden">
                            @if (!string.IsNullOrEmpty(avatarUrl))
                            {
                                <img src="@avatarUrl" alt="Avatar" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <i class="fas fa-user"></i>
                            }
                        </div>
                        <div class="text-left hidden sm:block">
                            <p class="text-[10px] font-black text-slate-900 truncate max-w-[100px] leading-none capitalize">@userName</p>
                            <p class="text-[8px] font-black text-indigo-500 uppercase tracking-widest mt-1">@userRole</p>
                        </div>
                    </button>
                    <!-- Dropdown on hover -->
                    <div class="absolute right-0 mt-2 w-60 bg-white rounded-2xl shadow-2xl border border-slate-100 p-2 invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-300">
                        <div class="p-4 border-b border-slate-50 mb-2">
                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Authenticated As</p>
                            <p class="text-sm font-black text-slate-900 capitalize">@userRole</p>
                        </div>
                        <a href="/Profile" class="flex items-center gap-3 px-4 py-3 hover:bg-slate-50 rounded-xl text-[10px] font-black uppercase text-slate-500 hover:text-indigo-600 transition-all">
                            <i class="fas fa-fingerprint opacity-50 w-4 text-center"></i> View Identity
                        </a>
                        <a href="/SavedJobs" class="flex items-center gap-3 px-4 py-3 hover:bg-slate-50 rounded-xl text-[10px] font-black uppercase text-slate-500 hover:text-indigo-600 transition-all">
                            <i class="fas fa-heart opacity-50 w-4 text-center"></i> Saved Missions
                        </a>
                        <a href="/Auth?handler=Logout" class="flex w-full items-center gap-3 px-4 py-3 hover:bg-red-50 text-red-500 rounded-xl text-[10px] font-black uppercase transition-all text-left">
                            <i class="fas fa-power-off opacity-50 w-4 text-center"></i> Terminate Session
                        </a>
                    </div>
                </div>
            }
        </div>
    </header>

    @{
        var isFullWidth = ViewData["FullWidth"] as bool? ?? false;
        var mainClasses = isFullWidth 
            ? "flex-1 w-full" 
            : "flex-1 max-w-7xl mx-auto w-full p-8 md:p-12";
    }
    <main class="@mainClasses">
        @RenderBody()
    </main>

    <footer class="bg-white border-t border-slate-200/60 py-16 px-8 mt-auto">
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
            <div class="space-y-6">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-slate-900 rounded-lg flex items-center justify-center font-black text-white text-sm">SR</div>
                    <span class="font-black text-lg uppercase tracking-tighter">SmartRecruit</span>
                </div>
                <p class="text-xs text-slate-400 leading-relaxed font-medium">The most advanced AI-powered recruitment ecosystem for the modern era. Blueprinting for ASP.NET architecture.</p>
            </div>
            <div class="space-y-4 text-right col-span-3">
                <h5 class="text-[10px] font-black uppercase tracking-widest text-slate-900">System Status</h5>
                <span class="inline-flex items-center px-4 py-2 border font-bold text-[10px] uppercase rounded-full border-green-200 bg-green-50 text-green-700">All Sectors Operational</span>
                <p class="text-[10px] text-slate-300 mt-4 uppercase font-black">© 2026 SmartRecruit Nexus</p>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (userRole != "")
    {
        var rawApiUrl = Configuration["ApiBaseUrl"] ?? "https://localhost:7001/api/";
        var hubUrl = rawApiUrl.Replace("/api/", "/notificationHub");
        <script>
            window.appConfig = {
                apiBaseUrl: '@rawApiUrl',
                notificationHubUrl: '@hubUrl',
                accessToken: '@TokenService.GetAccessToken()'
            };
        </script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
        <script src="~/js/notification.js" asp-append-version="true"></script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
