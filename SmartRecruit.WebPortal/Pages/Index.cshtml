@page
@model IndexModel
@{
    ViewData["Title"] = "Neural Hiring Redefined";
    ViewData["FullWidth"] = true;
}

<div class="animate-in fade-in duration-1000 overflow-hidden font-sans text-slate-900 selection:bg-indigo-200">


    <!-- MESH GRADIENT BACKGROUND -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
        <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-indigo-200/40 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[-5%] right-[-5%] w-[40%] h-[40%] bg-violet-200/30 rounded-full blur-[100px]"></div>
        <div class="absolute top-[30%] right-[10%] w-[30%] h-[30%] bg-blue-100/50 rounded-full blur-[80px]"></div>
    </div>

    <!-- HERO SECTION -->
    <section class="relative min-h-[85vh] flex items-center pt-10 pb-24 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 lg:gap-8 items-center relative z-10 w-full">
            
            <div class="space-y-10 text-center lg:text-left">
                <div class="inline-flex items-center px-4 py-2 rounded-full text-xs font-bold border border-indigo-100 bg-white/70 backdrop-blur-md shadow-sm text-indigo-700 animate-in slide-in-from-bottom-4 duration-700">
                    <span class="flex items-center gap-2">
                        <span class="w-2 h-2 bg-indigo-500 rounded-full shadow-[0_0_8px_rgba(99,102,241,0.8)] animate-pulse"></span>
                        Hệ Sinh Thái Tuyển Dụng Dẫn Dắt Bởi AI
                    </span>
                </div>

                <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-[5.5rem] font-black tracking-tight leading-[1.05] animate-in slide-in-from-bottom-8 duration-1000 text-slate-800">
                    Tuyển Dụng <br class="hidden lg:block"/>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 via-primary to-violet-600 drop-shadow-[0_2px_2px_rgba(0,0,0,0.1)]">Nhân Tài</span><br class="hidden lg:block"/> 
                    Nhanh Chóng.
                </h1>

                <p class="text-lg md:text-xl text-slate-600 font-medium max-w-2xl mx-auto lg:mx-0 leading-relaxed animate-in fade-in duration-1000 delay-300">
                    Khai phá sức mạnh của AI Gemini để kết nối nhân tài công nghệ với những vị trí hàng đầu. Đánh giá hồ sơ khách quan, kết quả tức thì và thanh toán liền mạch.
                </p>

                <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 pt-4 animate-in zoom-in-95 duration-1000 delay-500">
                    <a href="/Jobs" class="w-full sm:w-auto">
                        <button class="w-full sm:w-auto inline-flex items-center justify-center font-bold transition-all h-14 px-8 text-sm shadow-xl shadow-indigo-200/50 rounded-2xl hover:-translate-y-1 hover:shadow-2xl hover:shadow-indigo-300/50 bg-indigo-600 text-white">
                            Khám Phá Việc Làm <i class="fas fa-arrow-right ml-2 opacity-70"></i>
                        </button>
                    </a>
                    <a href="/Auth" class="w-full sm:w-auto">
                        <button class="w-full sm:w-auto inline-flex items-center justify-center font-bold transition-all h-14 px-8 text-sm rounded-2xl bg-white border border-slate-200 hover:border-indigo-400 text-slate-700 hover:bg-slate-50 shadow-sm hover:shadow-md">
                            Đăng Tin Tuyển Dụng <i class="fas fa-rocket ml-2 text-indigo-500"></i>
                        </button>
                    </a>
                </div>

                <div class="pt-8 flex items-center justify-center lg:justify-start gap-6 text-sm font-semibold text-slate-500 opacity-80">
                    <div class="flex items-center gap-2"><i class="fas fa-check-circle text-indigo-500"></i> 99.8% Độ Phù Hợp</div>
                    <div class="flex items-center gap-2"><i class="fas fa-bolt text-amber-500"></i> 10x Tốc Độ Lọc CV</div>
                </div>
            </div>

            <!-- HERO VISUAL -->
            <div class="relative w-full max-w-lg mx-auto lg:max-w-none lg:h-full flex items-center justify-center animate-in fade-in duration-1000 delay-700 group">
                <div class="absolute inset-0 bg-gradient-to-tr from-indigo-500/20 to-violet-500/20 rounded-[3rem] rotate-6 group-hover:rotate-12 transition-transform duration-700 blur-2xl"></div>
                <div class="relative w-full aspect-square md:aspect-auto md:h-[600px] bg-white rounded-[2.5rem] border border-slate-100 shadow-[0_20px_50px_-12px_rgba(0,0,0,0.1)] overflow-hidden p-6 flex flex-col gap-4 group-hover:-translate-y-2 transition-transform duration-700">
                    <!-- Faux UI Header -->
                    <div class="flex justify-between items-center px-2 pb-4 border-b border-slate-50/80">
                        <div class="flex gap-2">
                            <div class="w-3 h-3 rounded-full bg-slate-200"></div>
                            <div class="w-3 h-3 rounded-full bg-slate-200"></div>
                            <div class="w-3 h-3 rounded-full bg-slate-200"></div>
                        </div>
                        <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest"><i class="fas fa-lock mr-1"></i> AI Neural Match ACTIVE</div>
                    </div>
                    
                    <!-- Faux Candidate Score Card -->
                    <div class="bg-slate-50 rounded-3xl p-6 border border-slate-100 flex items-center gap-6 relative overflow-hidden">
                        <div class="absolute right-0 top-0 w-32 h-32 bg-indigo-500/10 rounded-full -mr-16 -mt-16 blur-xl"></div>
                        <img src="https://i.pravatar.cc/150?img=11" alt="Candidate" class="w-20 h-20 rounded-2xl object-cover shadow-sm border-2 border-white relative z-10" />
                        <div class="flex-1 relative z-10">
                            <h4 class="font-black text-slate-800 text-lg">Trần Công C</h4>
                            <p class="text-xs text-slate-500 font-medium mb-3">Kỹ Sư Phần Mềm Backend Senior</p>
                            <div class="w-full bg-slate-200 rounded-full h-2 overflow-hidden">
                                <div class="bg-indigo-600 h-2 rounded-full" style="width: 96%"></div>
                            </div>
                        </div>
                        <div class="text-right relative z-10">
                            <span class="text-3xl font-black text-indigo-600">96</span><span class="text-sm font-bold text-indigo-400">%</span>
                            <p class="text-[9px] font-black uppercase text-slate-400 tracking-wider">Độ Phù Hợp</p>
                        </div>
                    </div>

                    <!-- Faux Job Card -->
                    <div class="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm flex-1 flex flex-col justify-between">
                         <div>
                            <div class="flex justify-between items-start mb-4">
                                <div class="w-12 h-12 rounded-xl bg-violet-100 text-violet-600 flex items-center justify-center text-xl shadow-inner"><i class="fab fa-microsoft"></i></div>
                                <span class="bg-green-100 text-green-700 text-[10px] font-black px-2 py-1 rounded uppercase tracking-wider">Ưu Tiên Gấp</span>
                            </div>
                            <h4 class="font-black text-slate-800 text-xl mb-1">Kiến trúc sư phần mềm Senior</h4>
                            <p class="text-sm text-slate-500 font-medium flex gap-3"><span><i class="fas fa-map-marker-alt text-indigo-400 mr-1"></i> Hồ Chí Minh</span> <span><i class="fas fa-dollar-sign text-emerald-500 mr-1"></i> 140k - 180k</span></p>
                         </div>
                         <div class="grid grid-cols-3 gap-2 mt-4 opacity-70">
                             <div class="h-8 bg-slate-100 rounded-lg flex items-center justify-center text-xs font-bold text-slate-600">C#</div>
                             <div class="h-8 bg-slate-100 rounded-lg flex items-center justify-center text-xs font-bold text-slate-600">ASP.NET</div>
                             <div class="h-8 bg-slate-100 rounded-lg flex items-center justify-center text-xs font-bold text-slate-600">React</div>
                         </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- RECOMMENDED JOBS (FOR CANDIDATES) -->
    @if (Model.RecommendedJobs != null && Model.RecommendedJobs.Any())
    {
        <section class="py-20 px-4 max-w-7xl mx-auto relative z-10">
            <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
                <div class="space-y-2">
                    <div class="inline-flex items-center gap-2 text-indigo-600 font-bold text-xs uppercase tracking-widest">
                        <i class="fas fa-sparkles"></i> Gợi ý tự động
                    </div>
                    <h2 class="text-3xl md:text-4xl font-black text-slate-900 tracking-tight">Việc Làm Phù Hợp Dành Cho Bạn</h2>
                    <p class="text-slate-500 font-medium">Được đánh giá dựa trên hồ sơ AI và kỹ năng của bạn.</p>
                </div>
                <a href="/Jobs" class="group flex items-center gap-2 font-bold text-sm text-indigo-600 hover:text-indigo-700 transition-colors">
                    Khám phá tất cả <i class="fas fa-arrow-right text-xs group-hover:translate-x-1 transition-transform"></i>
                </a>
            </div>

            <div class="flex overflow-x-auto pb-10 gap-6 snap-x snap-mandatory scrollbar-hide -mx-4 px-4">
                @foreach (var job in Model.RecommendedJobs)
                {
                    <a href="/JobDetail?id=@job.Id" class="group flex-shrink-0 w-[280px] snap-start">
                        <div class="h-full bg-white rounded-3xl border border-slate-100 p-6 shadow-sm hover:shadow-xl hover:shadow-indigo-100/40 hover:border-indigo-200 hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between relative">
                            <div>
                                <div class="flex justify-between items-start mb-6">
                                    <div class="w-12 h-12 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center text-xl text-indigo-600 shadow-inner group-hover:bg-indigo-600 group-hover:text-white transition-colors">
                                        <i class="fas fa-rocket"></i>
                                    </div>
                                    @if (job.IsBoosted)
                                    {
                                        <span class="inline-flex items-center px-2 py-1 rounded text-[10px] font-black uppercase tracking-wider bg-orange-100 text-orange-700">
                                            <i class="fas fa-fire mr-1"></i> HOT
                                        </span>
                                    }
                                </div>

                                @if (Model.IsAuthenticated)
                                {
                                    bool isSaved = Model.SavedJobIds.Contains(job.Id);
                                    <div class="absolute top-6 right-6 z-20">
                                        <form method="post" asp-page-handler="ToggleSave" class="m-0">
                                            <input type="hidden" name="jobId" value="@job.Id" />
                                            <button type="submit" 
                                                    class="w-10 h-10 rounded-xl flex items-center justify-center transition-all shadow-sm
                                                           @(isSaved ? "bg-red-50 text-red-500 border border-red-100" : "bg-slate-50 text-slate-400 border border-slate-100 hover:text-red-500 hover:bg-red-50")">
                                                <i class="@(isSaved ? "fas" : "far") fa-heart"></i>
                                            </button>
                                        </form>
                                    </div>
                                }

                                <h3 class="text-lg font-black text-slate-900 group-hover:text-indigo-600 transition-colors mb-1 truncate">@job.Title</h3>
                                <div class="flex justify-between items-center mb-4">
                                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest truncate">@job.Company</p>
                                    @if (job.ExpireDate.HasValue)
                                    {
                                        var daysLeft = (job.ExpireDate.Value.Date - DateTime.UtcNow.Date).Days;
                                        string expireText = daysLeft > 0 ? $"Còn {daysLeft} ngày" : (daysLeft == 0 ? "Hôm nay" : "Hết hạn");
                                        string expireColor = daysLeft > 3 ? "text-emerald-600 bg-emerald-50 border border-emerald-100" : (daysLeft >= 0 ? "text-amber-600 bg-amber-50 border border-amber-100" : "text-red-600 bg-red-50 border border-red-100");
                                        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[8px] font-black uppercase tracking-wider @expireColor">
                                            <i class="fas fa-clock mr-1"></i> @expireText
                                        </span>
                                    }
                                </div>
                                
                                <div class="flex flex-wrap gap-2 mb-6">
                                    @if (!string.IsNullOrEmpty(job.SkillsRequired))
                                    {
                                        var skills = job.SkillsRequired.Split(',', StringSplitOptions.RemoveEmptyEntries).Take(2);
                                        foreach(var skill in skills)
                                        {
                                            <span class="px-2 py-1 bg-slate-50 rounded-lg text-[10px] font-bold text-slate-500 border border-slate-100">@skill.Trim()</span>
                                        }
                                    }
                                </div>
                            </div>

                            <div class="pt-6 border-t border-slate-50 flex items-center justify-between">
                                <span class="text-sm font-black text-slate-700">
                                    @((job.SalaryMax / 1000).ToString("N0"))k <span class="text-[10px] font-medium text-slate-400">/ tháng</span>
                                </span>
                                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest truncate max-w-[100px]">
                                    <i class="fas fa-map-marker-alt mr-1"></i> @job.Location
                                </span>
                            </div>
                        </div>
                    </a>
                }
            </div>
        </section>
    }

    <!-- TRUST STRIP -->
    <section class="py-12 border-y border-slate-200/60 bg-white/50 backdrop-blur-md">
        <div class="max-w-7xl mx-auto px-4">
            <p class="text-center text-xs font-black uppercase tracking-widest text-slate-400 mb-8">Được tin dùng bởi các doanh nghiệp công nghệ hàng đầu</p>
            <div class="flex flex-wrap justify-center items-center gap-12 md:gap-24 opacity-40 grayscale hover:grayscale-0 transition-all duration-500">
                <span class="text-2xl font-black italic tracking-tighter flex items-center gap-2"><i class="fas fa-cube"></i> SYNAPSE</span>
                <span class="text-2xl font-black italic tracking-tighter flex items-center gap-2"><i class="fas fa-wave-square"></i> DATASYNC</span>
                <span class="text-2xl font-black italic tracking-tighter flex items-center gap-2"><i class="fas fa-globe"></i> NEXUS.LABS</span>
                <span class="text-2xl font-black italic tracking-tighter flex items-center gap-2"><i class="fas fa-shield-alt"></i> COMMAND.CORE</span>
            </div>
        </div>
    </section>

    <!-- FEATURES OVERVIEW -->
    <section class="py-32 px-4 max-w-7xl mx-auto">
        <div class="text-center max-w-3xl mx-auto mb-20 space-y-4">
            <h2 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tight">Nền Tảng Tuyển Dụng Hiện Đại</h2>
            <p class="text-lg text-slate-500 font-medium">Tất cả những công cụ bạn cần để tìm kiếm, đánh giá và tuyển chọn nhân tài hoàn hảo.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative z-10">
            <!-- Feature 1 -->
            <div class="p-10 rounded-[2.5rem] bg-white border border-slate-100 shadow-sm hover:border-indigo-300 transition-all duration-500 hover:shadow-2xl hover:shadow-indigo-100/40 hover:-translate-y-2 group">
                <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-8 bg-indigo-50 transition-all group-hover:bg-indigo-600 group-hover:text-white text-indigo-600 shadow-inner">
                    <i class="fas fa-brain text-2xl"></i>
                </div>
                <h4 class="text-xl font-black text-slate-900 mb-3">Tự Động Máy Học Kép</h4>
                <p class="text-slate-500 font-medium leading-relaxed text-sm">Hệ thống gợi ý ứng viên tự động khớp CV với yêu cầu kỹ năng và môi trường công ty, giảm thiểu đáng kể thời gian sàng lọc hồ sơ thủ công.</p>
            </div>
            
            <!-- Feature 2 -->
            <div class="p-10 rounded-[2.5rem] bg-white border border-slate-100 shadow-sm hover:border-violet-300 transition-all duration-500 hover:shadow-2xl hover:shadow-violet-100/40 hover:-translate-y-2 group mt-0 md:mt-12">
                <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-8 bg-violet-50 transition-all group-hover:bg-violet-600 group-hover:text-white text-violet-600 shadow-inner">
                    <i class="fas fa-wallet text-2xl"></i>
                </div>
                <h4 class="text-xl font-black text-slate-900 mb-3">Tích Hợp Thanh Toán Ví</h4>
                <p class="text-slate-500 font-medium leading-relaxed text-sm">Hệ thống ví tiền ảo tích hợp mượt mà, giúp nhà tuyển dụng có thể chủ động thanh toán và kích hoạt gói công việc ưu tiên lên trang chủ ngay lập tức.</p>
            </div>

            <!-- Feature 3 -->
            <div class="p-10 rounded-[2.5rem] bg-white border border-slate-100 shadow-sm hover:border-blue-300 transition-all duration-500 hover:shadow-2xl hover:shadow-blue-100/40 hover:-translate-y-2 group">
                <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-8 bg-blue-50 transition-all group-hover:bg-blue-600 group-hover:text-white text-blue-600 shadow-inner">
                    <i class="fas fa-project-diagram text-2xl"></i>
                </div>
                <h4 class="text-xl font-black text-slate-900 mb-3">Quản Lý Trực Quan Trực Tiếp</h4>
                <p class="text-slate-500 font-medium leading-relaxed text-sm">Sử dụng quy trình Kanban thân thiện để kéo thả các hồ sơ đến vòng phỏng vấn hay mời nhận việc mà không tốn nhiều thao tác rườm rà.</p>
            </div>
        </div>
    </section>

    <!-- CTA SECTION -->
    <section class="py-24 px-4 relative overflow-hidden">
        <div class="absolute inset-0 bg-slate-900 -z-20"></div>
        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNjAiIGhlaWdodD0iNjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4wNykiLz48L3N2Zz4=')] opacity-50 pointer-events-none"></div>
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-indigo-600/30 rounded-full blur-[150px] -z-10 translate-x-1/3 -translate-y-1/3"></div>
        
        <div class="max-w-4xl mx-auto text-center space-y-10 relative z-10">
            <h2 class="text-4xl md:text-6xl font-black text-white tracking-tight leading-tight">
                Nâng Tầm Trải Nghiệm <br/> Tuyển Dụng Thật Dễ Dàng.
            </h2>
            <p class="text-lg text-slate-300 font-medium max-w-2xl mx-auto">
                Hãy là người dẫn đầu trong xu hướng công nghệ kết nối nhân lực hiện đại với nền tảng của chúng tôi.
            </p>
            <div class="pt-4 flex flex-col sm:flex-row justify-center gap-4">
                <a href="/Auth">
                    <button class="w-full sm:w-auto h-16 px-10 bg-white text-slate-900 font-black rounded-2xl hover:bg-indigo-50 shadow-[0_0_40px_rgba(255,255,255,0.3)] hover:shadow-[0_0_60px_rgba(255,255,255,0.5)] hover:-translate-y-1 transition-all duration-300 text-sm tracking-wide">
                        Khởi Tạo Ngay Miễn Phí
                    </button>
                </a>
                <a href="/Jobs">
                    <button class="w-full sm:w-auto h-16 px-10 bg-transparent border border-slate-600 text-white font-bold rounded-2xl hover:bg-slate-800 hover:border-slate-500 transition-all duration-300 text-sm">
                        Xem Các Việc Làm Open
                    </button>
                </a>
            </div>
        </div>
    </section>

</div>

<style>
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
    .scrollbar-hide {
        -ms-overflow-style: none; /* IE and Edge */
        scrollbar-width: none; /* Firefox */
    }
    @@keyframes shimmer {
        100% { transform: translateX(200%) skewX(-12deg); }
    }
</style>
