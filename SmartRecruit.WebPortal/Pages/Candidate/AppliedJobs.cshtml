@page "/Candidate/AppliedJobs"
@model WebPortal.Pages.Candidate.AppliedJobsModel
@using WebPortal.Models
@{
    ViewData["Title"] = "My Applied Jobs";
}

<div class="space-y-12 animate-in fade-in duration-700">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-indigo-50 border border-indigo-100 text-indigo-700 shadow-sm">Candidate Dashboard</span>
            <h2 class="text-5xl font-black text-slate-800 tracking-tighter uppercase mt-2">Applied Missions</h2>
            <p class="text-slate-500 text-sm font-medium mt-1">Track your progress and neural compatibility across all submitted applications.</p>
        </div>
        <a href="/Jobs" class="inline-flex">
            <button class="px-10 h-14 bg-indigo-600 text-white shadow-xl shadow-indigo-100 rounded-2xl font-black uppercase tracking-widest text-[11px] hover:bg-indigo-700 transition-all active:scale-95">
                <i class="fas fa-search mr-2"></i> Explore More Missions
            </button>
        </a>
    </div>

    <!-- Overview Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-8 bg-white border border-slate-200 rounded-3xl shadow-sm group hover:border-indigo-200 transition-all duration-300">
            <div class="w-14 h-14 bg-indigo-600 rounded-2xl flex items-center justify-center text-white mb-6 shadow-lg shadow-indigo-100 group-hover:scale-110 transition-transform">
                <i class="fas fa-paper-plane text-xl"></i>
            </div>
            <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2">Total Applications</p>
            <h3 class="text-3xl font-black text-slate-900 tracking-tighter">@Model.AppliedJobs.Count</h3>
        </div>
        <div class="p-8 bg-white border border-slate-200 rounded-3xl shadow-sm group hover:border-amber-200 transition-all duration-300">
            <div class="w-14 h-14 bg-amber-500 rounded-2xl flex items-center justify-center text-white mb-6 shadow-lg shadow-amber-100 group-hover:scale-110 transition-transform">
                <i class="fas fa-spinner text-xl"></i>
            </div>
            <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2">In Review</p>
            <h3 class="text-3xl font-black text-slate-900 tracking-tighter">@Model.AppliedJobs.Count(a => a.Status != ApplicationStatus.REJECTED)</h3>
        </div>
        <div class="p-8 bg-white border border-slate-200 rounded-3xl shadow-sm group hover:border-green-200 transition-all duration-300">
            <div class="w-14 h-14 bg-green-500 rounded-2xl flex items-center justify-center text-white mb-6 shadow-lg shadow-green-100 group-hover:scale-110 transition-transform">
                <i class="fas fa-brain text-xl"></i>
            </div>
            <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2">Avg compatibility</p>
            <h3 class="text-3xl font-black text-slate-900 tracking-tighter">
                @(Model.AppliedJobs.Any() ? Model.AppliedJobs.Average(a => a.MatchScore).ToString("F0") + "%" : "0%")
            </h3>
        </div>
    </div>

    <!-- Application List -->
    <div class="overflow-hidden border border-slate-200/60 shadow-2xl shadow-slate-200/20 bg-white rounded-[2.5rem]">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead class="bg-slate-50/50 border-b border-slate-100">
                    <tr>
                        <th class="px-10 py-8 text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Mission Identity</th>
                        <th class="px-8 py-8 text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Compatibility</th>
                        <th class="px-8 py-8 text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Deployment Status</th>
                        <th class="px-8 py-8 text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Submission Date</th>
                        <th class="px-10 py-8 text-[11px] font-black text-slate-400 uppercase tracking-[0.2em] text-right">Operation</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @if (!Model.AppliedJobs.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-10 py-32 text-center">
                                <div class="flex flex-col items-center gap-6">
                                    <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center text-slate-200">
                                        <i class="fas fa-folder-open text-4xl"></i>
                                    </div>
                                    <div class="space-y-2">
                                        <p class="text-xl font-bold text-slate-800">No missions launched yet</p>
                                        <p class="text-sm text-slate-400 font-medium">Your application history is empty. Start exploring new opportunities.</p>
                                    </div>
                                    <a href="/Jobs" class="px-8 py-3 bg-slate-900 text-white rounded-xl text-xs font-black uppercase tracking-widest hover:bg-slate-800 transition-all">Launch First Application</a>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var app in Model.AppliedJobs)
                        {
                            <tr class="group hover:bg-slate-50/50 transition-all duration-300">
                                <td class="px-10 py-8">
                                    <div class="flex flex-col gap-1">
                                        <a href="/Jobs/JobDetail?Id=@app.JobId" class="text-lg font-black text-slate-800 group-hover:text-indigo-600 transition-colors">@app.JobTitle</a>
                                        <p class="text-xs font-bold text-slate-400 flex items-center gap-2 uppercase tracking-tight">
                                            <i class="fas fa-building text-slate-300"></i> @app.Company
                                        </p>
                                    </div>
                                </td>
                                <td class="px-8 py-8">
                                    <div class="flex items-center gap-4">
                                        <div class="relative w-12 h-12 flex items-center justify-center">
                                            <svg class="w-full h-full transform -rotate-90">
                                                <circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width="4" fill="transparent" class="text-slate-100" />
                                                <circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width="4" fill="transparent" class="@(app.MatchScore > 80 ? "text-green-500" : app.MatchScore > 50 ? "text-indigo-500" : "text-amber-500")" 
                                                        stroke-dasharray="@(2 * Math.PI * 20)" 
                                                        stroke-dashoffset="@(2 * Math.PI * 20 * (1 - (double)app.MatchScore / 100))" />
                                            </svg>
                                            <span class="absolute text-[10px] font-black text-slate-700">@app.MatchScore.ToString("N0")%</span>
                                        </div>
                                        <div class="hidden sm:block">
                                            <p class="text-[10px] font-black text-slate-800 uppercase tracking-tighter">Match Index</p>
                                            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-tighter">Neural Verification</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-8 py-8">
                                    @{
                                        var statusClass = app.Status switch {
                                            ApplicationStatus.OFFERED => "bg-green-50 text-green-600 border-green-100",
                                            ApplicationStatus.REJECTED => "bg-red-50 text-red-600 border-red-100",
                                            ApplicationStatus.REVIEWING => "bg-indigo-50 text-indigo-600 border-indigo-100",
                                            _ => "bg-slate-50 text-slate-600 border-slate-100"
                                        };
                                    }
                                    <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest border @statusClass shadow-sm font-black">
                                        <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>
                                        @app.Status
                                    </span>
                                </td>
                                <td class="px-8 py-8">
                                    <p class="text-xs font-bold text-slate-800 tracking-tight">@app.CreatedAt.ToString("MMM dd, yyyy")</p>
                                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mt-0.5">@app.CreatedAt.ToString("HH:mm") UTC</p>
                                </td>
                                <td class="px-10 py-8 text-right">
                                    <div class="flex justify-end items-center gap-3 opacity-0 group-hover:opacity-100 transition-all translate-x-4 group-hover:translate-x-0">
                                        <a href="/Jobs/JobDetail?Id=@app.JobId" class="w-12 h-12 bg-white border border-slate-200 text-slate-600 flex items-center justify-center rounded-2xl hover:bg-slate-900 hover:text-white hover:border-slate-900 transition-all shadow-sm active:scale-90">
                                            <i class="fas fa-arrow-right text-xs"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="flex justify-center pb-12">
        <partial name="_Pagination" model='(Model.CurrentPage, Model.TotalPages, $"?CurrentPage={{0}}")' />
    </div>
</div>
