@page "/Dashboard"
@model SmartRecruitWeb.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="space-y-12 animate-in fade-in duration-1000 pb-32">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div class="space-y-2">
            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-indigo-50 border border-indigo-100 text-indigo-700 shadow-sm">Identity Hub</span>
            <h2 class="text-5xl font-black text-slate-900 tracking-tighter uppercase">Application Mission Log</h2>
            <p class="text-slate-500 font-medium">Tracking your active engagements within the neural network.</p>
        </div>
    </div>

    <div class="overflow-hidden bg-white rounded-[3rem] shadow-xl border border-slate-200">
        <table class="w-full text-left">
            <thead class="bg-slate-50/50 border-b border-slate-100">
                <tr>
                    <th class="px-12 py-8 text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">Mission Target</th>
                    <th class="px-12 py-8 text-[10px] font-black text-slate-400 uppercase tracking-[0.3em] text-center">Score</th>
                    <th class="px-12 py-8 text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">Status</th>
                    <th class="px-12 py-8 text-[10px] font-black text-slate-400 uppercase tracking-[0.3em] text-right">Applied Date</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
                @if (Model.UserApplications.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="px-12 py-32 text-center text-slate-300 italic uppercase font-black text-[10px] tracking-widest">
                            No active missions identified.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var app in Model.UserApplications)
                    {
                        var job = Model.RelatedJobs.FirstOrDefault(j => j.Id == app.JobId);
                        <tr class="hover:bg-slate-50 transition-colors group">
                            <td class="px-12 py-10">
                                <a href="/JobDetail?Id=@job?.Id" class="font-black text-slate-900 text-lg group-hover:text-indigo-600 transition-colors">@(job?.Title ?? "Unknown")</a>
                                <p class="text-[10px] font-bold text-slate-400 uppercase mt-1 tracking-widest">@(job?.Location ?? "Unknown")</p>
                            </td>
                            <td class="px-12 py-10 text-center">
                                <span class="text-2xl font-black text-indigo-600">@app.MatchScore.ToString("N0")%</span>
                            </td>
                            <td class="px-12 py-10">
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest bg-indigo-50 border border-indigo-100 text-indigo-600">@app.Status</span>
                            </td>
                            <td class="px-12 py-10 text-right text-[10px] font-black text-slate-400 uppercase">
                                @app.AppliedAt.ToString("MMM dd, yyyy")
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model='(Model.CurrentPage, Model.TotalPages, "?CurrentPage={0}")' />
</div>
