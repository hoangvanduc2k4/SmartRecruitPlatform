@page "/SavedJobs"
@model WebPortal.Pages.Candidate.SavedJobsModel
@using WebPortal.Models
@{
    ViewData["Title"] = "My Bookmarked Missions";
}

<div class="space-y-12 animate-in fade-in duration-700">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-pink-50 border border-pink-100 text-pink-700 shadow-sm">Talent Collection</span>
            <h2 class="text-5xl font-black text-slate-800 tracking-tighter uppercase mt-2">Bookmarked Missions</h2>
            <p class="text-slate-500 text-sm font-medium mt-1">Your curated list of high-priority professional targets.</p>
        </div>
        <a href="/Jobs" class="inline-flex">
            <button class="px-8 h-14 bg-slate-900 text-white shadow-xl shadow-slate-200 rounded-2xl font-black uppercase tracking-widest text-[11px] hover:bg-slate-800 transition">
                <i class="fas fa-search mr-2"></i> Explore More
            </button>
        </a>
    </div>

    @if (Model.SavedJobs.Count == 0)
    {
        <div class="py-32 text-center bg-white rounded-[3rem] border-2 border-dashed border-slate-200 shadow-inner">
            <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-6">
                <i class="far fa-heart text-3xl text-slate-200"></i>
            </div>
            <h3 class="text-xl font-black text-slate-400 uppercase tracking-widest">No Missions Logged</h3>
            <p class="text-slate-400 text-xs font-bold uppercase tracking-widest mt-2">Your collection is currently empty. Start scouting!</p>
            <a href="/Jobs" class="inline-block mt-8 text-indigo-600 font-black uppercase tracking-widest text-[10px] hover:underline">Return to Nexus Discovery</a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
            @foreach (var job in Model.SavedJobs)
            {
                <div class="group bg-white border border-slate-200/60 rounded-[2.5rem] p-8 shadow-sm hover:shadow-2xl hover:shadow-indigo-100/50 transition-all duration-500 relative overflow-hidden flex flex-col justify-between h-[420px]">
                    <div class="absolute top-0 right-0 p-8">
                        <form method="post" asp-page-handler="Unsave">
                            <input type="hidden" name="jobId" value="@job.Id" />
                            <button type="submit" class="w-12 h-12 bg-pink-50 text-pink-500 rounded-2xl flex items-center justify-center border border-pink-100 shadow-sm hover:bg-pink-100 transition-colors">
                                <i class="fas fa-heart text-xl"></i>
                            </button>
                        </form>
                    </div>

                    <div class="space-y-6">
                        <div class="w-16 h-16 bg-slate-900 rounded-2xl flex items-center justify-center text-white text-2xl shadow-xl">
                            <i class="fas fa-briefcase"></i>
                        </div>
                        
                        <div>
                            <span class="text-[9px] font-black uppercase tracking-widest text-indigo-500 bg-indigo-50 px-3 py-1 rounded-full border border-indigo-100">@job.Category</span>
                            <h3 class="text-2xl font-black text-slate-900 tracking-tight mt-3 line-clamp-2 group-hover:text-indigo-600 transition-colors">@job.Title</h3>
                        </div>

                        <div class="space-y-3">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2">
                                <i class="fas fa-location-dot text-indigo-400"></i> @job.Location
                            </p>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2">
                                <i class="fas fa-vault text-amber-400"></i> Est: $@job.SalaryMin.ToString("N0") - $@job.SalaryMax.ToString("N0")
                            </p>
                        </div>
                    </div>

                    <div class="mt-8 pt-6 border-t border-slate-50 flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <span class="inline-flex items-center px-3 py-1 rounded-lg text-[9px] font-black uppercase tracking-widest bg-slate-50 border border-slate-100 text-slate-600">@job.JobType</span>
                        </div>
                        <a href="/JobDetail?id=@job.Id" class="inline-flex">
                            <button class="px-6 h-11 bg-indigo-600 text-white rounded-xl font-black uppercase tracking-widest text-[10px] shadow-lg shadow-indigo-100 hover:bg-indigo-700 transition">
                                Launch Target
                            </button>
                        </a>
                    </div>
                </div>
            }
        </div>

        <partial name="_Pagination" model='(Model.CurrentPage, Model.TotalPages, "?CurrentPage={0}")' />
    }
</div>
