@page "/JobApplications"
@model WebPortal.Pages.JobApplicationsModel
@using WebPortal.Models
@{
    ViewData["Title"] = "Danh Sách Ứng Viên";
}

<div class="space-y-10 animate-in fade-in duration-700 pb-32">
    <div class="flex flex-col gap-4 mb-6">
        <div class="flex items-center gap-3">
            <a href="/RecruiterJobs" class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-slate-200 rounded-xl text-[11px] font-black uppercase tracking-widest text-slate-600 hover:text-indigo-600 hover:border-indigo-100 transition-all shadow-sm">
                <i class="fas fa-arrow-left"></i> Quay lại danh sách
            </a>
            <a asp-page="/Jobs/JobDetail" asp-route-Id="@Model.Id" class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-50 border border-indigo-100 rounded-xl text-[11px] font-black uppercase tracking-widest text-indigo-600 hover:bg-indigo-100 transition-all shadow-sm">
                <i class="fas fa-info-circle"></i> Chi Tiết Job
            </a>
        </div>
        <div>
            <h2 class="text-2xl font-black text-slate-900 uppercase tracking-tight">Danh Sách Ứng Tuyển</h2>
            <p class="text-[9px] font-bold text-slate-400 uppercase mt-1">Sắp xếp theo độ phù hợp • Mã Bài Đăng #@Model.Id</p>
        </div>
    </div>

    <div class="bg-white rounded-[2rem] border border-slate-200 shadow-2xl overflow-hidden animate-in fade-in slide-in-from-bottom-4 duration-500">
        <div class="p-8 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
            <div>
                <h4 class="text-[12px] font-black uppercase tracking-[0.3em] text-slate-900">Ứng Viên</h4>
                <p class="text-[9px] font-bold text-slate-400 uppercase mt-1">@Model.TotalApplicationCount ứng viên</p>
            </div>
            <form method="post" asp-page-handler="BulkReject" id="bulkRejectForm" class="m-0 hidden">
                <input type="hidden" name="Id" value="@Model.Job.Id" />
                <div id="hiddenInputsWrapper"></div>
            </form>
            <button type="button" onclick="submitBulkReject()" id="bulkRejectBtn" class="hidden h-10 px-6 bg-red-50 text-red-500 font-bold text-[10px] uppercase tracking-widest rounded-xl border border-red-100 hover:bg-red-500 hover:text-white transition-all">
                Từ Chối Hàng Loạt (<span id="selectedCount">0</span>)
            </button>
        </div>
        <table class="w-full text-left">
            <thead class="bg-slate-50/80 border-b border-slate-100">
                <tr>
                    <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest w-16 text-center">
                        <input type="checkbox" id="selectAllApps" class="w-4 h-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer" onclick="toggleAllCheckboxes(this)" />
                    </th>
                    <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center w-12">#</th>
                    <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Hồ Sơ Ứng Viên</th>
                    <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Độ Phù Hợp</th>
                    <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Trạng Thái</th>
                    <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Thao Tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
                @foreach (var app in Model.Applications)
                {
                    <tr class="hover:bg-indigo-50/20 transition-all">
                        <th class="px-8 py-6 text-center text-xs">
                            <input type="checkbox" name="selectedApplications" value="@app.Id" class="app-checkbox w-4 h-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer" onclick="updateBulkRejectBtn()" />
                        </th>
                        <td class="px-8 py-6 text-center text-xs text-slate-400">
                            <i class="fas fa-fingerprint"></i>
                        </td>
                        <td class="px-8 py-6">
                            <div class="flex items-center gap-4">
                                <img src="https://i.pravatar.cc/150?u=@app.CandidateId" class="w-12 h-12 rounded-xl object-cover shadow-sm" alt="" />
                                <div>
                                    <p class="font-black text-slate-900">@app.CandidateName</p>
                                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-0.5 flex items-center gap-2">
                                        Mã số: #@app.Id <span class="text-slate-200">|</span> @app.CreatedAt.ToString("MMM dd, yyyy")
                                    </p>
                                </div>
                            </div>
                        </td>
                        <td class="px-8 py-6 text-center">
                            <div class="inline-flex flex-col items-center">
                                <span class="text-2xl font-black @(app.MatchScore > 80 ? "text-indigo-600" : app.MatchScore > 50 ? "text-amber-600" : "text-slate-400")">@app.MatchScore.ToString("N0")%</span>
                                <div class="w-16 h-1 bg-slate-100 rounded-full mt-1 overflow-hidden">
                                    <div class="h-full bg-indigo-500" style="width: @app.MatchScore%"></div>
                                </div>
                            </div>
                        </td>
                        <td class="px-8 py-6">
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest @(app.Status == ApplicationStatus.REJECTED ? "bg-red-50 text-red-600" : "bg-indigo-50 text-indigo-600")">
                                @(app.Status switch {
                                    ApplicationStatus.REVIEWING => "Đang xem xét",
                                    ApplicationStatus.INTERVIEWING => "Phỏng vấn",
                                    ApplicationStatus.OFFERED => "Đã mời làm việc",
                                    ApplicationStatus.REJECTED => "Đã từ chối",
                                    _ => app.Status.ToString()
                                })
                            </span>
                        </td>
                        <td class="px-8 py-6 text-right">
                            <div class="flex justify-end gap-2">
                                <a href="/CandidatePreview/@app.Id" class="inline-flex">
                                    <button type="button" class="h-10 px-4 rounded-xl bg-white border border-slate-200 text-[9px] font-black uppercase text-slate-600 hover:text-indigo-600 hover:border-indigo-500 transition-all shadow-sm">Chi Tiết</button>
                                </a>
                                <form method="post" asp-page-handler="UpdateStatus" class="inline">
                                    <input type="hidden" name="Id" value="@Model.Job.Id" />
                                    <input type="hidden" name="applicationId" value="@app.Id" />
                                    
                                    @if (app.Status != ApplicationStatus.REJECTED)
                                    {
                                        <input type="hidden" name="status" value="@ApplicationStatus.REJECTED" />
                                        <button type="submit" class="w-10 h-10 rounded-xl bg-red-50 text-red-500 border border-red-100 flex items-center justify-center hover:bg-red-500 hover:text-white transition-all" title="Từ Chối"><i class="fas fa-times text-xs"></i></button>
                                    }
                                    else
                                    {
                                        <input type="hidden" name="status" value="@ApplicationStatus.REVIEWING" />
                                        <button type="submit" class="w-10 h-10 rounded-xl bg-green-50 text-green-500 border border-green-100 flex items-center justify-center hover:bg-green-500 hover:text-white transition-all" title="Khôi Phục"><i class="fas fa-rotate-left text-xs"></i></button>
                                    }
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (Model.Applications.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="py-24 text-center text-[10px] font-black uppercase text-slate-300 italic tracking-[0.4em]">Danh sách trống - Chưa có ứng viên nào ứng tuyển.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model='(Model.CurrentPage, Model.TotalPages, $"?Id={Model.Id}&CurrentPage={{0}}")' />
</div>

@section Scripts {
    <script>
        function toggleAllCheckboxes(source) {
            const checkboxes = document.querySelectorAll('.app-checkbox');
            checkboxes.forEach(cb => cb.checked = source.checked);
            updateBulkRejectBtn();
        }

        function updateBulkRejectBtn() {
            const checked = document.querySelectorAll('.app-checkbox:checked');
            const btn = document.getElementById('bulkRejectBtn');
            const countSpan = document.getElementById('selectedCount');

            if (checked.length > 0) {
                btn.classList.remove('hidden');
                countSpan.innerText = checked.length;
            } else {
                btn.classList.add('hidden');
            }
        }

        function submitBulkReject() {
            const checked = document.querySelectorAll('.app-checkbox:checked');
            const wrapper = document.getElementById('hiddenInputsWrapper');
            const form = document.getElementById('bulkRejectForm');
            
            wrapper.innerHTML = '';
            checked.forEach(cb => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'selectedApplications';
                input.value = cb.value;
                wrapper.appendChild(input);
            });
            
            if (checked.length > 0 && confirm(`Bạn có chắc chắn muốn từ chối ${checked.length} ứng viên đã chọn không?`)) {
                form.submit();
            }
        }
    </script>
}
