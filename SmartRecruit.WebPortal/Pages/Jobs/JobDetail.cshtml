                                        </div>
                                        <div class="space-y-3">
                                            <div class="flex justify-between text-[9px] font-black uppercase text-slate-500"><span>Khớp Kỹ Năng</span><span id="skillMatchValue">--</span></div>
                                            <div class="w-full h-1.5 bg-white/5 rounded-full overflow-hidden"><div class="h-full bg-indigo-500 shadow-[0_0_10px_rgba(79,70,229,0.5)]" style="width: 0%" id="skillMatchBar"></div></div>
