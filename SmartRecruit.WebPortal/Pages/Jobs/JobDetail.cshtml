@page "/JobDetail"
@model WebPortal.Pages.JobDetailModel
@using WebPortal.Models
@{
    ViewData["Title"] = Model.Job?.Title ?? "Job Board";
}

@if (Model.Job == null)
{
    <div class="p-32 text-center font-black uppercase text-slate-300">Không Tìm Thấy Công Việc</div>
}
else
{
    <div class="space-y-6 animate-in fade-in duration-700 pb-32">
        @if (TempData["Message"] != null)
        {
            <div class="p-4 bg-green-50 border border-green-100 text-green-700 rounded-2xl text-xs font-bold uppercase tracking-tight flex items-center gap-3">
                <i class="fas fa-check-circle"></i>
                @TempData["Message"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="p-4 bg-red-50 border border-red-100 text-red-700 rounded-2xl text-xs font-bold uppercase tracking-tight flex items-center gap-3">
                <i class="fas fa-exclamation-circle text-base"></i>
                @TempData["Error"]
            </div>
        }

        @if (Model.IsOwner)
        {
            <div class="flex flex-col gap-4 mb-2">
                <a href="/RecruiterJobs" class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-slate-200 rounded-xl text-[11px] font-black uppercase tracking-widest text-slate-600 hover:text-indigo-600 hover:border-indigo-100 transition-all shadow-sm w-fit">
                    <i class="fas fa-arrow-left"></i> Quay lại danh sách
                </a>
                <div class="flex items-center gap-3">
                    <a asp-page="/Jobs/JobApplications" asp-route-Id="@Model.Job.Id" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white border border-indigo-100 rounded-2xl text-[11px] font-black uppercase tracking-widest text-indigo-600 hover:bg-indigo-50 shadow-sm transition-all">
                        <i class="fas fa-users"></i> Ứng Viên (@Model.TotalApplicationCount)
                    </a>
                    <a asp-page="/Recruiter/JobPipeline" asp-route-id="@Model.Job.Id" class="inline-flex items-center gap-2 px-5 py-2.5 bg-slate-900 border border-slate-900 rounded-2xl text-[11px] font-black uppercase tracking-widest text-white hover:bg-slate-800 shadow-sm transition-all">
                        <i class="fas fa-layer-group"></i> Quản Lý Quy Trình
                    </a>
                </div>

                @if (!string.IsNullOrEmpty(Model.Job.DraftChanges))
                {
                    <div class="mt-2 p-4 bg-amber-50 border border-amber-200 rounded-2xl flex items-center justify-between shadow-sm">
                        <div class="flex items-center gap-3 text-amber-700">
                            <i class="fas fa-exclamation-triangle"></i>
                            <span class="text-xs font-bold uppercase tracking-tight">Bản Nháp Đang Chờ Duyệt</span>
                        </div>
                        <p class="text-[10px] font-bold text-amber-600 uppercase">Chỉ Hiển Thị Với Bạn</p>
                    </div>
                }
            </div>
        }
        
        <!-- HEADER -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 bg-white p-10 rounded-[2.5rem] border border-slate-200 shadow-xl shadow-slate-200/20 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-indigo-50 rounded-full -mr-16 -mt-16 blur-3xl opacity-50"></div>
            <div>
                @if (Model.IsRecruiter || Model.IsAdmin)
                {
                    <div class="flex items-center gap-3 mb-2">
                        <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-indigo-50 border border-indigo-100 text-indigo-700 shadow-sm">Mã Tín: @Model.Job.Id</span>
                        @{
                            var statusClass = Model.Job.Status switch {
                                JobStatus.APPROVED => "bg-green-50 border-green-100 text-green-700",
                                JobStatus.BLOCKED => "bg-red-50 border-red-100 text-red-700",
                                JobStatus.DRAFT => "bg-slate-50 border-slate-100 text-slate-400",
                                JobStatus.CHECKING => "bg-amber-50 border-amber-100 text-amber-700",
                                _ => "bg-slate-50 border-slate-100 text-slate-400"
                            };
                        }
                        <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest border shadow-sm @statusClass">@Model.Job.Status</span>
                        @if (Model.Job.IsBoosted)
                        {
                            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-yellow-100 border border-yellow-200 text-yellow-800 shadow-sm animate-pulse">ĐANG ĐẨY TOP</span>
                        }
                    </div>
                }
                <div class="flex items-center gap-6">
                    <h1 class="text-4xl font-black text-slate-900 tracking-tighter uppercase">@Model.Job.Title</h1>
                    @if (Model.IsAuthenticated)
                    {
                      <div class="flex items-center gap-3">
    <form method="post" asp-page-handler="ToggleSave" class="inline-flex m-0 items-center gap-2">
        <input type="hidden" name="Id" value="@Model.Job.Id" />
        <button type="submit"
                title="@(Model.IsSaved ? "Xóa khỏi Việc làm đã lưu" : "Lưu việc làm này")"
                class="h-12 px-4 rounded-2xl flex items-center justify-center gap-2 text-xs font-black uppercase tracking-widest transition-all
                        @(Model.IsSaved
                            ? "bg-red-50 text-red-500 border border-red-100 shadow-xl shadow-red-100/50 hover:bg-red-100"
                            : "bg-slate-50 text-slate-400 border border-slate-100 hover:text-red-500 hover:bg-red-50")">
            <i class="@(Model.IsSaved ? "fas" : "far") fa-heart text-base"></i>
            <span>@(Model.IsSaved ? "Đã lưu" : "Lưu tin")</span>
        </button>
    </form>

    @if (!Model.IsOwner && Model.CurrentUserDto?.Role == WebPortal.Models.UserRole.CANDIDATE)
    {
        @if (Model.MyApplication == null)
        {
            <form method="post" asp-page-handler="Apply" class="inline-flex m-0 items-center">
                <input type="hidden" name="Id" value="@Model.Job.Id" />
                <button type="submit" 
                        class="h-12 px-6 bg-indigo-600 text-white rounded-2xl flex items-center justify-center gap-2 text-xs font-black uppercase tracking-widest transition-all shadow-xl shadow-indigo-200 hover:bg-indigo-700 disabled:opacity-50 disabled:cursor-not-allowed" 
                        disabled="@(!Model.HasCV)" 
                        title="@(!Model.HasCV ? "Vui lòng cập nhật CV trong Hồ sơ của bạn để ứng tuyển" : "Gửi hồ sơ ứng tuyển")">
                    <i class="fas fa-paper-plane text-base"></i>
                    <span>Ứng tuyển ngay</span>
                </button>
            </form>
        }
        else
        {
            <button disabled class="h-12 px-6 bg-green-50 text-green-600 border border-green-200 rounded-2xl flex items-center justify-center gap-2 text-xs font-black uppercase tracking-widest cursor-default">
                <i class="fas fa-check-circle text-base"></i>
                <span>Đã ứng tuyển</span>
            </button>
        }
    }
</div>

                    }
                </div>
                <p class="text-slate-400 font-bold uppercase tracking-widest text-[10px] mt-2 flex items-center gap-2">
                    <i class="fas fa-location-dot text-indigo-500"></i> @Model.Job.Location
                    <span class="text-slate-200">|</span>
                    <i class="fas fa-folder text-indigo-500"></i> @Model.Job.Category
                </p>
            </div>

            @if (Model.IsOwner)
            {
                <div class="flex gap-3 relative z-10">
                    <span class="px-5 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest bg-slate-50 text-slate-400 border border-slate-100">Tính Năng Nhà Tuyển Dụng</span>
                </div>
            }
        </div>

        <!-- CONTENT AREA -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
            <div class="lg:col-span-2 p-10 bg-white rounded-[2rem] border border-slate-200/60 shadow-lg space-y-8">
                        <div class="flex justify-between items-center pb-6 border-b border-slate-50">
                            <h4 class="text-[12px] font-black uppercase tracking-widest text-slate-900">Thông Tin Chi Tiết</h4>
                            @if (Model.IsOwner) {
                                <span class="bg-yellow-100 text-yellow-800 text-[10px] font-black px-3 py-1 rounded-full">Chế Độ Chỉnh Sửa</span>
                            }
                        </div>

                        <form class="space-y-6" id="jobEditForm" method="post" asp-page-handler="Update">
                            <input type="hidden" name="Id" value="@Model.Job.Id" />
                            <input type="hidden" name="EditJob.Id" value="@Model.Job.Id" />
                            <input type="hidden" name="Tab" value="@Model.Tab" />

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Tiêu Đề Công Việc</label>
                                    <input type="text" name="EditJob.Title" value="@Model.Job.Title" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsOwner ? "disabled" : "") />
                                </div>
                                <div>
                                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Tên Công Ty</label>
                                    <input type="text" name="EditJob.Company" value="@Model.Job.Company" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsOwner ? "disabled" : "") />
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Loại Công Việc</label>
                                    <select name="EditJob.JobType" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsOwner ? "disabled" : "")>
                                        <option value="0" selected="@(Model.Job.JobType == JobType.FULL_TIME)">Toàn Thời Gian</option>
                                        <option value="1" selected="@(Model.Job.JobType == JobType.PART_TIME)">Bán Thời Gian</option>
                                        <option value="2" selected="@(Model.Job.JobType == JobType.REMOTE)">Làm Việc Từ Xa</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Kỹ Năng Yêu Cầu (cách nhau bởi dấu phẩy)</label>
                                    <input type="text" name="EditJob.SkillsRequired" value="@Model.Job.SkillsRequired" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsOwner ? "disabled" : "") />
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Địa Điểm</label>
                                    <input type="text" name="EditJob.Location" value="@Model.Job.Location" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsOwner ? "disabled" : "") />
                                </div>
                                <div>
                                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Danh Mục</label>
                                    <select name="EditJob.CategoryId" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsOwner ? "disabled" : "")>
                                        @foreach (var cat in Model.Categories)
                                        {
                                            <option value="@cat.Id" selected="@(Model.Job.CategoryId == cat.Id)">@cat.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="grid grid-cols-2 gap-4">
                                    <div>
                                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Lương Tối Thiểu</label>
                                        <input type="number" name="EditJob.SalaryMin" value="@Model.Job.SalaryMin" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsOwner ? "disabled" : "") />
                                    </div>
                                    <div>
                                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Lương Tối Đa</label>
                                        <input type="number" name="EditJob.SalaryMax" value="@Model.Job.SalaryMax" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsOwner ? "disabled" : "") />
                                    </div>
                                </div>
                            </div>

                            <div>
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Quyền Lợi</label>
                                <textarea name="EditJob.Benefits" class="w-full p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none min-h-[100px]" @(!Model.IsOwner ? "disabled" : "")>@Model.Job.Benefits</textarea>
                            </div>

                            <div>
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Yêu Cầu Công Việc</label>
                                <textarea name="EditJob.Requirement" class="w-full p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none min-h-[100px]" @(!Model.IsOwner ? "disabled" : "")>@Model.Job.Requirement</textarea>
                            </div>
                            <div>
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Mô Tả Công Việc</label>
                                <textarea name="EditJob.Description" class="w-full p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none min-h-[250px]" @(!Model.IsOwner ? "disabled" : "")>@Model.Job.Description</textarea>
                            </div>
                        </form>

                        @if (Model.IsOwner)
                        {
                            <div class="pt-10 flex flex-col sm:flex-row justify-end items-center gap-4 border-t border-slate-50">
                                <!-- Boost Button -->
                                <form method="post" asp-page-handler="Boost" class="w-full sm:w-auto">
                                    <input type="hidden" name="Id" value="@Model.Job.Id" />
                                    <button type="submit" class="w-full sm:w-auto h-14 px-8 gap-3 group bg-white border border-slate-200 text-slate-700 font-bold rounded-2xl flex justify-center items-center shadow-sm disabled:opacity-50 hover:bg-slate-50 transition-all" @(Model.Job.IsBoosted || Model.Job.Status != JobStatus.APPROVED ? "disabled" : "")>
                                        <i class="fas fa-fire-flame-curved @(Model.Job.IsBoosted ? "text-slate-300" : "text-amber-300 group-hover:scale-125 transition-transform")"></i>
                                        @(Model.Job.Status != JobStatus.APPROVED ? "Đăng bài trước khi lên Top" : (Model.Job.IsBoosted ? "Đã Đẩy Top" : "Đẩy Lên Top (20k VNĐ)"))
                                    </button>
                                </form>

                                <!-- Save Draft Button -->
                                <button type="submit" form="jobEditForm" class="w-full sm:w-auto h-14 px-8 bg-white border border-slate-200 text-slate-700 font-bold rounded-2xl flex justify-center items-center hover:bg-slate-50 shadow-sm transition-all">
                                    <i class="fas fa-save mr-2"></i> Lưu Bản Nháp
                                </button>

                                <!-- Publish Button -->
                                <form method="post" asp-page-handler="Publish" class="w-full sm:w-auto">
                                    <input type="hidden" name="Id" value="@Model.Job.Id" />
                                    <button type="submit" class="w-full sm:w-auto h-14 px-10 bg-indigo-600 text-white font-bold rounded-2xl shadow-lg shadow-indigo-200 hover:bg-indigo-700 hover:shadow-indigo-300 transition-all flex justify-center items-center">
                                        <i class="fas fa-paper-plane mr-2"></i> Đăng Bài (@(Model.Job.Status == JobStatus.APPROVED ? "25k" : "50k") VNĐ)
                                    </button>
                                </form>
                            </div>
                        }
            </div>

            <div class="space-y-8">
                <div class="p-8 bg-slate-900 text-white rounded-[2rem] border-0 shadow-2xl relative overflow-hidden group">
                    <div class="absolute top-0 right-0 p-8 opacity-10 text-7xl"><i class="fas fa-dna"></i></div>
                    <div class="relative z-10 space-y-6">
                        <p class="text-[10px] font-black uppercase tracking-[0.3em] text-indigo-400">Trình Độ Tương Thích</p>
                        @if (!Model.IsOwner)
                        {
                            <div class="space-y-6">
                                @if (!Model.IsAuthenticated)
                                {
                                    <p class="text-xs text-slate-400 leading-relaxed font-medium">Vui lòng đăng nhập để xem độ tương thích và ứng tuyển.</p>
                                    <a href="/Auth" class="w-full h-16 bg-white/10 border border-white/20 text-white font-bold rounded-2xl hover:bg-white hover:text-slate-900 transition-all flex items-center justify-center gap-2">
                                        <i class="fas fa-sign-in-alt"></i> Yêu Cầu Đăng Nhập
                                    </a>
                                }
                                else if (!Model.HasCV)
                                {
                                    <div class="p-5 bg-amber-500/10 border border-amber-500/20 rounded-2xl space-y-4">
                                        <p class="text-[10px] font-black uppercase text-amber-400 tracking-widest flex items-center gap-2">
                                            <i class="fas fa-exclamation-triangle"></i> Chưa Tải CV
                                        </p>
                                        <p class="text-xs text-slate-300 leading-relaxed">Hồ sơ của bạn chưa hoàn thiện. Vui lòng tải CV lên để tiếp tục.</p>
                                        <a href="/Profile" class="w-full h-12 bg-amber-600 text-white text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-amber-700 transition flex items-center justify-center">
                                            Cập Nhật Hồ Sơ
                                        </a>
                                    </div>
                                }
                                else if (Model.MyApplication != null)
                                {
                                    <div class="space-y-6 animate-in zoom-in-95 duration-500">
                                     @if (Model.MyApplication.MatchScore == 0 && string.IsNullOrEmpty(Model.MyApplication.AI_Summary))
{
    <div id="ai-evaluating-wrapper">
        <div class="p-6 bg-indigo-500/10 border border-indigo-500/20 rounded-3xl text-center space-y-4">
            <div class="inline-flex items-center px-3 py-1 bg-indigo-500 text-white rounded-full text-[9px] font-black uppercase tracking-widest mb-2">
                Đang Ứng Tuyển
            </div>
            <div class="py-4">
                <i class="fas fa-dna fa-spin text-4xl text-indigo-400 mb-3"></i>
                <p class="text-[10px] font-black uppercase tracking-widest text-slate-300">Đang đánh giá hồ sơ...</p>
                <p class="text-xs text-slate-400 mt-2">Trí tuệ nhân tạo đang phân tích độ tương thích của bạn. Vui lòng chờ trong giây lát...</p>
            </div>
        </div>
    </div>

    <div id="ai-result-wrapper" class="hidden space-y-6">
        <div class="p-6 bg-indigo-500/10 border border-indigo-500/20 rounded-3xl text-center space-y-4">
            <div class="inline-flex items-center px-3 py-1 bg-indigo-500 text-white rounded-full text-[9px] font-black uppercase tracking-widest mb-2">
                Đang Ứng Tuyển
            </div>
            <div class="flex justify-center items-end gap-1">
                <span id="ai-match-score" class="text-6xl font-black text-white tracking-tighter">0</span>
                <span class="text-xl font-bold text-indigo-400 mb-2">%</span>
            </div>
            <p class="text-[9px] font-black uppercase tracking-widest text-slate-400">Kết quả độ tương thích hệ thống</p>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div class="p-4 bg-white/5 border border-white/10 rounded-2xl">
                <p class="text-[8px] font-black uppercase text-slate-500 mb-2 tracking-widest">Kỹ năng</p>
                <p class="text-lg font-black text-white"><span id="ai-skill-match">0</span>%</p>
            </div>
            <div class="p-4 bg-white/5 border border-white/10 rounded-2xl">
                <p class="text-[8px] font-black uppercase text-slate-500 mb-2 tracking-widest">Kinh nghiệm</p>
                <p class="text-lg font-black text-white"><span id="ai-exp-match">0</span>%</p>
            </div>
        </div>

        <div id="ai-summary-box" class="hidden p-5 bg-white/5 border border-white/10 rounded-2xl space-y-3">
            <p class="text-[9px] font-black uppercase text-indigo-400 tracking-widest flex items-center gap-2">
                <i class="fas fa-robot"></i> Phân tích từ AI
            </p>
            <p id="ai-summary-text" class="text-xs text-slate-300 leading-relaxed italic"></p>
        </div>
    </div>
}
else
{
    <div id="ai-result-wrapper" class="space-y-6">
        <div class="p-6 bg-indigo-500/10 border border-indigo-500/20 rounded-3xl text-center space-y-4">
            <div class="inline-flex items-center px-3 py-1 bg-indigo-500 text-white rounded-full text-[9px] font-black uppercase tracking-widest mb-2">
                Đang Ứng Tuyển
            </div>
            <div class="flex justify-center items-end gap-1">
                <span id="ai-match-score" class="text-6xl font-black text-white tracking-tighter">@((int)(Model.MyApplication.MatchScore))</span>
                <span class="text-xl font-bold text-indigo-400 mb-2">%</span>
            </div>
            <p class="text-[9px] font-black uppercase tracking-widest text-slate-400">Kết quả độ tương thích hệ thống</p>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div class="p-4 bg-white/5 border border-white/10 rounded-2xl">
                <p class="text-[8px] font-black uppercase text-slate-500 mb-2 tracking-widest">Kỹ năng</p>
                <p class="text-lg font-black text-white"><span id="ai-skill-match">@((int)(Model.MyApplication.SkillMatch))</span>%</p>
            </div>
            <div class="p-4 bg-white/5 border border-white/10 rounded-2xl">
                <p class="text-[8px] font-black uppercase text-slate-500 mb-2 tracking-widest">Kinh nghiệm</p>
                <p class="text-lg font-black text-white"><span id="ai-exp-match">@((int)(Model.MyApplication.ExperienceMatch))</span>%</p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.MyApplication.AI_Summary))
        {
            <div id="ai-summary-box" class="p-5 bg-white/5 border border-white/10 rounded-2xl space-y-3">
                <p class="text-[9px] font-black uppercase text-indigo-400 tracking-widest flex items-center gap-2">
                    <i class="fas fa-robot"></i> Phân tích từ AI
                </p>
                <p id="ai-summary-text" class="text-xs text-slate-300 leading-relaxed italic">"@Model.MyApplication.AI_Summary"</p>
            </div>
        }
    </div>
}

                                        <div class="text-center pt-2">
                                            <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest flex items-center justify-center gap-2">
                                                <i class="fas fa-check-double text-emerald-500"></i> Hồ Sơ Đã Được Chốt
