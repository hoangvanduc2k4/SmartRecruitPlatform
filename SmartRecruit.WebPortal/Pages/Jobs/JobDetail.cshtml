@section Scripts {
    <script>
        function simulateMatch() {
            const btn = event.currentTarget;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Đang Phân Tích...';
            btn.disabled = true;

            setTimeout(() => {
                document.getElementById('matchingSection').classList.add('hidden');
                document.getElementById('resultSection').classList.remove('hidden');
            }, 1500);
        }

        function toggleAllCheckboxes(source) {
            const checkboxes = document.querySelectorAll('.app-checkbox');
            checkboxes.forEach(cb => cb.checked = source.checked);
            updateBulkRejectBtn();
        }

        function updateBulkRejectBtn() {
            const checked = document.querySelectorAll('.app-checkbox:checked');
            const btn = document.getElementById('bulkRejectBtn');
            const countSpan = document.getElementById('selectedCount');
            const selectAllCheck = document.getElementById('selectAllApps');
            
            if (checked.length > 0) {
                btn.classList.remove('hidden');
                countSpan.innerText = checked.length;
            } else {
                btn.classList.add('hidden');
            }

            const totalCheckboxes = document.querySelectorAll('.app-checkbox').length;
            if (selectAllCheck) {
                selectAllCheck.checked = (totalCheckboxes > 0 && checked.length === totalCheckboxes);
            }
        }

        function submitBulkReject() {
            const checked = document.querySelectorAll('.app-checkbox:checked');
            const wrapper = document.getElementById('hiddenInputsWrapper');
            const form = document.getElementById('bulkRejectForm');
            
            wrapper.innerHTML = '';
            checked.forEach(cb => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'selectedApplications';
                input.value = cb.value;
                wrapper.appendChild(input);
            });
            
            if (checked.length > 0 && confirm(`Bạn có chắc chắn muốn từ chối ${checked.length} ứng viên đã chọn không?`)) {
                form.submit();
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            if (window.notificationHubConnection) {
                window.notificationHubConnection.on("ReceiveApplicationScoreUpdate", function (update) {
                    if (update.jobId == @Model.Job.Id) {
                        const evalWrapper = document.getElementById('ai-evaluating-wrapper');
                        const resultWrapper = document.getElementById('ai-result-wrapper');
                        
                        if (evalWrapper) evalWrapper.classList.add('hidden');
                        if (resultWrapper) resultWrapper.classList.remove('hidden');

                        const matchScoreEl = document.getElementById('ai-match-score');
                        const skillMatchEl = document.getElementById('ai-skill-match');
                        const expMatchEl = document.getElementById('ai-exp-match');
                        
                        if (matchScoreEl) matchScoreEl.innerText = Math.round(update.matchScore || 0);
                        if (skillMatchEl) skillMatchEl.innerText = Math.round(update.skillMatch || 0);
                        if (expMatchEl) expMatchEl.innerText = Math.round(update.experienceMatch || 0);

                        const summaryTextStr = update.aI_Summary || update.ai_Summary || update.AI_Summary;
                        if (summaryTextStr) {
                            const summaryBox = document.getElementById('ai-summary-box');
                            const summaryText = document.getElementById('ai-summary-text');
                            if (summaryBox) summaryBox.classList.remove('hidden');
                            if (summaryText) summaryText.innerText = '"' + summaryTextStr + '"';
                        }
                    }
                });
            }
        });
    </script>
}
