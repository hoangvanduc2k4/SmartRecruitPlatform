@page "/JobDetail"
@model WebPortal.Pages.JobDetailModel
@using WebPortal.Models
@{
    ViewData["Title"] = Model.Job?.Title ?? "Job Board";
}

@if (Model.Job == null)
{
    <div class="p-32 text-center font-black uppercase text-slate-300">Mission Target Not Found</div>
}
else
{
    <div class="space-y-10 animate-in fade-in duration-700 pb-32">
        <!-- HEADER -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 bg-white p-10 rounded-[2.5rem] border border-slate-200 shadow-xl shadow-slate-200/20 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-indigo-50 rounded-full -mr-16 -mt-16 blur-3xl opacity-50"></div>
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-indigo-50 border border-indigo-100 text-indigo-700 shadow-sm">Mission @Model.Job.Id</span>
                    @if (Model.Job.IsBoosted)
                    {
                        <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-yellow-100 border border-yellow-200 text-yellow-800 shadow-sm animate-pulse">BOOSTED ACTIVE</span>
                    }
                </div>
                <div class="flex items-center gap-6">
                    <h1 class="text-4xl font-black text-slate-900 tracking-tighter uppercase">@Model.Job.Title</h1>
                    <form method="post" asp-page-handler="ToggleSave" class="inline-flex m-0">
                        <input type="hidden" name="Id" value="@Model.Job.Id" />
                        <button type="submit" title="@(Model.IsSaved ? "Unsave Mission" : "Save Mission")" class="w-12 h-12 rounded-2xl flex items-center justify-center transition-all @(Model.IsSaved ? "bg-red-50 text-red-500 border border-red-100 shadow-xl shadow-red-100/50" : "bg-slate-50 text-slate-400 border border-slate-100 hover:text-red-500 hover:bg-red-50")">
                            <i class="@(Model.IsSaved ? "fas" : "far") fa-heart text-xl"></i>
                        </button>
                    </form>
                </div>
                <p class="text-slate-400 font-bold uppercase tracking-widest text-[10px] mt-2 flex items-center gap-2">
                    <i class="fas fa-location-dot text-indigo-500"></i> @Model.Job.Location
                    <span class="text-slate-200">|</span>
                    <i class="fas fa-folder text-indigo-500"></i> @Model.Job.Category
                </p>
            </div>

            @if (Model.IsRecruiter)
            {
                <div class="flex bg-slate-100 p-1.5 rounded-2xl border border-slate-200 relative z-10">
                    <a href="/JobDetail?Id=@Model.Job.Id&Tab=DETAILS" class="px-6 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(Model.Tab == "DETAILS" ? "bg-white shadow-xl text-indigo-600" : "text-slate-400 hover:text-slate-600")">Detail & Edit</a>
                    <a href="/JobDetail?Id=@Model.Job.Id&Tab=APPLICANTS" class="px-6 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(Model.Tab == "APPLICANTS" ? "bg-white shadow-xl text-indigo-600" : "text-slate-400 hover:text-slate-600")">Applicants (@Model.TotalApplicationCount)</a>
                    <a href="/JobDetail?Id=@Model.Job.Id&Tab=PIPELINE" class="px-6 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(Model.Tab == "PIPELINE" ? "bg-white shadow-xl text-indigo-600" : "text-slate-400 hover:text-slate-600")">ATS Pipeline</a>
                </div>
            }
        </div>

        <!-- CONTENT AREA -->
        <div class="grid grid-cols-1 gap-10">
            @if (Model.Tab == "DETAILS")
            {
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
                    <div class="lg:col-span-2 p-10 bg-white rounded-[2rem] border border-slate-200/60 shadow-lg space-y-8">
                        <div class="flex justify-between items-center pb-6 border-b border-slate-50">
                            <h4 class="text-[12px] font-black uppercase tracking-widest text-slate-900">Information Matrix</h4>
                            @if (Model.IsRecruiter) {
                                <span class="bg-yellow-100 text-yellow-800 text-[10px] font-black px-3 py-1 rounded-full">Edit Mode</span>
                            }
                        </div>

                        <form class="space-y-6" id="jobEditForm">
                            <div>
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Job Title</label>
                                <input type="text" value="@Model.Job.Title" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsRecruiter ? "disabled" : "") />
                            </div>
                            <div class="grid grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Location</label>
                                    <input type="text" value="@Model.Job.Location" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsRecruiter ? "disabled" : "") />
                                </div>
                                <div>
                                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Salary Range Max</label>
                                    <input type="number" value="@Model.Job.SalaryMax" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsRecruiter ? "disabled" : "") />
                                </div>
                            </div>
                            <div>
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Core Requirements</label>
                                <textarea class="w-full p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none min-h-[100px]" @(!Model.IsRecruiter ? "disabled" : "")>@Model.Job.Requirement</textarea>
                            </div>
                            <div>
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Mission Description</label>
                                <textarea class="w-full p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none min-h-[250px]" @(!Model.IsRecruiter ? "disabled" : "")>@Model.Job.Description</textarea>
                            </div>
                        </form>

                        @if (Model.IsRecruiter)
                        {
                            <div class="pt-10 flex justify-between items-center border-t border-slate-50">
                                <form method="post" asp-page-handler="Boost">
                                    <input type="hidden" name="Id" value="@Model.Job.Id" />
                                    <button type="submit" class="h-14 px-10 gap-3 group bg-white border border-slate-200 text-slate-700 font-bold rounded-2xl flex items-center shadow-sm disabled:opacity-50" @(Model.Job.IsBoosted ? "disabled" : "")>
                                        <i class="fas fa-fire-flame-curved @(Model.Job.IsBoosted ? "text-slate-300" : "text-amber-300 group-hover:scale-125 transition-transform")"></i>
                                        @(Model.Job.IsBoosted ? "Job is Already Boosted" : "Boost to Top (20k VND)")
                                    </button>
                                </form>
                                <button type="button" onclick="alert('Mock saving to DB...')" class="h-14 px-12 bg-indigo-600 text-white font-bold rounded-2xl shadow-lg shadow-indigo-100 hover:bg-indigo-700">
                                    <i class="fas fa-save mr-2"></i> Commit Changes
                                </button>
                            </div>
                        }
                    </div>

                    <div class="space-y-8">
                        <div class="p-8 bg-slate-900 text-white rounded-[2rem] border-0 shadow-2xl relative overflow-hidden group">
                            <div class="absolute top-0 right-0 p-8 opacity-10 text-7xl"><i class="fas fa-dna"></i></div>
                            <div class="relative z-10 space-y-6">
                                <p class="text-[10px] font-black uppercase tracking-[0.3em] text-indigo-400">Match Telemetry</p>
                                @if (!Model.IsRecruiter)
                                {
                                    <div class="space-y-6" id="matchingSection">
                                        <p class="text-xs text-slate-400 leading-relaxed font-medium">Analyze your professional DNA against this mission's requirements using our neural matching protocol.</p>
                                        <button type="button" onclick="simulateMatch()" class="w-full h-16 bg-transparent border border-white/10 text-white font-bold rounded-2xl hover:border-indigo-500 transition-all flex items-center justify-center">
                                            <i class="fas fa-microchip mr-2"></i> Initiate AI Match
                                        </button>
                                    </div>
                                    <div class="space-y-6 hidden animate-in zoom-in-95 duration-500" id="resultSection">
                                        <div class="text-center py-6">
                                            <span class="text-6xl font-black text-indigo-400 tracking-tighter" id="scoreValue">85%</span>
                                            <p class="text-[9px] font-black uppercase tracking-widest text-slate-400 mt-2">Neural Compatibility Score</p>
                                        </div>
                                        <div class="space-y-3">
                                            <div class="flex justify-between text-[9px] font-black uppercase text-slate-500"><span>Skills DNA</span><span id="skillMatchValue">90%</span></div>
                                            <div class="w-full h-1.5 bg-white/5 rounded-full overflow-hidden"><div class="h-full bg-indigo-500 shadow-[0_0_10px_rgba(79,70,229,0.5)]" style="width: 90%" id="skillMatchBar"></div></div>
                                        </div>
                                        <form method="post" asp-page-handler="Apply">
                                            <input type="hidden" name="Id" value="@Model.Job.Id" />
                                            <button type="submit" class="w-full h-16 bg-indigo-600 border-0 text-white font-bold rounded-2xl shadow-2xl shadow-indigo-900/50 hover:bg-indigo-700">Submit Identity Profile</button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <div class="space-y-4">
                                        <div class="p-5 bg-white/5 rounded-2xl border border-white/5 flex justify-between items-center">
                                            <span class="text-[9px] font-black uppercase text-slate-400">Total Views</span>
                                            <span class="text-xl font-black text-white">@Model.Job.ViewCount.ToString("N0")</span>
                                        </div>
                                        <div class="p-5 bg-white/5 rounded-2xl border border-white/5 flex justify-between items-center">
                                            <span class="text-[9px] font-black uppercase text-slate-400">Total Applications</span>
                                            <span class="text-xl font-black text-indigo-400">@Model.TotalApplicationCount</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (Model.Tab == "APPLICANTS" && Model.IsRecruiter)
            {
                <div class="bg-white rounded-[2rem] border border-slate-200 shadow-2xl overflow-hidden animate-in fade-in slide-in-from-bottom-4 duration-500">
                    <div class="p-8 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                        <div>
                            <h4 class="text-[12px] font-black uppercase tracking-[0.3em] text-slate-900">Talent Queue</h4>
                            <p class="text-[9px] font-bold text-slate-400 uppercase mt-1">Sorted by neural compatibility score</p>
                        </div>
                        <form method="post" asp-page-handler="BulkReject" id="bulkRejectForm" class="m-0 hidden">
                            <input type="hidden" name="Id" value="@Model.Job.Id" />
                            <div id="hiddenInputsWrapper"></div>
                        </form>
                        <button type="button" onclick="submitBulkReject()" id="bulkRejectBtn" class="hidden h-10 px-6 bg-red-50 text-red-500 font-bold text-[10px] uppercase tracking-widest rounded-xl border border-red-100 hover:bg-red-500 hover:text-white transition-all">Reject Selected (<span id="selectedCount">0</span>)</button>
                    </div>
                    <table class="w-full text-left">
                        <thead class="bg-slate-50/80 border-b border-slate-100">
                            <tr>
                                <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest w-16 text-center">
                                    <input type="checkbox" id="selectAllApps" class="w-4 h-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer" onclick="toggleAllCheckboxes(this)" />
                                </th>
                                <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center w-12">#</th>
                                <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Candidate Identity</th>
                                <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Neural Score</th>
                                <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Status</th>
                                <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            @foreach (var app in Model.Applications)
                            {
                                <tr class="hover:bg-indigo-50/20 transition-all">
                                    <th class="px-8 py-6 text-center text-xs">
                                        <input type="checkbox" name="selectedApplications" value="@app.Id" class="app-checkbox w-4 h-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer" onclick="updateBulkRejectBtn()" />
                                    </th>
                                    <td class="px-8 py-6 text-center text-xs text-slate-400">
                                        <i class="fas fa-fingerprint"></i>
                                    </td>
                                    <td class="px-8 py-6">
                                        <div class="flex items-center gap-4">
                                            <img src="https://i.pravatar.cc/150?u=@app.CandidateId" class="w-12 h-12 rounded-xl object-cover shadow-sm" alt="" />
                                            <div>
                                                <p class="font-black text-slate-900">@app.CandidateName</p>
                                                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-0.5 flex items-center gap-2">
                                                    Ref: #@app.Id <span class="text-slate-200">|</span> @app.CreatedAt.ToString("MMM dd, yyyy")
                                                </p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6 text-center">
                                        <div class="inline-flex flex-col items-center">
                                            <span class="text-2xl font-black @(app.MatchScore > 80 ? "text-indigo-600" : app.MatchScore > 50 ? "text-amber-600" : "text-slate-400")">@app.MatchScore.ToString("N0")%</span>
                                            <div class="w-16 h-1 bg-slate-100 rounded-full mt-1 overflow-hidden">
                                                <div class="h-full bg-indigo-500" style="width: @app.MatchScore%"></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest @(app.Status == ApplicationStatus.REJECTED ? "bg-red-50 text-red-600" : "bg-indigo-50 text-indigo-600")">@app.Status</span>
                                    </td>
                                    <td class="px-8 py-6 text-right">
                                        <div class="flex justify-end gap-2">
                                            <a href="/CandidatePreview/@app.Id" class="inline-flex">
                                                <button type="button" class="h-10 px-4 rounded-xl bg-white border border-slate-200 text-[9px] font-black uppercase text-slate-600 hover:text-indigo-600 hover:border-indigo-500 transition-all shadow-sm">Profile</button>
                                            </a>
                                            <form method="post" asp-page-handler="UpdateStatus" class="inline">
                                                <input type="hidden" name="Id" value="@Model.Job.Id" />
                                                <input type="hidden" name="applicationId" value="@app.Id" />
                                                
                                                @if (app.Status != ApplicationStatus.REJECTED)
                                                {
                                                    <input type="hidden" name="status" value="@ApplicationStatus.REJECTED" />
                                                    <button type="submit" class="w-10 h-10 rounded-xl bg-red-50 text-red-500 border border-red-100 flex items-center justify-center hover:bg-red-500 hover:text-white transition-all" title="Reject"><i class="fas fa-times text-xs"></i></button>
                                                }
                                                else
                                                {
                                                    <input type="hidden" name="status" value="@ApplicationStatus.REVIEWING" />
                                                    <button type="submit" class="w-10 h-10 rounded-xl bg-green-50 text-green-500 border border-green-100 flex items-center justify-center hover:bg-green-500 hover:text-white transition-all" title="Restore"><i class="fas fa-rotate-left text-xs"></i></button>
                                                }
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (Model.Applications.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="py-24 text-center text-[10px] font-black uppercase text-slate-300 italic tracking-[0.4em]">Queue Empty - No DNA profiles matched yet.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <partial name="_Pagination" model='(Model.CurrentPage, Model.TotalPages, $"?Id={Model.Id}&Tab={Model.Tab}&CurrentPage={{0}}")' />
            }

            @if (Model.Tab == "PIPELINE" && Model.IsRecruiter)
            {
                var statuses = new[]
                {
                    new { Status = ApplicationStatus.REVIEWING, Label = "Reviewing", Icon = "fa-search", Color = "bg-indigo-400 shadow-indigo-400/30" },
                    new { Status = ApplicationStatus.INTERVIEWING, Label = "Interview", Icon = "fa-comments", Color = "bg-amber-400 shadow-amber-400/30" },
                    new { Status = ApplicationStatus.OFFERED, Label = "Offer", Icon = "fa-gift", Color = "bg-green-400 shadow-green-400/30" },
                    new { Status = ApplicationStatus.REJECTED, Label = "Rejected Pool", Icon = "fa-circle-xmark", Color = "bg-red-400 shadow-red-400/30" }
                };

                <div class="space-y-10 animate-in fade-in slide-in-from-bottom-4 duration-500">
                    <div class="flex gap-8 overflow-x-auto pb-8 snap-x custom-scrollbar min-h-[700px] items-start">
                        @foreach (var col in statuses)
                        {
                            var appsInColumn = Model.Applications.Where(a => a.Status == col.Status).ToList();
                            
                            <div class="flex-shrink-0 w-80 snap-start flex flex-col gap-6 group/col">
                                <!-- Column Header -->
                                <div class="flex items-center justify-between px-4">
                                    <div class="flex items-center gap-4">
                                        <div class="w-3 h-3 rounded-full @col.Color shadow-lg ring-4 ring-white"></div>
                                        <span class="font-black text-slate-900 text-[10px] uppercase tracking-[0.3em]">@col.Label</span>
                                    </div>
                                    <span class="inline-flex items-center justify-center px-2 py-1 text-xs font-bold leading-none @(col.Status == ApplicationStatus.REJECTED ? "text-red-100 bg-red-600" : "text-indigo-100 bg-indigo-600") rounded-full">
                                        @appsInColumn.Count
                                    </span>
                                </div>

                                <!-- Column Body -->
                                <div class="rounded-[2.5rem] p-4 flex-1 border min-h-[600px] space-y-6 transition-all duration-300 @(col.Status == ApplicationStatus.REJECTED ? "bg-red-50/20 border-red-100/30 shadow-inner" : "bg-slate-100/40 border-slate-200/50 group-hover/col:bg-indigo-50/20 group-hover/col:border-indigo-100/50")">
                                    @if (appsInColumn.Count == 0)
                                    {
                                        <div class="py-32 text-center text-slate-400/20 flex flex-col items-center gap-4">
                                            <i class="fas @col.Icon text-5xl opacity-10"></i>
                                            <p class="text-[9px] font-black uppercase tracking-widest opacity-30 italic">No Identity Segment</p>
                                        </div>
                                    }
                                    
                                    @foreach (var app in appsInColumn)
                                    {
                                        <div class="p-6 transition-all duration-300 group/card bg-white relative border border-slate-200 shadow-sm rounded-2xl overflow-hidden cursor-grab active:cursor-grabbing hover:translate-y-[-4px] hover:shadow-2xl hover:shadow-indigo-100/50">
                                            <div class="mb-4">
                                                <div class="flex justify-between items-start mb-2">
                                                    <h4 class="font-black text-slate-900 text-lg group-hover/card:text-indigo-600 transition-colors truncate mb-1 pr-4">@app.CandidateName</h4>
                                                    <span class="text-[10px] font-black tabular-nums @(app.MatchScore > 85 ? "text-green-600" : "text-indigo-500")">@(app.MatchScore.ToString("0"))%</span>
                                                </div>
                                                <div class="flex items-center gap-2">
                                                    <div class="w-full h-1 bg-slate-100 rounded-full overflow-hidden">
                                                        <div class="h-full @(app.MatchScore > 85 ? "bg-green-500" : "bg-indigo-400")" style="width: @app.MatchScore%"></div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="flex gap-2 isolate pt-2 border-t border-slate-100">
                                                <a href="/CandidatePreview/@app.Id" class="flex-1">
                                                    <button type="button" class="text-[9px] font-black h-10 w-full rounded-xl bg-white border border-slate-200 text-slate-600 hover:border-indigo-500 hover:text-indigo-600 transition-all uppercase tracking-widest">
                                                        Preview
                                                    </button>
                                                </a>

                                                <form method="post" asp-page-handler="UpdateStatus" class="flex relative z-10 m-0">
                                                    <input type="hidden" name="Id" value="@Model.Job.Id" />
                                                    <input type="hidden" name="returnTab" value="PIPELINE" />
                                                    <input type="hidden" name="applicationId" value="@app.Id" />
                                                    @if (col.Status != ApplicationStatus.REJECTED)
                                                    {
                                                        <input type="hidden" name="status" value="@ApplicationStatus.REJECTED.ToString()" />
                                                        <button type="submit" class="h-10 w-11 p-0 rounded-xl flex-shrink-0 bg-red-50 text-red-600 border border-red-100 hover:bg-red-100 transition-colors flex items-center justify-center">
                                                            <i class="fas fa-times text-xs"></i>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <input type="hidden" name="status" value="@ApplicationStatus.REVIEWING.ToString()" />
                                                        <button type="submit" class="h-10 px-4 text-[9px] rounded-xl bg-green-600 text-white font-bold border-0 hover:bg-green-700 uppercase tracking-widest whitespace-nowrap">
                                                            Restore
                                                        </button>
                                                    }
                                                </form>

                                                @if (col.Status != ApplicationStatus.OFFERED && col.Status != ApplicationStatus.REJECTED)
                                                {
                                                    <form method="post" asp-page-handler="UpdateStatus" class="flex relative z-10 m-0">
                                                        <input type="hidden" name="Id" value="@Model.Job.Id" />
                                                        <input type="hidden" name="returnTab" value="PIPELINE" />
                                                        <input type="hidden" name="applicationId" value="@app.Id" />
                                                        @{
                                                            var possibleStatuses = new[] { ApplicationStatus.REVIEWING, ApplicationStatus.INTERVIEWING, ApplicationStatus.OFFERED };
                                                            var idx = System.Array.IndexOf(possibleStatuses, col.Status);
                                                            var nextStatus = possibleStatuses[idx + 1];
                                                        }
                                                        <input type="hidden" name="status" value="@nextStatus.ToString()" />
                                                        <button type="submit" class="h-10 w-11 p-0 rounded-xl bg-indigo-600 text-white border-0 shadow-lg shadow-indigo-100 hover:bg-indigo-700 flex items-center justify-center">
                                                            <i class="fas fa-arrow-right text-xs"></i>
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <script>
        function simulateMatch() {
            const btn = event.currentTarget;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Decrypting DNA...';
            btn.disabled = true;

            setTimeout(() => {
                document.getElementById('matchingSection').classList.add('hidden');
                document.getElementById('resultSection').classList.remove('hidden');
            }, 1500);
        }

        function toggleAllCheckboxes(source) {
            const checkboxes = document.querySelectorAll('.app-checkbox');
            checkboxes.forEach(cb => cb.checked = source.checked);
            updateBulkRejectBtn();
        }

        function updateBulkRejectBtn() {
            const checked = document.querySelectorAll('.app-checkbox:checked');
            const btn = document.getElementById('bulkRejectBtn');
            const countSpan = document.getElementById('selectedCount');
            const selectAllCheck = document.getElementById('selectAllApps');
            
            if (checked.length > 0) {
                btn.classList.remove('hidden');
                countSpan.innerText = checked.length;
            } else {
                btn.classList.add('hidden');
            }

            const totalCheckboxes = document.querySelectorAll('.app-checkbox').length;
            if (selectAllCheck) {
                selectAllCheck.checked = (totalCheckboxes > 0 && checked.length === totalCheckboxes);
            }
        }

        function submitBulkReject() {
            const checked = document.querySelectorAll('.app-checkbox:checked');
            const wrapper = document.getElementById('hiddenInputsWrapper');
            const form = document.getElementById('bulkRejectForm');
            
            wrapper.innerHTML = '';
            checked.forEach(cb => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'selectedApplications';
                input.value = cb.value;
                wrapper.appendChild(input);
            });
            
            if (checked.length > 0 && confirm(`Are you sure you want to reject ${checked.length} selected candidates?`)) {
                form.submit();
            }
        }
    </script>
}
