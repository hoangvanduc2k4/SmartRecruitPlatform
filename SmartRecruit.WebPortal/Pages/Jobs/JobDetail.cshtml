@page "/JobDetail"
@model WebPortal.Pages.JobDetailModel
@using WebPortal.Models
@{
    ViewData["Title"] = Model.Job?.Title ?? "Job Board";
}

@if (Model.Job == null)
{
    <div class="p-32 text-center font-black uppercase text-slate-300">Mission Target Not Found</div>
}
else
{
    <div class="space-y-6 animate-in fade-in duration-700 pb-32">
        @if (TempData["Message"] != null)
        {
            <div class="p-4 bg-green-50 border border-green-100 text-green-700 rounded-2xl text-xs font-bold uppercase tracking-tight flex items-center gap-3">
                <i class="fas fa-check-circle"></i>
                @TempData["Message"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="p-4 bg-red-50 border border-red-100 text-red-700 rounded-2xl text-xs font-bold uppercase tracking-tight flex items-center gap-3">
                <i class="fas fa-exclamation-circle text-base"></i>
                @TempData["Error"]
            </div>
        }

        @if (Model.IsOwner)
        {
            <div class="flex flex-col gap-4 mb-2">
                <a href="/RecruiterJobs" class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-slate-200 rounded-xl text-[11px] font-black uppercase tracking-widest text-slate-600 hover:text-indigo-600 hover:border-indigo-100 transition-all shadow-sm w-fit">
                    <i class="fas fa-arrow-left"></i> Quay lại danh sách
                </a>
                <div class="flex items-center gap-3">
                    <a asp-page="/Jobs/JobApplications" asp-route-Id="@Model.Job.Id" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white border border-indigo-100 rounded-2xl text-[11px] font-black uppercase tracking-widest text-indigo-600 hover:bg-indigo-50 shadow-sm transition-all">
                        <i class="fas fa-users"></i> Applications (@Model.TotalApplicationCount)
                    </a>
                    <a asp-page="/Recruiter/JobPipeline" asp-route-id="@Model.Job.Id" class="inline-flex items-center gap-2 px-5 py-2.5 bg-slate-900 border border-slate-900 rounded-2xl text-[11px] font-black uppercase tracking-widest text-white hover:bg-slate-800 shadow-sm transition-all">
                        <i class="fas fa-layer-group"></i> ATS Pipeline
                    </a>
                </div>

                @if (!string.IsNullOrEmpty(Model.Job.DraftChanges))
                {
                    <div class="mt-2 p-4 bg-amber-50 border border-amber-200 rounded-2xl flex items-center justify-between shadow-sm">
                        <div class="flex items-center gap-3 text-amber-700">
                            <i class="fas fa-exclamation-triangle"></i>
                            <span class="text-xs font-bold uppercase tracking-tight">Draft Changes Pending Review</span>
                        </div>
                        <p class="text-[10px] font-bold text-amber-600 uppercase">Visible Only To You</p>
                    </div>
                }
            </div>
        }
        
        <!-- HEADER -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 bg-white p-10 rounded-[2.5rem] border border-slate-200 shadow-xl shadow-slate-200/20 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-indigo-50 rounded-full -mr-16 -mt-16 blur-3xl opacity-50"></div>
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-indigo-50 border border-indigo-100 text-indigo-700 shadow-sm">Mission @Model.Job.Id</span>
                    @{
                        var statusClass = Model.Job.Status switch {
                            JobStatus.APPROVED => "bg-green-50 border-green-100 text-green-700",
                            JobStatus.BLOCKED => "bg-red-50 border-red-100 text-red-700",
                            JobStatus.DRAFT => "bg-slate-50 border-slate-100 text-slate-400",
                            JobStatus.CHECKING => "bg-amber-50 border-amber-100 text-amber-700",
                            _ => "bg-slate-50 border-slate-100 text-slate-400"
                        };
                    }
                    <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest border shadow-sm @statusClass">@Model.Job.Status</span>
                    @if (Model.Job.IsBoosted)
                    {
                        <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-yellow-100 border border-yellow-200 text-yellow-800 shadow-sm animate-pulse">BOOSTED ACTIVE</span>
                    }
                </div>
                <div class="flex items-center gap-6">
                    <h1 class="text-4xl font-black text-slate-900 tracking-tighter uppercase">@Model.Job.Title</h1>
                    @if (Model.IsAuthenticated)
                    {
                        <form method="post" asp-page-handler="ToggleSave" class="inline-flex m-0 items-center gap-2">
                            <input type="hidden" name="Id" value="@Model.Job.Id" />
                            <button type="submit"
                                    title="@(Model.IsSaved ? "Remove from Saved Jobs" : "Add to Saved Jobs")"
                                    class="h-12 px-4 rounded-2xl flex items-center justify-center gap-2 text-xs font-black uppercase tracking-widest transition-all
                                           @(Model.IsSaved
                                               ? "bg-red-50 text-red-500 border border-red-100 shadow-xl shadow-red-100/50 hover:bg-red-100"
                                               : "bg-slate-50 text-slate-400 border border-slate-100 hover:text-red-500 hover:bg-red-50")">
                                <i class="@(Model.IsSaved ? "fas" : "far") fa-heart text-base"></i>
                                <span>@(Model.IsSaved ? "Saved" : "Save")</span>
                            </button>
                        </form>
                    }
                </div>
                <p class="text-slate-400 font-bold uppercase tracking-widest text-[10px] mt-2 flex items-center gap-2">
                    <i class="fas fa-location-dot text-indigo-500"></i> @Model.Job.Location
                    <span class="text-slate-200">|</span>
                    <i class="fas fa-folder text-indigo-500"></i> @Model.Job.Category
                </p>
            </div>

            @if (Model.IsOwner)
            {
                <div class="flex gap-3 relative z-10">
                    <span class="px-5 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest bg-slate-50 text-slate-400 border border-slate-100">Recruiter Control</span>
                </div>
            }
        </div>

        <!-- CONTENT AREA -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
            <div class="lg:col-span-2 p-10 bg-white rounded-[2rem] border border-slate-200/60 shadow-lg space-y-8">
                        <div class="flex justify-between items-center pb-6 border-b border-slate-50">
                            <h4 class="text-[12px] font-black uppercase tracking-widest text-slate-900">Information Matrix</h4>
                            @if (Model.IsOwner) {
                                <span class="bg-yellow-100 text-yellow-800 text-[10px] font-black px-3 py-1 rounded-full">Edit Mode</span>
                            }
                        </div>

                        <form class="space-y-6" id="jobEditForm" method="post" asp-page-handler="Update">
                            <input type="hidden" name="Id" value="@Model.Job.Id" />
                            <input type="hidden" name="EditJob.Id" value="@Model.Job.Id" />
                            <input type="hidden" name="Tab" value="@Model.Tab" />

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Job Title</label>
                                    <input type="text" name="EditJob.Title" value="@Model.Job.Title" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsOwner ? "disabled" : "") />
                                </div>
                                <div>
                                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Company Name</label>
                                    <input type="text" name="EditJob.Company" value="@Model.Job.Company" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsOwner ? "disabled" : "") />
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Job Type</label>
                                    <select name="EditJob.JobType" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsOwner ? "disabled" : "")>
                                        <option value="0" selected="@(Model.Job.JobType == JobType.FULL_TIME)">Full Time</option>
                                        <option value="1" selected="@(Model.Job.JobType == JobType.PART_TIME)">Part Time</option>
                                        <option value="2" selected="@(Model.Job.JobType == JobType.REMOTE)">Remote</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Required Skills (comma separated)</label>
                                    <input type="text" name="EditJob.SkillsRequired" value="@Model.Job.SkillsRequired" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsOwner ? "disabled" : "") />
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Location</label>
                                    <input type="text" name="EditJob.Location" value="@Model.Job.Location" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsOwner ? "disabled" : "") />
                                </div>
                                <div>
                                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Category</label>
                                    <select name="EditJob.CategoryId" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsOwner ? "disabled" : "")>
                                        @foreach (var cat in Model.Categories)
                                        {
                                            <option value="@cat.Id" selected="@(Model.Job.CategoryId == cat.Id)">@cat.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="grid grid-cols-2 gap-4">
                                    <div>
                                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Salary Min</label>
                                        <input type="number" name="EditJob.SalaryMin" value="@Model.Job.SalaryMin" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsOwner ? "disabled" : "") />
                                    </div>
                                    <div>
                                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Salary Max</label>
                                        <input type="number" name="EditJob.SalaryMax" value="@Model.Job.SalaryMax" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" @(!Model.IsOwner ? "disabled" : "") />
                                    </div>
                                </div>
                            </div>

                            <div>
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Benefits</label>
                                <textarea name="EditJob.Benefits" class="w-full p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none min-h-[100px]" @(!Model.IsOwner ? "disabled" : "")>@Model.Job.Benefits</textarea>
                            </div>

                            <div>
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Core Requirements</label>
                                <textarea name="EditJob.Requirement" class="w-full p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none min-h-[100px]" @(!Model.IsOwner ? "disabled" : "")>@Model.Job.Requirement</textarea>
                            </div>
                            <div>
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Mission Description</label>
                                <textarea name="EditJob.Description" class="w-full p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none min-h-[250px]" @(!Model.IsOwner ? "disabled" : "")>@Model.Job.Description</textarea>
                            </div>
                        </form>

                        @if (Model.IsOwner)
                        {
                            <div class="pt-10 flex justify-between items-center border-t border-slate-50">
                                <form method="post" asp-page-handler="Boost">
                                    <input type="hidden" name="Id" value="@Model.Job.Id" />
                                    <button type="submit" class="h-14 px-10 gap-3 group bg-white border border-slate-200 text-slate-700 font-bold rounded-2xl flex items-center shadow-sm disabled:opacity-50" @(Model.Job.IsBoosted || Model.Job.Status != JobStatus.APPROVED ? "disabled" : "")>
                                        <i class="fas fa-fire-flame-curved @(Model.Job.IsBoosted ? "text-slate-300" : "text-amber-300 group-hover:scale-125 transition-transform")"></i>
                                        @(Model.Job.Status != JobStatus.APPROVED ? "Publish first to Boost" : (Model.Job.IsBoosted ? "Job is Already Boosted" : "Boost to Top (20k VND)"))
                                    </button>
                                </form>
                                <div class="flex flex-wrap items-center gap-3">
                                    <button type="submit" form="jobEditForm" class="h-14 px-10 bg-white border border-slate-200 text-slate-700 font-bold rounded-2xl flex items-center hover:bg-slate-50 transition-colors">
                                        <i class="fas fa-save mr-2"></i> Save Draft
                                    </button>

                                    <form method="post" asp-page-handler="Publish">
                                        <input type="hidden" name="Id" value="@Model.Job.Id" />
                                        <button type="submit" class="h-14 px-12 bg-indigo-600 text-white font-bold rounded-2xl shadow-lg shadow-indigo-100 hover:bg-indigo-700">
                                            <i class="fas fa-paper-plane mr-2"></i> Publish (@(Model.Job.Status == JobStatus.APPROVED ? "25k" : "50k") VNĐ)
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
            </div>

            <div class="space-y-8">
                <div class="p-8 bg-slate-900 text-white rounded-[2rem] border-0 shadow-2xl relative overflow-hidden group">
                    <div class="absolute top-0 right-0 p-8 opacity-10 text-7xl"><i class="fas fa-dna"></i></div>
                    <div class="relative z-10 space-y-6">
                        <p class="text-[10px] font-black uppercase tracking-[0.3em] text-indigo-400">Match Telemetry</p>
                        @if (!Model.IsOwner)
                        {
                            <div class="space-y-6">
                                @if (!Model.IsAuthenticated)
                                {
                                    <p class="text-xs text-slate-400 leading-relaxed font-medium">Please log in to initiate neural matching and mission application.</p>
                                    <a href="/Auth" class="w-full h-16 bg-white/10 border border-white/20 text-white font-bold rounded-2xl hover:bg-white hover:text-slate-900 transition-all flex items-center justify-center gap-2">
                                        <i class="fas fa-sign-in-alt"></i> Authentication Required
                                    </a>
                                }
                                else if (!Model.HasCV)
                                {
                                    <div class="p-5 bg-amber-500/10 border border-amber-500/20 rounded-2xl space-y-4">
                                        <p class="text-[10px] font-black uppercase text-amber-400 tracking-widest flex items-center gap-2">
                                            <i class="fas fa-exclamation-triangle"></i> CV Missing
                                        </p>
                                        <p class="text-xs text-slate-300 leading-relaxed">Your professional DNA profile is incomplete. please upload your CV text to proceed.</p>
                                        <a href="/Profile" class="w-full h-12 bg-amber-600 text-white text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-amber-700 transition flex items-center justify-center">
                                            Update Profile
                                        </a>
                                    </div>
                                }
                                else if (Model.MyApplication != null)
                                {
                                    <div class="space-y-6 animate-in zoom-in-95 duration-500">
                                        <div class="p-6 bg-indigo-500/10 border border-indigo-500/20 rounded-3xl text-center space-y-4">
                                            <div class="inline-flex items-center px-3 py-1 bg-indigo-500 text-white rounded-full text-[9px] font-black uppercase tracking-widest mb-2">
                                                Application Active
                                            </div>
                                            <div class="flex justify-center items-end gap-1">
                                                <span class="text-6xl font-black text-white tracking-tighter">@((int)(Model.MyApplication.MatchScore))</span>
                                                <span class="text-xl font-bold text-indigo-400 mb-2">%</span>
                                            </div>
                                            <p class="text-[9px] font-black uppercase tracking-widest text-slate-400">Neural DNA Match Result</p>
                                        </div>

                                        <div class="grid grid-cols-2 gap-4">
                                            <div class="p-4 bg-white/5 border border-white/10 rounded-2xl">
                                                <p class="text-[8px] font-black uppercase text-slate-500 mb-2 tracking-widest">Skill Sync</p>
                                                <p class="text-lg font-black text-white">@((int)(Model.MyApplication.SkillMatch))%</p>
                                            </div>
                                            <div class="p-4 bg-white/5 border border-white/10 rounded-2xl">
                                                <p class="text-[8px] font-black uppercase text-slate-500 mb-2 tracking-widest">Exp Index</p>
                                                <p class="text-lg font-black text-white">@((int)(Model.MyApplication.ExperienceMatch))%</p>
                                            </div>
                                        </div>

                                        @if (!string.IsNullOrEmpty(Model.MyApplication.AI_Summary))
                                        {
                                            <div class="p-5 bg-white/5 border border-white/10 rounded-2xl space-y-3">
                                                <p class="text-[9px] font-black uppercase text-indigo-400 tracking-widest flex items-center gap-2">
                                                    <i class="fas fa-robot"></i> Neural Synthesis
                                                </p>
                                                <p class="text-xs text-slate-300 leading-relaxed italic">"@Model.MyApplication.AI_Summary"</p>
                                            </div>
                                        }

                                        <div class="text-center pt-2">
                                            <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest flex items-center justify-center gap-2">
                                                <i class="fas fa-check-double text-emerald-500"></i> Identity Profile Locked
                                            </span>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="space-y-6" id="matchingSection">
                                        <p class="text-xs text-slate-400 leading-relaxed font-medium">Analyze your professional DNA against this mission's requirements using our neural matching protocol.</p>
                                        <button type="button" onclick="simulateMatch()" class="w-full h-16 bg-transparent border border-white/10 text-white font-bold rounded-2xl hover:border-indigo-500 transition-all flex items-center justify-center">
                                            <i class="fas fa-microchip mr-2"></i> Initiate AI Match
                                        </button>
                                    </div>
                                    <div class="space-y-6 hidden animate-in zoom-in-95 duration-500" id="resultSection">
                                        <div class="text-center py-6">
                                            <span class="text-6xl font-black text-indigo-400 tracking-tighter" id="scoreValue">--</span>
                                            <p class="text-[9px] font-black uppercase tracking-widest text-slate-400 mt-2">Neural Compatibility Score</p>
                                        </div>
                                        <div class="space-y-3">
                                            <div class="flex justify-between text-[9px] font-black uppercase text-slate-500"><span>Skills DNA</span><span id="skillMatchValue">--</span></div>
                                            <div class="w-full h-1.5 bg-white/5 rounded-full overflow-hidden"><div class="h-full bg-indigo-500 shadow-[0_0_10px_rgba(79,70,229,0.5)]" style="width: 0%" id="skillMatchBar"></div></div>
                                        </div>
                                        <form method="post" asp-page-handler="Apply">
                                            <input type="hidden" name="Id" value="@Model.Job.Id" />
                                            <button type="submit" class="w-full h-16 bg-indigo-600 border-0 text-white font-bold rounded-2xl shadow-2xl shadow-indigo-900/50 hover:bg-indigo-700">Submit Identity Profile</button>
                                        </form>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="space-y-4">
                                <div class="p-5 bg-white/5 rounded-2xl border border-white/5 flex justify-between items-center">
                                    <span class="text-[9px] font-black uppercase text-slate-400">Total Views</span>
                                    <span class="text-xl font-black text-white">@Model.Job.ViewCount.ToString("N0")</span>
                                </div>
                                <div class="p-5 bg-white/5 rounded-2xl border border-white/5 flex justify-between items-center">
                                    <span class="text-[9px] font-black uppercase text-slate-400">Total Applications</span>
                                    <span class="text-xl font-black text-indigo-400">@Model.TotalApplicationCount</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        function simulateMatch() {
            const btn = event.currentTarget;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Decrypting DNA...';
            btn.disabled = true;

            setTimeout(() => {
                document.getElementById('matchingSection').classList.add('hidden');
                document.getElementById('resultSection').classList.remove('hidden');
            }, 1500);
        }

        function toggleAllCheckboxes(source) {
            const checkboxes = document.querySelectorAll('.app-checkbox');
            checkboxes.forEach(cb => cb.checked = source.checked);
            updateBulkRejectBtn();
        }

        function updateBulkRejectBtn() {
            const checked = document.querySelectorAll('.app-checkbox:checked');
            const btn = document.getElementById('bulkRejectBtn');
            const countSpan = document.getElementById('selectedCount');
            const selectAllCheck = document.getElementById('selectAllApps');
            
            if (checked.length > 0) {
                btn.classList.remove('hidden');
                countSpan.innerText = checked.length;
            } else {
                btn.classList.add('hidden');
            }

            const totalCheckboxes = document.querySelectorAll('.app-checkbox').length;
            if (selectAllCheck) {
                selectAllCheck.checked = (totalCheckboxes > 0 && checked.length === totalCheckboxes);
            }
        }

        function submitBulkReject() {
            const checked = document.querySelectorAll('.app-checkbox:checked');
            const wrapper = document.getElementById('hiddenInputsWrapper');
            const form = document.getElementById('bulkRejectForm');
            
            wrapper.innerHTML = '';
            checked.forEach(cb => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'selectedApplications';
                input.value = cb.value;
                wrapper.appendChild(input);
            });
            
            if (checked.length > 0 && confirm(`Are you sure you want to reject ${checked.length} selected candidates?`)) {
                form.submit();
            }
        }
    </script>
}
