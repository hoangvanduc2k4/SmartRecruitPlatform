
@page "/Jobs"
@model WebPortal.Pages.JobsModel
@using WebPortal.Models
@using System.Globalization
@{
    ViewData["Title"] = "Tìm Việc Làm";
}

<div class="space-y-12 animate-in fade-in duration-700">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
        <div class="space-y-2">
            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-indigo-50 border border-indigo-100 text-indigo-700 shadow-sm">Khám Phá Cơ Hội</span>
            <h2 class="text-5xl font-black text-slate-900 tracking-tighter">Khám phá cơ hội</h2>
        </div>
        <div class="flex-1 max-w-5xl">
            <form method="get" class="flex flex-col sm:flex-row gap-3" id="searchForm">
                <!-- Keep other filters in state -->
                <input type="hidden" name="CategoryFilter" value="@Model.CategoryFilter" />
                <input type="hidden" name="TypeFilter" value="@Model.TypeFilter" />
                <input type="hidden" name="MinSalary" value="@Model.MinSalary" />
                <input type="hidden" name="MaxSalary" value="@Model.MaxSalary" />

                <div class="relative flex-1 group">
                    <i class="fas fa-search absolute left-5 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-indigo-600 transition-colors"></i>
                    <input type="text" name="SearchTerm" placeholder="Nhập tên công việc, kỹ năng, hoặc địa điểm..." class="h-14 pl-12 pr-6 bg-white border border-slate-200 rounded-2xl w-full focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 outline-none font-medium transition-all shadow-sm" value="@Model.SearchTerm" />
                </div>

                <div class="sm:w-48 relative">
                    <select name="LocationFilter" class="h-14 w-full bg-white border border-slate-200 rounded-2xl px-5 text-[10px] font-black uppercase tracking-widest text-slate-600 focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 outline-none transition-all shadow-sm appearance-none">
                        @foreach (var loc in Model.AvailableLocations)
                        {
                            <option value="@loc" selected="@(Model.LocationFilter == loc)">@(loc == "ALL" ? "Tất cả địa điểm" : loc.ToUpper())</option>
                        }
                    </select>
                    <i class="fas fa-chevron-down absolute right-5 top-1/2 -translate-y-1/2 text-slate-300 pointer-events-none text-[10px]"></i>
                </div>

                <div class="sm:w-48 relative">
                    <select name="sortBy" onchange="this.form.submit()" class="h-14 w-full bg-white border border-slate-200 rounded-2xl px-5 text-[10px] font-black uppercase tracking-widest text-slate-600 focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 outline-none transition-all shadow-sm appearance-none cursor-pointer">
                        <option value="" selected='@(string.IsNullOrEmpty(Model.SortBy))'>Mặc định</option>
                        <option value="date_desc" selected='@(Model.SortBy == "date" && Model.SortOrder == "desc")'>Mới nhất</option>
                        <option value="date_asc" selected='@(Model.SortBy == "date" && Model.SortOrder == "asc")'>Cũ nhất</option>
                        <option value="salary_desc" selected='@(Model.SortBy == "salary" && Model.SortOrder == "desc")'>Lương: Cao - Thấp</option>
                        <option value="salary_asc" selected='@(Model.SortBy == "salary" && Model.SortOrder == "asc")'>Lương: Thấp - Cao</option>
                    </select>
                    <i class="fas fa-sort absolute right-5 top-1/2 -translate-y-1/2 text-slate-300 pointer-events-none text-[10px]"></i>
                </div>

                <button type="submit" class="h-14 px-8 bg-slate-900 text-white rounded-2xl font-black uppercase tracking-widest text-[10px] hover:bg-indigo-600 transition-all shadow-lg active:scale-95">Tìm Kiếm</button>
            </form>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
        <!-- Sidebar Filters -->
        <aside class="lg:col-span-3 space-y-8">
            <form method="get" class="p-8 space-y-8 sticky top-28 bg-white rounded-[2rem] border border-slate-200/60 shadow-lg" id="filterForm">
                <input type="hidden" name="SearchTerm" value="@Model.SearchTerm" />
                <input type="hidden" name="LocationFilter" value="@Model.LocationFilter" />
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortOrder" value="@Model.SortOrder" />
                
                <div class="space-y-4">
                    <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-400">Lĩnh Vực Ngành Nghề</h4>
                    <select name="CategoryFilter" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-xs font-black uppercase tracking-widest text-slate-600 focus:ring-2 focus:ring-indigo-500 outline-none">
                        <option value="0" selected="@(Model.CategoryFilter == null || Model.CategoryFilter == 0)">TẤT CẢ LĨNH VỰC</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.Id" selected="@(Model.CategoryFilter == cat.Id)">@cat.Name.ToUpper()</option>
                        }
                    </select>
                </div>

                <div class="space-y-4">
                    <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-400">Hình Thức Làm Việc</h4>
                    <div class="space-y-2">
                        @{
                            var types = new List<string> { "ALL" };
                            types.AddRange(Enum.GetNames<JobType>());
                        }
                        @foreach (var t in types)
                        {
                            <label class="flex items-center gap-3 p-3 bg-slate-50/50 rounded-xl border border-slate-100 cursor-pointer hover:bg-white hover:border-indigo-400 transition-all group">
                                <input type="radio" name="TypeFilter" value="@t" class="w-4 h-4 text-indigo-600 border-slate-300 focus:ring-0" @(Model.TypeFilter == t ? "checked" : "") />
                                <span class="text-[10px] font-black uppercase tracking-widest text-slate-500 group-hover:text-slate-900">@(t == "ALL" ? "TẤT CẢ" : (t == "FULL_TIME" ? "TOÀN THỜI GIAN" : (t == "PART_TIME" ? "BÁN THỜI GIAN" : (t == "REMOTE" ? "LÀM VIỆC TỪ XA" : t))))</span>
                            </label>
                        }
                    </div>
                </div>

                <div class="space-y-4 pt-4 border-t border-slate-50">
                    <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-400">Mức Lương</h4>
                    <div class="space-y-4">
                        <div class="space-y-2">
                            <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Tối Thiểu (VNĐ)</label>
                             <input type="text" name="MinSalary" value="@Model.MinSalary" class="w-full h-11 bg-slate-50 border border-slate-100 rounded-xl px-4 text-xs font-black text-slate-600 focus:ring-2 focus:ring-indigo-500 outline-none currency-input" placeholder="0" />
                        </div>
                        <div class="space-y-2">
                            <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Tối Đa (VNĐ)</label>
                            <input type="text" name="MaxSalary" value="@Model.MaxSalary" class="w-full h-11 bg-slate-50 border border-slate-100 rounded-xl px-4 text-xs font-black text-slate-600 focus:ring-2 focus:ring-indigo-500 outline-none currency-input" placeholder="Không G.hạn" />
                        </div>
                    </div>
                </div>

                <div class="flex gap-3 pt-4">
                    <button type="submit" class="flex-1 h-12 bg-indigo-600 text-white rounded-xl font-black uppercase tracking-widest text-[10px] hover:bg-indigo-700 transition-all shadow-lg active:scale-95">Áp Dụng Lọc</button>
                    <button type="button" onclick="clearFilters()" class="h-12 px-4 text-[10px] font-black text-slate-400 uppercase tracking-widest hover:text-indigo-600 bg-transparent border border-slate-200 rounded-xl outline-none cursor-pointer hover:border-indigo-300 transition-all">Xóa</button>
                </div>
            </form>
        </aside>

        <!-- Job List -->
        <div class="lg:col-span-9 space-y-6">
            @if (Model.Jobs.Count > 0)
            {
                <div class="mb-2"></div>
            }
            @if (Model.Jobs.Count == 0)
            {
                <div class="py-32 text-center bg-white rounded-[3rem] border-2 border-dashed border-slate-200">
                    <i class="fas fa-dna text-4xl text-slate-100 mb-6"></i>
                    <p class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400 italic text-center">Không tìm thấy công việc nào phù hợp với yêu cầu của bạn.</p>
                </div>
            }
            else
            {
                <div class="space-y-6">
                    @foreach (var job in Model.Jobs)
                    {
                        <div class="block group relative">
                            <a href="/JobDetail?id=@job.Id.ToString(System.Globalization.CultureInfo.InvariantCulture)" class="block p-8 bg-white rounded-[2.5rem] border border-slate-200/60 transition-all duration-500 @(job.IsBoosted ? "bg-white shadow-[0_0_40px_rgba(99,102,241,0.15)] border-indigo-100 hover:shadow-[0_0_60px_rgba(99,102,241,0.25)] hover:border-indigo-300 transform hover:-translate-y-1" : "hover:translate-x-2 hover:shadow-2xl hover:shadow-indigo-100/50")">
                                @if (job.IsBoosted)
                                {
                                    <div class="absolute top-0 right-10">
                                        <div class="bg-yellow-400 text-slate-900 text-[9px] font-black uppercase tracking-widest px-4 py-1.5 rounded-b-xl shadow-lg flex items-center gap-2">
                                            <i class="fas fa-fire-flame-curved animate-bounce"></i> Tuyển Gấp
                                        </div>
                                    </div>
                                }

                                <div class="flex flex-col md:flex-row gap-8 items-start md:items-center">
                                    <div class="w-16 h-16 rounded-[1.5rem] flex items-center justify-center text-2xl transition-transform group-hover:scale-110 @(job.IsBoosted ? "bg-indigo-600 text-white shadow-xl shadow-indigo-200" : "bg-slate-900 text-white shadow-lg")">
                                        <i class="fas fa-briefcase"></i>
                                    </div>

                                    <div class="flex-1 space-y-2">
                                        <div class="flex flex-wrap items-center gap-3">
                                            <div class="flex flex-col">
                                                <h3 class="text-2xl font-black text-slate-900 tracking-tight group-hover:text-indigo-600 transition-colors">@job.Title</h3>
                                                <span 
                                                        onclick="event.preventDefault(); event.stopPropagation(); document.getElementsByName('SearchTerm')[0].value='@job.Company'; document.getElementById('searchForm').requestSubmit();"
                                                        class="text-[10px] font-black text-slate-400 hover:text-indigo-600 uppercase tracking-widest transition-colors flex items-center gap-1.5 w-fit mt-0.5 cursor-pointer">
                                                    <i class="fas fa-building text-[9px] text-slate-300"></i>
                                                    @job.Company
                                                </span>
                                            </div>
                                            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest @(job.JobType == JobType.REMOTE ? "bg-blue-50 border-blue-100 text-blue-700" : "bg-slate-50 border-slate-200 text-slate-700") border shadow-sm">
                                                @(job.JobType == JobType.FULL_TIME ? "TOÀN THỜI GIAN" : (job.JobType == JobType.PART_TIME ? "BÁN THỜI GIAN" : "LÀM VIỆC TỪ XA"))
                                            </span>
                                        </div>
                                        <div class="flex flex-wrap gap-x-6 gap-y-1">
                                            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2">
                                                <i class="fas fa-location-dot text-indigo-400"></i> @job.Location
                                            </span>
                                            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2">
                                                <i class="fas fa-microchip text-slate-300"></i> @job.Category
                                            </span>
                                            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2">
                                                <i class="fas fa-eye text-slate-300"></i> @job.ViewCount Lượt Xem
                                            </span>
                                            @if (job.ExpireDate.HasValue)
                                            {
                                                var daysLeft = (job.ExpireDate.Value.Date - DateTime.UtcNow.Date).Days;
                                                string expireText = daysLeft > 0 ? $"Còn {daysLeft} ngày" : (daysLeft == 0 ? "Hết hạn hôm nay" : "Đã hết hạn");
                                                string expireColor = daysLeft > 3 ? "text-emerald-500" : (daysLeft >= 0 ? "text-amber-500" : "text-red-500");
                                                <span class="text-[10px] font-black uppercase tracking-widest flex items-center gap-2 @expireColor">
                                                    <i class="fas fa-clock"></i> Hạn: @job.ExpireDate.Value.ToString("dd/MM/yyyy") (@expireText)
                                                </span>
                                            }
                                        </div>
                                    </div>

                                    <div class="text-right w-full md:w-auto pt-6 md:pt-0 border-t md:border-0 border-slate-50 flex flex-row md:flex-col justify-between items-center md:items-end gap-2 md:pr-14">
                                        @{
                                            string FormatSalary(decimal val) {
                                                if (val >= 1000000000) return (val / 1000000000m).ToString("0.#") + "tỷ";
                                                if (val >= 1000000) return (val / 1000000m).ToString("0.#") + "tr";
                                                if (val >= 1000) return (val / 1000m).ToString("0.#") + "k";
                                                return val.ToString("N0");
                                            }
                                        }
                                        <p class="text-2xl font-black text-indigo-600 tracking-tighter">@FormatSalary(job.SalaryMin) - @FormatSalary(job.SalaryMax) VNĐ</p>
                                    </div>
                                </div>

                                <div class="mt-8 pt-8 border-t border-slate-50 flex flex-wrap gap-2 items-center">
                                    <span class="text-[9px] font-black text-slate-300 uppercase tracking-widest mr-2">Kỹ Năng:</span>
                                    @foreach (var s in job.SkillsRequiredList)
                                    {
                                        <span class="px-3 py-1.5 bg-slate-50 text-slate-500 rounded-lg text-[9px] font-black uppercase tracking-wider border border-slate-100">@s</span>
                                    }
                                </div>
                            </a>

                            @if (Model.IsAuthenticated && Model.IsCandidate)
                            {
                                bool isSaved = Model.SavedJobIds.Contains(job.Id);
                                <div class="absolute top-6 right-6 z-20">
                                    <form method="post" asp-page-handler="ToggleSave" class="m-0">
                                        <input type="hidden" name="jobId" value="@job.Id" />
                                        <button type="submit" 
                                                class="w-10 h-10 rounded-xl flex items-center justify-center transition-all 
                                                       @(isSaved ? "bg-red-50 text-red-500 border border-red-100 shadow-sm" : "bg-slate-50 text-slate-400 border border-slate-100 hover:text-red-500 hover:bg-red-50")">
                                            <i class="@(isSaved ? "fas" : "far") fa-heart"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Pagination UI -->
                <partial name="_Pagination" model='(Model.CurrentPage, Model.TotalPages, $"?SearchTerm={Model.SearchTerm}&LocationFilter={Model.LocationFilter}&CategoryFilter={Model.CategoryFilter}&TypeFilter={Model.TypeFilter}&MinSalary={Model.MinSalary}&MaxSalary={Model.MaxSalary}&CurrentPage={{0}}")' />
            }
        </div>
    </div>

    <script>
        function clearFilters() {
            // Find both forms
            const filterForm = document.getElementById('filterForm');
            const searchForm = document.getElementById('searchForm');

            if (filterForm) {
                // Clear Category
                const categorySelect = filterForm.querySelector('select[name="CategoryFilter"]');
                if (categorySelect) categorySelect.value = "0";

                // Clear Type (Radio)
                const typeRadios = filterForm.querySelectorAll('input[name="TypeFilter"]');
                typeRadios.forEach(r => {
                    r.checked = (r.value === "ALL");
                });

                // Clear Salaries
                const minSal = filterForm.querySelector('input[name="MinSalary"]');
                if (minSal) minSal.value = "";
                
                const maxSal = filterForm.querySelector('input[name="MaxSalary"]');
                if (maxSal) maxSal.value = "";

                // Clear Sorting
                const sortBy = filterForm.querySelector('input[name="sortBy"]');
                if (sortBy) sortBy.value = "";
                const sortOrder = filterForm.querySelector('input[name="sortOrder"]');
                if (sortOrder) sortOrder.value = "";
            }

            if (searchForm) {
                // Clear Search Term
                const searchTerm = searchForm.querySelector('input[name="SearchTerm"]');
                if (searchTerm) searchTerm.value = "";

                // Clear Location
                const locationSelect = searchForm.querySelector('select[name="LocationFilter"]');
                if (locationSelect) locationSelect.value = "ALL";
            }
            
            // Note: We don't submit the form here as requested.
            // The user will enter/submit manually.
        }

        function applySort(val) {
            const parts = val.split('_');
            const sortBy = parts[0];
            const sortOrder = parts[1];
            
            const searchForm = document.getElementById('searchForm');
            if (searchForm) {
                const sortByInput = searchForm.querySelector('select[name="sortBy"]');
                if (sortByInput) {
                    sortByInput.value = val;
                }
                searchForm.submit();
            }
        }

        // Add Enter key support for filter form inputs
        document.addEventListener('DOMContentLoaded', function() {
            const filterForm = document.getElementById('filterForm');
            const searchForm = document.getElementById('searchForm');
            
            // Handle Enter key for filter form inputs
            if (filterForm) {
                const inputs = filterForm.querySelectorAll('input[type="text"], select');
                inputs.forEach(input => {
                    input.addEventListener('keypress', function(e) {
                        if (e.key === 'Enter') {
                            e.preventDefault();
                            filterForm.requestSubmit();
                        }
                    });
                });
            }
            
            // Handle Enter key for search form inputs
            if (searchForm) {
                const searchInput = searchForm.querySelector('input[name="SearchTerm"]');
                const locationSelect = searchForm.querySelector('select[name="LocationFilter"]');
                
                if (searchInput) {
                    searchInput.addEventListener('keypress', function(e) {
                        if (e.key === 'Enter') {
                            e.preventDefault();
                            searchForm.requestSubmit();
                        }
                    });
                }
                
                if (locationSelect) {
                    locationSelect.addEventListener('keypress', function(e) {
                        if (e.key === 'Enter') {
                            e.preventDefault();
                            searchForm.requestSubmit();
                        }
                    });
                }
            }
        });
    </script>
</div>
