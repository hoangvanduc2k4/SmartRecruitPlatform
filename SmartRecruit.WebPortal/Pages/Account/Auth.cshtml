@page "/Auth"
@model WebPortal.Pages.AuthModel
@{
    ViewData["Title"] = "Authenticate";
}

<div class="min-h-[85vh] flex items-center justify-center p-4">
    <div class="w-full max-w-lg p-10 md:p-12 bg-white rounded-[2rem] border border-slate-200/60 shadow-2xl relative overflow-hidden">
        <!-- Decorative Background Elements -->
        <div class="absolute top-0 right-0 w-48 h-48 bg-indigo-50 rounded-full -mr-24 -mt-24 blur-3xl opacity-50"></div>
        <div class="absolute bottom-0 left-0 w-32 h-32 bg-violet-100 rounded-full -ml-16 -mb-16 blur-3xl opacity-50"></div>

        <div class="text-center mb-8 relative z-10">
            <div class="w-16 h-16 bg-indigo-600 rounded-[1.25rem] flex items-center justify-center text-2xl font-black text-white mx-auto mb-6 shadow-xl shadow-indigo-100 transform hover:rotate-6 transition-transform">SR</div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tighter mb-1" id="auth-title">
                Welcome Back
            </h2>
            <p class="text-slate-400 font-bold uppercase tracking-widest text-[9px]" id="auth-subtitle">
                AI-Powered Recruitment Terminal
            </p>
        </div>

        @if (!ModelState.IsValid)
        {
            <div class="mb-4 p-4 text-sm text-red-800 rounded-lg bg-red-50 border border-red-200 relative z-10" role="alert">
                <div asp-validation-summary="All" class="text-sm"></div>
            </div>
        }
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-4 p-4 text-sm text-emerald-800 rounded-lg bg-emerald-50 border border-emerald-200 relative z-10" role="alert">
                @TempData["SuccessMessage"]
            </div>
        }



        <form method="post" class="space-y-6 relative z-10 animate-in fade-in slide-in-from-bottom-4 duration-500">
            <input type="hidden" asp-for="Input.Mode" id="authMode" />

            <!-- Register Only Fields -->
            <div id="registerFields" class="hidden">
                <div class="flex bg-slate-100 p-1.5 rounded-2xl mb-4 border border-slate-200/50">
                    <label class="flex-1 text-center cursor-pointer">
                        <input type="radio" asp-for="Input.Role" value="CANDIDATE" class="peer sr-only" checked />
                        <div class="py-3 text-[10px] font-black uppercase tracking-widest rounded-xl transition-all peer-checked:bg-white peer-checked:shadow-lg peer-checked:text-indigo-600 text-slate-400 hover:text-slate-600">Candidate</div>
                    </label>
                    <label class="flex-1 text-center cursor-pointer">
                        <input type="radio" asp-for="Input.Role" value="RECRUITER" class="peer sr-only" />
                        <div class="py-3 text-[10px] font-black uppercase tracking-widest rounded-xl transition-all peer-checked:bg-white peer-checked:shadow-lg peer-checked:text-indigo-600 text-slate-400 hover:text-slate-600">Recruiter</div>
                    </label>
                </div>
                
                <div class="mb-4">
                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Full Name</label>
                    <input type="text" asp-for="Input.FullName" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 placeholder:text-slate-300 focus:bg-white focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 transition-all outline-none" placeholder="John Doe" />
                </div>
            </div>

            <!-- Email (All Modes) -->
            <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Email Address</label>
                <input type="email" asp-for="Input.Email" required class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 placeholder:text-slate-300 focus:bg-white focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 transition-all outline-none" placeholder="name@company.xyz" />
            </div>

            <!-- OTP Field -->
            <div id="otpField" class="hidden relative">
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Security Code</label>
                <input type="text" asp-for="Input.OTPCode" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 placeholder:text-slate-300 focus:bg-white focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 transition-all outline-none text-center tracking-[0.5em] font-mono" placeholder="------" maxlength="6" />
                <button type="button" id="resendOtpBtn" onclick="resendOtp()" class="absolute right-1 top-0 text-[9px] font-black text-indigo-600 uppercase tracking-widest hover:underline">
                    Resend
                </button>
                <div id="resendMessage" class="absolute right-0 top-12 text-[10px] text-emerald-600 hidden mt-1"></div>
            </div>

            <!-- Password Fields -->
            <div class="relative" id="passwordFieldGroup">
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Password</label>
                <div class="relative">
                    <input type="password" asp-for="Input.Password" id="passwordInput" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 pr-12 text-sm font-medium text-slate-900 placeholder:text-slate-300 focus:bg-white focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 transition-all outline-none" placeholder="••••••••" />
                    <button type="button" onclick="togglePasswordVisibility('passwordInput')" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-colors">
                        <i class="fas fa-eye" id="passwordInput-icon"></i>
                    </button>
                </div>
                <button type="button" onclick="setMode('FORGOT_PASSWORD', true)" class="absolute right-1 top-0 text-[9px] font-black text-indigo-600 uppercase tracking-widest hover:underline" id="forgotPwdBtn">
                    Forgot?
                </button>
            </div>

            <div id="confirmPasswordField" class="hidden mb-4 relative mt-4">
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Confirm Password</label>
                <div class="relative">
                    <input type="password" id="confirmPasswordInput" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 pr-12 text-sm font-medium text-slate-900 placeholder:text-slate-300 focus:bg-white focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 transition-all outline-none" placeholder="••••••••" />
                    <button type="button" onclick="togglePasswordVisibility('confirmPasswordInput')" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-colors">
                        <i class="fas fa-eye" id="confirmPasswordInput-icon"></i>
                    </button>
                </div>
            </div>

            <button type="submit" class="w-full h-12 text-sm mt-4 bg-indigo-600 text-white font-bold rounded-full hover:bg-indigo-700 transition-colors shadow-lg shadow-indigo-100" id="submitBtn">
                Initiate Access
            </button>

            <div class="space-y-4 mt-6 relative z-10" id="google-login">
                <div class="flex items-center gap-4 text-slate-200 mb-4">
                    <div class="h-px bg-slate-100 flex-1"></div>
                    <span class="text-[9px] font-black uppercase tracking-widest text-slate-400">OR</span>
                    <div class="h-px bg-slate-100 flex-1"></div>
                </div>

                <!-- Custom Google Login using Official OAuth2 Flow -->
                <button type="button" id="login-width-google" onclick="handleGoogleLogin()" 
                   class="w-full h-12 bg-white border border-slate-200 text-slate-600 font-bold rounded-full hover:bg-slate-50 transition-colors shadow-sm flex items-center justify-center gap-3">
                    <svg class="w-5 h-5" viewBox="0 0 24 24">
                        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                    </svg>
                    <span>Continue with Google</span>
                </button>
            </div>

            <div class="text-center text-xs pt-6" id="toggleAuthMode">
                <span class="text-slate-400 font-medium" id="toggleText">New to the platform?</span>
                <button type="button" onclick="toggleMainMode()" class="text-indigo-600 font-black hover:underline uppercase tracking-wider ml-2" id="toggleBtn">
                    Register Hub
                </button>
            </div>
            
            <button type="button" onclick="setMode('LOGIN', true)" id="backToLoginBtn" class="hidden w-full text-[10px] font-black text-indigo-600 uppercase tracking-widest hover:underline mt-4">
                Back to Login
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <script>
        function handleGoogleLogin() {
            // Initialize the Google Identity Services client
            window.google.accounts.id.initialize({
                client_id: "382239454095-dm5214vllda451uo99lo90nvn82805cc.apps.googleusercontent.com",
                callback: handleCredentialResponse,
                context: "signin",
                ux_mode: "popup"
            });
            
            // Trigger the Google Sign-in popup manually
            window.google.accounts.id.prompt((notification) => {
                if (notification.isNotDisplayed() || notification.isSkippedMoment()) {
                    // Fallback to rendering a hidden button and clicking it if prompt is blocked
                    const googleLoginWrapper = document.createElement('div');
                    googleLoginWrapper.style.display = 'none';
                    document.body.appendChild(googleLoginWrapper);
                    
                    window.google.accounts.id.renderButton(googleLoginWrapper, {
                        type: 'standard',
                        theme: 'outline',
                        size: 'large'
                    });
                    
                    const button = googleLoginWrapper.querySelector('div[role=button]');
                    if(button) button.click();
                }
            });
        }

        async function handleCredentialResponse(response) {
            try {
                // Prepare form data exactly as traditional form POST
                const formData = new FormData();
                formData.append('id_token', response.credential);

                // Add CSRF token for security (ASP.NET Core AntiForgery)
                const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                
                const fetchOptions = {
                    method: 'POST',
                    body: formData
                };

                if (csrfToken) {
                    fetchOptions.headers = {
                        'RequestVerificationToken': csrfToken
                    };
                }

                // Send the ID token to our backend via AJAX (Fetch API)
                const serverResponse = await fetch('/Auth?handler=GoogleCallback', fetchOptions);

                if (serverResponse.ok) {
                    // If login successful, redirect to Index
                    window.location.href = '/Index';
                } else {
                    // Handle failure (e.g. reload or show error)
                    window.location.reload();
                }
            } catch (error) {
                console.error("Google Login Error:", error);
                window.location.reload();
            }
        }

        function setMode(mode, clearErrors = false) {
            if (clearErrors) {
                const alerts = document.querySelectorAll('[role="alert"]');
                alerts.forEach(a => a.style.display = 'none');
            }

            const authMode = document.getElementById('authMode');
            const title = document.getElementById('auth-title');
            const subtitle = document.getElementById('auth-subtitle');
            const googleLogin = document.getElementById('google-login');
            const registerFields = document.getElementById('registerFields');
            const passwordFieldGroup = document.getElementById('passwordFieldGroup');
            const confirmPasswordField = document.getElementById('confirmPasswordField');
            const otpField = document.getElementById('otpField');
            const forgotPwdBtn = document.getElementById('forgotPwdBtn');
            const submitBtn = document.getElementById('submitBtn');
            const toggleAuthMode = document.getElementById('toggleAuthMode');
            const backToLoginBtn = document.getElementById('backToLoginBtn');

            authMode.value = mode;

            if (mode === 'LOGIN') {
                title.innerText = 'Welcome Back';
                subtitle.innerText = 'AI-POWERED RECRUITMENT TERMINAL';
                googleLogin.classList.remove('hidden');
                registerFields.classList.add('hidden');
                passwordFieldGroup.classList.remove('hidden');
                confirmPasswordField.classList.add('hidden');
                otpField.classList.add('hidden');
                forgotPwdBtn.classList.remove('hidden');
                submitBtn.innerText = 'Initiate Access';
                toggleAuthMode.classList.remove('hidden');
                backToLoginBtn.classList.add('hidden');
                document.getElementById('toggleText').innerText = "New to the platform?";
                document.getElementById('toggleBtn').innerText = "Register Hub";
            } else if (mode === 'REGISTER') {
                title.innerText = 'Create Account';
                subtitle.innerText = 'AI-POWERED RECRUITMENT TERMINAL';
                googleLogin.classList.remove('hidden');
                registerFields.classList.remove('hidden');
                passwordFieldGroup.classList.remove('hidden');
                confirmPasswordField.classList.remove('hidden');
                otpField.classList.add('hidden');
                forgotPwdBtn.classList.add('hidden');
                submitBtn.innerText = 'Create DNA Profile';
                toggleAuthMode.classList.remove('hidden');
                backToLoginBtn.classList.add('hidden');
                document.getElementById('toggleText').innerText = "Already verified?";
                document.getElementById('toggleBtn').innerText = "Login Terminal";
            } else if (mode === 'VERIFY_OTP') {
                title.innerText = 'Security Check';
                subtitle.innerText = 'ENTER THE 6-DIGIT CODE SENT TO YOUR EMAIL';
                googleLogin.classList.add('hidden');
                registerFields.classList.add('hidden');
                passwordFieldGroup.classList.add('hidden');
                confirmPasswordField.classList.add('hidden');
                otpField.classList.remove('hidden');
                forgotPwdBtn.classList.add('hidden');
                submitBtn.innerText = 'Verify Device';
                toggleAuthMode.classList.add('hidden');
                backToLoginBtn.classList.remove('hidden');
            } else if (mode === 'FORGOT_PASSWORD') {
                title.innerText = 'Recover Key';
                subtitle.innerText = 'ENTER YOUR EMAIL TO RESET SECURITY ACCESS';
                googleLogin.classList.add('hidden');
                registerFields.classList.add('hidden');
                passwordFieldGroup.classList.add('hidden');
                confirmPasswordField.classList.add('hidden');
                otpField.classList.add('hidden');
                submitBtn.innerText = 'Send Reset Link';
                toggleAuthMode.classList.add('hidden');
                backToLoginBtn.classList.remove('hidden');
            } else if (mode === 'RESET_PASSWORD') {
                title.innerText = 'Set New Key';
                subtitle.innerText = 'ENTER THE 6-DIGIT CODE AND YOUR NEW PASSWORD';
                googleLogin.classList.add('hidden');
                registerFields.classList.add('hidden');
                otpField.classList.remove('hidden');
                passwordFieldGroup.classList.remove('hidden');
                confirmPasswordField.classList.remove('hidden');
                forgotPwdBtn.classList.add('hidden');
                submitBtn.innerText = 'Reset Password';
                toggleAuthMode.classList.add('hidden');
                backToLoginBtn.classList.remove('hidden');
            }
        }

        function toggleMainMode() {
            const currentMode = document.getElementById('authMode').value;
            setMode(currentMode === 'LOGIN' ? 'REGISTER' : 'LOGIN', true);
        }

        function togglePasswordVisibility(inputId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(inputId + '-icon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }

        async function resendOtp() {
            const emailInput = document.getElementById('Input_Email');
            if(!emailInput || !emailInput.value) {
                alert("Please enter your email address first.");
                return;
            }
            const resendBtn = document.getElementById('resendOtpBtn');
            const resendMsg = document.getElementById('resendMessage');
            
            resendBtn.innerText = 'Sending...';
            resendBtn.disabled = true;

            try {
                const formData = new FormData();
                formData.append('email', emailInput.value);
                const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                if(csrfToken) formData.append('__RequestVerificationToken', csrfToken);

                const response = await fetch('/Auth?handler=ResendOtp', { method: 'POST', body: formData });
                const result = await response.json();
                
                resendMsg.innerText = result.message;
                resendMsg.className = result.success ? "absolute right-0 top-12 text-[10px] text-emerald-600 mt-1" : "absolute right-0 top-12 text-[10px] text-red-600 mt-1";
                resendMsg.classList.remove('hidden');

                if (result.success) {
                    let countdown = 60;
                    const timer = setInterval(() => {
                        countdown--;
                        resendBtn.innerText = `WAIT (${countdown}S)`;
                        if (countdown <= 0) {
                            clearInterval(timer);
                            resendBtn.innerText = 'RESEND';
                            resendBtn.disabled = false;
                        }
                    }, 1000);
                } else {
                    resendBtn.innerText = 'RESEND';
                    resendBtn.disabled = false;
                }
            } catch (err) {
                 resendBtn.innerText = 'RESEND';
                 resendBtn.disabled = false;
            }
        }

        // Restore visual state if returned from server with errors
        document.addEventListener('DOMContentLoaded', () => {
            const serverMode = '@Model.Input.Mode';
            const inputMode = document.getElementById('authMode').value;
            const currentMode = serverMode || inputMode || 'LOGIN';
            
            // Force the DOM element to match the server
            document.getElementById('authMode').value = currentMode;
            setMode(currentMode);
        });
    </script>
}
