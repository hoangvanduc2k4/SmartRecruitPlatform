<script>
    function submitAvatarForm() {
        const input = document.getElementById('avatarInput');
        if (input.files && input.files[0]) {
            // Show loading overlay
            const overlay = document.getElementById('avatarLoading');
            if (overlay) {
                overlay.classList.remove('opacity-0', 'pointer-events-none');
            }
            
            // Disable all buttons to prevent double clicks
            const buttons = document.querySelectorAll('button');
            buttons.forEach(btn => {
                btn.disabled = true;
                btn.style.opacity = '0.7';
                btn.style.cursor = 'not-allowed';
            });
            
            // Submit form
            document.getElementById('avatarForm').submit();
        }
    }

    // CV Preview Reliability Logic
    let cvLoadTimer;
    let cvRetryCount = 0;
    const MAX_CV_RETRIES = 1;

    function handleCVLoad(iframe) {
        clearTimeout(cvLoadTimer);
        const loadingState = document.getElementById('cvLoadingState');
        if (loadingState) {
            loadingState.classList.add('opacity-0');
            setTimeout(() => loadingState.style.display = 'none', 300);
        }
        iframe.classList.remove('opacity-0');
        console.log("CV Preview loaded successfully.");
    }

    function reloadCVPreview() {
        const iframe = document.getElementById('cvIframe');
        if (!iframe) return;

        const loadingState = document.getElementById('cvLoadingState');
        if (loadingState) {
            loadingState.style.display = 'flex';
            loadingState.classList.remove('opacity-0');
        }
        iframe.classList.add('opacity-0');

        // Add a cache-buster timestamp
        const currentSrc = new URL(iframe.src);
        currentSrc.searchParams.set('v', new Date().getTime());
        iframe.src = currentSrc.toString();

        startCVWatchdog();
    }

    function startCVWatchdog() {
        clearTimeout(cvLoadTimer);
        cvLoadTimer = setTimeout(() => {
            const iframe = document.getElementById('cvIframe');
            if (iframe && iframe.classList.contains('opacity-0')) {
                console.warn("CV Preview timeout detected - attempting reload.");
                if (cvRetryCount < MAX_CV_RETRIES) {
                    cvRetryCount++;
                    reloadCVPreview();
                }
            }
        }, 7000); // 7 second timeout
    }

    // Initialize watchdog on page load if iframe exists
    document.addEventListener('DOMContentLoaded', function() {
        if (document.getElementById('cvIframe')) {
            startCVWatchdog();
        }
    });
</script>



