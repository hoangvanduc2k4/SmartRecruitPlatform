@page "/Profile"
@model SmartRecruitWeb.Pages.ProfileModel
@{
    ViewData["Title"] = "Profile Nexus";
}

<div class="space-y-10 animate-in fade-in duration-700 pb-32">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
        <div class="space-y-2">
            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-indigo-50 border border-indigo-100 text-indigo-700 shadow-sm">Identity Terminal</span>
            <h2 class="text-5xl font-black text-slate-900 tracking-tighter uppercase">Profile Nexus</h2>
            <p class="text-slate-500 font-medium">Synchronizing your professional DNA and security protocols.</p>
        </div>

        <div class="flex bg-slate-100 p-1.5 rounded-2xl border border-slate-200 shadow-sm">
            <a href="?Tab=IDENTITY" class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(Model.Tab == "IDENTITY" ? "bg-white text-indigo-600 shadow-lg" : "text-slate-500 hover:text-slate-800")">IDENTITY</a>
            <a href="?Tab=SKILLS" class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(Model.Tab == "SKILLS" ? "bg-white text-indigo-600 shadow-lg" : "text-slate-500 hover:text-slate-800")">SKILLS</a>
            <a href="?Tab=SECURITY" class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(Model.Tab == "SECURITY" ? "bg-white text-indigo-600 shadow-lg" : "text-slate-500 hover:text-slate-800")">SECURITY</a>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
        <!-- Left Column: Fixed Bio -->
        <div class="lg:col-span-4 space-y-8">
            <div class="p-10 text-center bg-white border border-slate-200/60 shadow-xl shadow-slate-200/10 rounded-[2rem]">
                <div class="relative inline-block mb-8">
                    <div class="absolute inset-0 bg-indigo-600 rounded-[3rem] blur-2xl opacity-10"></div>
                    <img src="@Model.CurrentUser.AvatarUrl" class="w-40 h-40 rounded-[2.5rem] border-8 border-slate-50 shadow-2xl mx-auto object-cover relative z-10" alt="" />
                    <button class="absolute -bottom-2 -right-2 w-10 h-10 bg-indigo-600 text-white rounded-xl flex items-center justify-center border-4 border-white shadow-xl hover:scale-110 transition-transform z-20">
                        <i class="fas fa-camera text-xs"></i>
                    </button>
                </div>
                <h3 class="text-2xl font-black text-slate-900 tracking-tight mb-1">@Model.CurrentUser.FullName</h3>
                <p class="text-indigo-600 font-black uppercase tracking-[0.3em] text-[9px]">@Model.CurrentUser.Role</p>

                <div class="mt-10 space-y-3">
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100 flex justify-between items-center">
                        <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Trust Rating</span>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800">9.8/10</span>
                    </div>
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100 flex justify-between items-center">
                        <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Security Level</span>
                        <span class="text-[10px] font-black text-slate-900">Tier 1 Alpha</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Tab Content -->
        <div class="lg:col-span-8">
            @if (Model.Tab == "IDENTITY")
            {
                <div class="p-12 space-y-8 bg-white rounded-[2rem] border border-slate-200 animate-in fade-in slide-in-from-right-4 duration-500 shadow-sm">
                    <div class="flex justify-between items-center pb-6 border-b border-slate-50">
                        <h4 class="text-[12px] font-black uppercase tracking-widest text-slate-900">Personal Metadata</h4>
                        <span class="bg-slate-100 text-slate-600 text-[10px] font-black tracking-widest uppercase px-3 py-1 rounded-full">Read Only</span>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Full Name</label>
                            <input type="text" value="@Model.CurrentUser.FullName" disabled class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-500 outline-none" />
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Email Hub</label>
                            <input type="text" value="@Model.CurrentUser.Email" disabled class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-500 outline-none" />
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Identity Role</label>
                            <input type="text" value="@Model.CurrentUser.Role" disabled class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-500 outline-none" />
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Created At</label>
                            <input type="text" value="@System.DateTime.Now.ToString("MMM dd, yyyy")" disabled class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-500 outline-none" />
                        </div>
                    </div>
                    <div class="pt-8 flex justify-end">
                        <button class="h-12 px-8 bg-white border border-slate-200 text-slate-700 font-bold rounded-2xl hover:bg-slate-50 transition-colors shadow-sm text-[10px] uppercase tracking-widest">Request Identity Change</button>
                    </div>
                </div>
            }

            @if (Model.Tab == "SKILLS")
            {
                <div class="p-12 space-y-10 bg-white rounded-[2rem] border border-slate-200 animate-in fade-in slide-in-from-right-4 duration-500 shadow-sm">
                    <form method="post" asp-page-handler="UploadSim" id="uploadForm">
                        <button type="submit" class="w-full text-left" onclick="showParsing()">
                            <div class="border-4 border-dashed border-slate-200 rounded-[2.5rem] p-12 text-center transition-all cursor-pointer group bg-slate-50 hover:bg-white hover:border-indigo-400 hover:shadow-xl hover:shadow-indigo-50" id="uploadBox">
                                <div class="space-y-4" id="uploadIdle">
                                    <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center text-indigo-600 mx-auto shadow-md group-hover:scale-110 transition-transform">
                                        <i class="fas fa-microchip text-2xl"></i>
                                    </div>
                                    <h5 class="text-xl font-black text-slate-800">Upload New Resume</h5>
                                    <p class="text-[10px] text-slate-400 font-medium max-w-xs mx-auto">Update your competency matrix automatically with AI parsing.</p>
                                </div>
                                <div class="hidden flex-col items-center gap-4 py-4" id="uploadSpin">
                                    <div class="w-12 h-12 border-4 border-indigo-600 border-t-transparent rounded-full animate-spin"></div>
                                    <p class="text-[10px] font-black uppercase tracking-widest text-indigo-600">Syncing Technical DNA...</p>
                                </div>
                            </div>
                        </button>
                    </form>

                    <div class="space-y-6">
                        <h4 class="text-[12px] font-black uppercase tracking-widest text-slate-900">Mapped Competencies</h4>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var s in Model.Skills)
                            {
                                <div class="px-5 py-3 bg-slate-50 border border-slate-100 rounded-xl text-[10px] font-black uppercase tracking-widest text-slate-600 flex items-center gap-3">
                                    @s <i class="fas fa-times opacity-30 cursor-pointer hover:text-red-500 transition-colors"></i>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            @if (Model.Tab == "SECURITY")
            {
                <div class="p-12 space-y-10 bg-white rounded-[2rem] border border-slate-200 animate-in fade-in slide-in-from-right-4 duration-500 shadow-sm">
                    <div class="space-y-2">
                        <h4 class="text-[12px] font-black uppercase tracking-widest text-slate-900">Access Key Management</h4>
                        <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">Last updated: 3 months ago</p>
                    </div>

                    <form method="post" asp-page-handler="UpdatePassword" class="space-y-6" onsubmit="return validatePassword()">
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Current Terminal Key</label>
                            <input type="password" name="currentPassword" required placeholder="••••••••" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" />
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div>
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">New Security Key</label>
                                <input type="password" name="newPassword" id="newPwd" required placeholder="••••••••" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" />
                            </div>
                            <div>
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Confirm New Key</label>
                                <input type="password" name="confirmPassword" id="confPwd" required placeholder="••••••••" class="w-full h-12 bg-slate-50 border border-slate-100 rounded-xl px-4 text-sm font-medium text-slate-900 focus:bg-white focus:border-indigo-400 transition-all outline-none" />
                            </div>
                        </div>

                        <div class="bg-amber-50 p-6 rounded-2xl border border-amber-100 flex gap-4">
                            <i class="fas fa-triangle-exclamation text-amber-500 mt-1"></i>
                            <div>
                                <p class="text-[10px] font-black text-amber-800 uppercase tracking-widest mb-1">Security Warning</p>
                                <p class="text-[10px] text-amber-600 leading-relaxed font-medium">Changing your password will terminate all other active sessions across your authenticated devices.</p>
                            </div>
                        </div>

                        <div class="pt-6 border-t border-slate-50 flex justify-end">
                            <button type="submit" class="px-10 h-14 bg-indigo-600 text-white font-bold rounded-2xl shadow-xl shadow-indigo-100 hover:bg-indigo-700 transition" id="savePwdBtn">
                                Commit Key Update
                            </button>
                        </div>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showParsing() {
            document.getElementById('uploadIdle').classList.add('hidden');
            document.getElementById('uploadSpin').classList.remove('hidden');
            document.getElementById('uploadSpin').classList.add('flex');
            const box = document.getElementById('uploadBox');
            box.classList.remove('bg-slate-50', 'border-slate-200');
            box.classList.add('bg-indigo-50', 'border-indigo-200');
        }

        function validatePassword() {
            var newP = document.getElementById('newPwd').value;
            var confP = document.getElementById('confPwd').value;
            if (newP !== confP) {
                alert("New passwords do not match.");
                return false;
            }
            var btn = document.getElementById('savePwdBtn');
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Committing...';
            btn.classList.add('opacity-75', 'cursor-not-allowed');
            return true;
        }
    </script>
}
