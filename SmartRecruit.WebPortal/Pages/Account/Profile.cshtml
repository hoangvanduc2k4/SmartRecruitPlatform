                            </div>
                        </div>
                        <div class="flex justify-end">
                            <button type="submit" formaction="?handler=UploadCv" class="h-14 px-10 bg-slate-900 text-white font-black rounded-2xl text-[10px] uppercase tracking-[0.2em] shadow-2xl shadow-slate-200 hover:bg-black hover:-translate-y-1 transition-all flex items-center gap-3">
                                <i class="fas fa-upload text-xs"></i> Tải Lên CV
                            </button>
                        </div>
                    </div>
                </div>
            }
            
        </div>
    </div>
}

