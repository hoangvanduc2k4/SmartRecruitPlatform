@page "/Profile"
@model WebPortal.Pages.ProfileModel
@{
    ViewData["Title"] = "Hồ Sơ";
    var isCandidate = Model.CurrentUser?.Role?.ToUpper() == "CANDIDATE";
    var isRecruiter = Model.CurrentUser?.Role?.ToUpper() == "RECRUITER";
}

<div class="space-y-10 animate-in fade-in duration-700 pb-32">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
        <div class="space-y-2">
            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-indigo-50 border border-indigo-100 text-indigo-700 shadow-sm">Hồ Sơ Cá Nhân</span>
            <h2 class="text-5xl font-black text-slate-900 tracking-tighter uppercase">Trung Tâm Cập Nhật</h2>
            <p class="text-slate-500 font-medium">Cập nhật và đồng bộ thông tin của bạn trên hệ thống.</p>
        </div>

        <div class="flex bg-slate-100 p-1.5 rounded-2xl border border-slate-200 shadow-sm flex-wrap gap-1">
            <a href="?Tab=IDENTITY@(Request.Query.ContainsKey("userId") ? $"&userId={Request.Query["userId"]}" : "")" class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(Model.Tab == "IDENTITY" ? "bg-white text-indigo-600 shadow-lg" : "text-slate-500 hover:text-slate-800")">Thông Tin</a>
            @if (isCandidate)
            {
                <a href="?Tab=SKILLS@(Request.Query.ContainsKey("userId") ? $"&userId={Request.Query["userId"]}" : "")" class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(Model.Tab == "SKILLS" ? "bg-white text-indigo-600 shadow-lg" : "text-slate-500 hover:text-slate-800")">Kỹ Năng</a>
                <a href="?Tab=CVS@(Request.Query.ContainsKey("userId") ? $"&userId={Request.Query["userId"]}" : "")" class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(Model.Tab == "CVS" ? "bg-white text-emerald-600 shadow-lg" : "text-slate-500 hover:text-slate-800")">CV</a>
            }
            @if (isRecruiter)
            {
                <a href="?Tab=COMPANY@(Request.Query.ContainsKey("userId") ? $"&userId={Request.Query["userId"]}" : "")" class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(Model.Tab == "COMPANY" ? "bg-white text-indigo-600 shadow-lg" : "text-slate-500 hover:text-slate-800")">Công Ty</a>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="p-4 bg-emerald-50 border border-emerald-100 rounded-2xl text-sm text-emerald-700 flex items-center gap-3">
            <i class="fas fa-check-circle text-emerald-400"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null || !string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="p-4 bg-red-50 border border-red-100 rounded-2xl text-sm text-red-700 flex items-center gap-3">
            <i class="fas fa-exclamation-triangle text-red-400"></i> @(TempData["ErrorMessage"] ?? Model.ErrorMessage)
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
        <!-- Left Column: Fixed Bio Card -->
        <div class="lg:col-span-4 space-y-8">
            <div class="p-10 text-center bg-white border border-slate-200/60 shadow-xl shadow-slate-200/10 rounded-[2rem]">
                <div class="relative inline-block mb-8">
                    <div class="relative w-40 h-40 mx-auto">
                        <div class="absolute inset-0 bg-indigo-600 rounded-[2.5rem] blur-2xl opacity-10"></div>
                        
                        @if (!string.IsNullOrEmpty(Model.CurrentUser?.AvatarUrl))
                        {
                            <img src="@Model.CurrentUser.AvatarUrl" class="w-40 h-40 rounded-[2.5rem] border-8 border-white shadow-2xl object-cover relative z-10" alt="Avatar" />
                        }
                        else
                        {
                            <div class="w-40 h-40 rounded-[2.5rem] border-8 border-white shadow-2xl relative z-10 bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center">
                                <span class="text-5xl font-black text-white">@(Model.CurrentUser?.FullName?.Substring(0, 1).ToUpper() ?? "?")</span>
                            </div>
                        }

                        <!-- Loading Overlay -->
                        <div id="avatarLoading" class="absolute inset-0 z-30 rounded-[2.5rem] bg-white/80 backdrop-blur-[2px] flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300">
                            <div class="flex flex-col items-center gap-2">
                                <div class="w-8 h-8 border-4 border-indigo-600 border-t-transparent rounded-full animate-spin"></div>
                                <span class="text-[8px] font-black uppercase tracking-widest text-indigo-600">Đang tải lên</span>
                            </div>
                        </div>

                        @if (Model.IsOwnProfile)
                        {
                            <!-- Corner Upload Button -->
                            <button type="button" onclick="document.getElementById('avatarInput').click()" 
                                    class="absolute -bottom-2 -right-2 z-40 w-12 h-12 bg-emerald-500 hover:bg-emerald-600 text-white rounded-full border-4 border-white shadow-xl flex items-center justify-center transition-all hover:scale-110 active:scale-90 group">
                                <i class="fas fa-camera text-sm transition-transform group-hover:rotate-12"></i>
                            </button>
                        }
                    </div>
                </div>
                <h3 class="text-2xl font-black text-slate-900 tracking-tight mb-1">@(Model.CurrentUser?.FullName ?? "-")</h3>
                <p class="text-indigo-600 font-black uppercase tracking-[0.3em] text-[9px]">@(Model.CurrentUser?.Role == "CANDIDATE" ? "ỨNG VIÊN" : Model.CurrentUser?.Role == "RECRUITER" ? "NHÀ TUYỂN DỤNG" : Model.CurrentUser?.Role == "ADMIN" ? "QUẢN TRỊ VIÊN" : Model.CurrentUser?.Role)</p>
                <p class="text-slate-400 text-xs mt-1 font-medium">@(Model.CurrentUser?.Email ?? "")</p>

                <div class="mt-8 space-y-4 text-left">
                    <div class="p-4 bg-slate-50/50 rounded-2xl border border-slate-100 flex justify-between items-center group hover:bg-white hover:border-indigo-100 transition-all">
                        <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Thành Viên Từ</span>
                        <span class="text-[10px] font-black text-slate-900">@(Model.CurrentUser?.CreatedAt.ToString("MM/yyyy") ?? "-")</span>
                    </div>

                    @if (isCandidate && Model.CurrentUser?.CandidateProfile != null)
                    {
                        <div class="p-4 bg-slate-50/50 rounded-2xl border border-slate-100 flex justify-between items-center group hover:bg-white hover:border-violet-100 transition-all">
                            <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Kinh Nghiệm</span>
                            <span class="text-[10px] font-black text-slate-900">@Model.CurrentUser.CandidateProfile.ExperienceYears năm</span>
                        </div>
                        @if (Model.CurrentUser.CandidateProfile.ExpectedSalary.HasValue)
                        {
                            <div class="p-4 bg-emerald-50/30 rounded-2xl border border-emerald-100/50 flex justify-between items-center group hover:bg-white hover:border-emerald-100 transition-all">
                                <span class="text-[9px] font-black text-emerald-600/50 uppercase tracking-widest">Kỳ Vọng</span>
                                <span class="text-[10px] font-black text-emerald-600">@Model.CurrentUser.CandidateProfile.ExpectedSalary?.ToString("N0") đ</span>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.CurrentUser.CandidateProfile.Skills))
                        {
                            <div class="pt-4 space-y-3">
                                <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest px-1">Kỹ Năng</span>
                                <div class="flex flex-wrap gap-2">
                                    @foreach (var skill in Model.CurrentUser.CandidateProfile.Skills.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <span class="px-3 py-1 bg-indigo-50 text-indigo-600 text-[9px] font-black uppercase tracking-tighter rounded-lg border border-indigo-100/50">@skill.Trim()</span>
                                    }
                                </div>
                            </div>
                        }
                    }

                    @if (isRecruiter && Model.CurrentUser?.CompanyProfile != null)
                    {
                        <div class="p-4 bg-slate-50/50 rounded-2xl border border-slate-100 flex justify-between items-center group hover:bg-white hover:border-indigo-100 transition-all">
                            <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Công Ty</span>
                            <span class="text-[10px] font-black text-slate-900">@(Model.CurrentUser.CompanyProfile.CompanyName ?? "-")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.CurrentUser.CompanyProfile.WebsiteUrl))
                        {
                            <div class="p-4 bg-slate-50/50 rounded-2xl border border-slate-100 flex justify-between items-center group hover:bg-white hover:border-indigo-100 transition-all">
                                <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Website</span>
                                <a href="@Model.CurrentUser.CompanyProfile.WebsiteUrl" target="_blank" class="text-[10px] font-black text-indigo-600 hover:underline truncate max-w-[150px]">@Model.CurrentUser.CompanyProfile.WebsiteUrl.Replace("https://", "").Replace("http://", "")</a>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Right Column: Tabs -->
        <div class="lg:col-span-8">
            <form id="avatarForm" method="post" asp-page-handler="UploadAvatar" enctype="multipart/form-data" class="hidden">
                <input type="file" id="avatarInput" asp-for="AvatarFile" accept="image/*" onchange="submitAvatarForm()" />
                <input type="hidden" asp-for="Tab" />
            </form>

            <form method="post" asp-page-handler="Update" enctype="multipart/form-data">
                <input type="hidden" asp-for="Tab" />

                @if (Model.Tab == "IDENTITY")
                {
                    <div class="p-12 space-y-10 bg-white rounded-[2.5rem] border border-slate-200/60 animate-in fade-in slide-in-from-right-8 duration-700 shadow-xl shadow-slate-200/10">
                            <div class="flex justify-between items-center pb-8 border-b border-slate-50">
                                <div>
                                    <h4 class="text-xs font-black uppercase tracking-[0.3em] text-slate-900 mb-1">Thông Tin Cá Nhân</h4>
                                    <p class="text-[10px] text-slate-400 font-bold uppercase">Quản lý thông tin định danh và quyền liên lạc</p>
                                </div>
                            <div class="w-12 h-12 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600">
                                <i class="fas fa-fingerprint text-xl"></i>
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                            <div class="space-y-3">
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Họ Và Tên</label>
                                <div class="relative group">
                                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-400 group-focus-within:text-indigo-500 transition-colors">
                                        <i class="fas fa-user-tag text-xs"></i>
                                    </div>
                                    <input asp-for="UpdateInput.FullName" placeholder="Nhập họ và tên" readonly="@(!Model.IsOwnProfile)"
                                           class="w-full h-14 bg-slate-50 border border-slate-100 rounded-2xl pl-11 pr-4 text-sm font-semibold text-slate-900 focus:bg-white focus:border-indigo-400 focus:ring-4 focus:ring-indigo-50/50 transition-all outline-none @(!Model.IsOwnProfile ? "cursor-not-allowed opacity-80" : "")" />
                                </div>
                            </div>
                            <div class="space-y-3">
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Địa chỉ Email (Không thể thay đổi)</label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-300">
                                        <i class="fas fa-envelope text-xs"></i>
                                    </div>
                                    <input type="text" value="@(Model.CurrentUser?.Email)" disabled 
                                           class="w-full h-14 bg-slate-50/50 border border-slate-100 rounded-2xl pl-11 pr-4 text-sm font-semibold text-slate-400 outline-none cursor-not-allowed" />
                                </div>
                            </div>
                            <div class="space-y-3">
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Vai Trò Hệ Thống</label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-300">
                                        <i class="fas fa-shield-halved text-xs"></i>
                                    </div>
                                     <input type="text" value="@(Model.CurrentUser?.Role == "CANDIDATE" ? "ỨNG VIÊN" : Model.CurrentUser?.Role == "RECRUITER" ? "NHÀ TUYỂN DỤNG" : Model.CurrentUser?.Role == "ADMIN" ? "QUẢN TRỊ VIÊN" : Model.CurrentUser?.Role)" disabled 
                                           class="w-full h-14 bg-slate-100/50 border border-slate-100 rounded-2xl pl-11 pr-4 text-[10px] font-black uppercase tracking-widest text-slate-500 outline-none" />
                                </div>
                            </div>
                            <div class="space-y-3">
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Ngày Đăng Ký</label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-300">
                                        <i class="fas fa-calendar-check text-xs"></i>
                                    </div>
                                     <input type="text" value="@(Model.CurrentUser?.CreatedAt.ToString("dd/MM/yyyy"))" disabled 
                                           class="w-full h-14 bg-slate-100/50 border border-slate-100 rounded-2xl pl-11 pr-4 text-sm font-semibold text-slate-400 outline-none" />
                                </div>
                            </div>
                        </div>
                        @if (Model.IsOwnProfile)
                        {
                            <div class="pt-10 flex justify-end border-t border-slate-50">
                                <button type="submit" class="px-12 h-14 bg-indigo-600 text-white font-black rounded-2xl shadow-2xl shadow-indigo-200 hover:bg-indigo-700 hover:-translate-y-1 transition-all active:translate-y-0 text-[10px] uppercase tracking-[0.2em] flex items-center gap-3">
                                    <i class="fas fa-cloud-arrow-up text-xs"></i> Cập Nhật Thông Tin
                                </button>
                            </div>
                        }
                    </div>
                }

                @if (Model.Tab == "SKILLS" && isCandidate)
                {
                    <div class="p-12 space-y-10 bg-white rounded-[2.5rem] border border-slate-200/60 animate-in fade-in slide-in-from-right-8 duration-700 shadow-xl shadow-slate-200/10">
                        <div class="flex justify-between items-center pb-8 border-b border-slate-50">
                            <div>
                                <h4 class="text-xs font-black uppercase tracking-[0.3em] text-slate-900 mb-1">Kỹ Năng & Lĩnh Vực Chuyên Môn</h4>
                                <p class="text-[10px] text-slate-400 font-bold uppercase">Định hình năng lực cốt lõi và mức lương kỳ vọng</p>
                            </div>
                            <div class="w-12 h-12 bg-violet-50 rounded-2xl flex items-center justify-center text-violet-600">
                                <i class="fas fa-brain text-xl"></i>
                            </div>
                        </div>
                        <div class="space-y-8">
                            <div class="space-y-3">
                                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Danh Sách Kỹ Năng (Cách nhau bởi dấu phẩy)</label>
                                <div class="relative group">
                                    <div class="absolute top-4 left-4 text-slate-400 group-focus-within:text-violet-500 transition-colors">
                                        <i class="fas fa-code text-xs"></i>
                                    </div>
                                    <textarea asp-for="UpdateInput.Skills" rows="4" readonly="@(!Model.IsOwnProfile)"
                                              class="w-full bg-slate-50 border border-slate-100 rounded-[1.5rem] pl-11 pr-6 py-4 text-sm font-semibold text-slate-900 focus:bg-white focus:border-violet-400 focus:ring-4 focus:ring-violet-50/50 transition-all outline-none resize-none leading-relaxed @(!Model.IsOwnProfile ? "cursor-not-allowed opacity-80" : "")"
                                              placeholder="VD: C#, ASP.NET Core, React, SQL Server, Azure..."></textarea>
                                </div>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                <div class="space-y-3">
                                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Kinh Nghiệm Làm Việc (Năm)</label>
                                    <div class="relative group">
                                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-400 group-focus-within:text-violet-500 transition-colors">
                                            <i class="fas fa-briefcase text-xs"></i>
                                        </div>
                                        <input asp-for="UpdateInput.ExperienceYears" type="number" min="0" max="50" readonly="@(!Model.IsOwnProfile)"
                                               class="w-full h-14 bg-slate-50 border border-slate-100 rounded-2xl pl-11 pr-4 text-sm font-semibold text-slate-900 focus:bg-white focus:border-violet-400 focus:ring-4 focus:ring-violet-50/50 transition-all outline-none @(!Model.IsOwnProfile ? "cursor-not-allowed opacity-80" : "")" />
                                    </div>
                                </div>
                                <div class="space-y-3">
                                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Mức Lương Mong Muốn (VNĐ / Tháng)</label>
                                    <div class="relative group">
                                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-400 group-focus-within:text-emerald-500 transition-colors">
                                            <i class="fas fa-hand-holding-dollar text-xs"></i>
                                        </div>
                                        <input asp-for="UpdateInput.ExpectedSalary" type="number" min="0" step="500000" readonly="@(!Model.IsOwnProfile)"
                                               class="w-full h-14 bg-slate-50 border border-slate-100 rounded-2xl pl-11 pr-4 text-sm font-black text-emerald-600 focus:bg-white focus:border-emerald-400 focus:ring-4 focus:ring-emerald-50/50 transition-all outline-none @(!Model.IsOwnProfile ? "cursor-not-allowed opacity-80" : "")"
                                               placeholder="e.g. 20000000" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        @if (Model.IsOwnProfile)
                        {
                            <div class="pt-10 flex justify-end border-t border-slate-50">
                                <button type="submit" class="px-12 h-14 bg-violet-600 text-white font-black rounded-2xl shadow-2xl shadow-violet-200 hover:bg-violet-700 hover:-translate-y-1 transition-all text-[10px] uppercase tracking-[0.2em] flex items-center gap-3">
                                    <i class="fas fa-save text-xs"></i> Cập Nhật Kỹ Năng
                                </button>
                            </div>
                        }
                    </div>
                }

                @if (Model.Tab == "CVS" && isCandidate)
{
    <div class="p-12 space-y-10 bg-white rounded-[2.5rem] border border-slate-200/60 animate-in fade-in slide-in-from-right-8 duration-700 shadow-xl shadow-slate-200/10">
        
        <div class="flex justify-between items-center pb-8 border-b border-slate-50">
            <div>
                <h4 class="text-xs font-black uppercase tracking-[0.3em] text-slate-900 mb-1">Quản Lý Hồ Sơ CV</h4>
                <p class="text-[10px] text-slate-400 font-bold uppercase">Tải lên tài liệu và xem trước định dạng</p>
            </div>
            <div class="w-12 h-12 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600">
                <i class="fas fa-file-pdf text-xl"></i>
            </div>
        </div>

        <div class="space-y-8">
            @if (!string.IsNullOrEmpty(Model.CurrentUser?.CandidateProfile?.CVUrl))
            {
                 <div class="flex items-center justify-between mb-2">
                     <span class="text-[10px] font-black uppercase tracking-widest text-slate-400 px-1">Xem Trước Tài Liệu</span>
                     <button type="button" onclick="reloadCVPreview()" class="text-[10px] font-black uppercase tracking-widest text-indigo-600 hover:text-indigo-700 flex items-center gap-2 transition-all group/reload">
                         <i class="fas fa-sync-alt group-hover/reload:rotate-180 transition-transform duration-500"></i> Tải Lại Lập Tức
                     </button>
                 </div>

                <div class="p-6 bg-slate-50 border border-slate-100 rounded-[1.5rem] flex flex-col md:flex-row items-center justify-between gap-6">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center text-red-500 border border-slate-100">
                            <i class="fas fa-file-pdf text-xl"></i>
                        </div>
                        <div>
                            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">CV Hiện Tại</p>
                            <p class="text-sm font-bold text-slate-900">Tài liệu đang mở</p>
                        </div>
                    </div>
                    <div class="flex gap-3">
                        <a href="@Model.CurrentUser.CandidateProfile.CVUrl" download 
                           class="px-6 py-3 bg-indigo-600 text-white font-black rounded-xl text-[10px] uppercase tracking-widest hover:bg-indigo-700 shadow-lg shadow-indigo-100 transition-all flex items-center gap-2">
                            <i class="fas fa-download"></i> Tải Xuống
                        </a>
                    </div>
                </div>



                                <div class="relative w-full rounded-2xl border border-slate-200 shadow-inner bg-slate-50 flex justify-center items-center overflow-hidden group" style="height: 800px;">
                                    <div id="cvLoadingState" class="absolute inset-0 flex flex-col items-center justify-center text-slate-400 z-0 transition-opacity duration-300">
                                        <i class="fas fa-spinner fa-spin text-3xl mb-3"></i>
                                        <span class="text-xs font-bold uppercase tracking-widest">Đang khởi tạo xem trước...</span>
                                    </div>

                                    <iframe id="cvIframe" 
                                            src="https://docs.google.com/gview?url=@(System.Net.WebUtility.UrlEncode(Model.CurrentUser.CandidateProfile.CVUrl))&embedded=true"
                                            class="relative z-10 w-full h-full border-none bg-transparent opacity-0 transition-opacity duration-500"
                                            title="CV Preview"
                                            onload="handleCVLoad(this)">
                                    </iframe>
                                </div>

            }
            else
            {
                <div class="text-center py-10 border-2 border-dashed border-slate-200 rounded-[2rem] bg-slate-50/50">
                    <div class="w-16 h-16 bg-white rounded-full shadow-sm flex items-center justify-center text-slate-300 mx-auto mb-4">
                        <i class="fas fa-cloud-upload-alt text-2xl"></i>
                    </div>
                    <p class="text-sm font-bold text-slate-400">Bạn chưa tải lên CV nào</p>
                    <p class="text-[10px] text-slate-400 uppercase tracking-widest mt-1">Tải lên định dạng PDF để tăng cơ hội tìm việc</p>
                </div>
            }

            @if (Model.IsOwnProfile)
            {
                <div class="pt-6 border-t border-slate-50">
                    <div class="space-y-6">
                        <input type="hidden" asp-for="Tab" value="CVS" />
                        <div class="space-y-3">
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Tải Lên Phiên Bản Mới (Chỉ hỗ trợ PDF)</label>
                            <div class="relative group">
                                <input type="file" asp-for="CvFile" accept=".pdf" 
