@page "/Account/Transactions"
@model WebPortal.Pages.TransactionHistoryModel
@{
    ViewData["Title"] = "Lịch Sử Giao Dịch - SmartRecruit";
}

<div class="max-w-6xl mx-auto space-y-8 animate-in fade-in duration-700 pb-32">
    <!-- Header with Back Button -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <a asp-page="/Account/Wallet" class="inline-flex items-center text-xs font-black uppercase tracking-widest text-slate-400 hover:text-indigo-600 transition-colors mb-2">
                <i class="fas fa-arrow-left mr-2"></i> Quay Lại Ví
            </a>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight flex items-center gap-3">
                <i class="fas fa-history text-indigo-600"></i>
                Lịch Sử Giao Dịch
            </h2>
        </div>
        
        <div class="p-4 bg-indigo-50 border border-indigo-100 rounded-2xl flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl bg-indigo-600 flex items-center justify-center text-white shadow-lg shadow-indigo-100">
                <i class="fas fa-wallet"></i>
            </div>
            <div>
                <p class="text-[10px] font-black text-indigo-400 uppercase tracking-widest mb-0.5">Số Dư Hiện Tại</p>
                <p class="text-lg font-black text-indigo-900">@Model.Balance.ToString("N0") <span class="text-xs">VNĐ</span></p>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="bg-white p-6 rounded-[2rem] border border-slate-200 shadow-sm">
        <form method="get" class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
            <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Loại Giao Dịch</label>
                <select asp-for="Type" class="w-full h-11 bg-slate-50 border border-slate-100 rounded-xl px-4 text-xs font-bold text-slate-700 focus:bg-white focus:border-indigo-400 transition-all outline-none">
                    <option value="">Tất Cả Thể Loại</option>
                    <option value="0">Top-up (Nạp tiền)</option>
                    <option value="1">Job Post (Đăng tin)</option>
                    <option value="2">Boost (Đẩy tin)</option>
                    <option value="3">VIP Upgrade (Nâng cấp VIP)</option>
                    <option value="4">Other (Khác)</option>
                </select>
            </div>
            <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Trạng Thái</label>
                <select asp-for="Status" class="w-full h-11 bg-slate-50 border border-slate-100 rounded-xl px-4 text-xs font-bold text-slate-700 focus:bg-white focus:border-indigo-400 transition-all outline-none">
                    <option value="">Tất Cả Trạng Thái</option>
                    <option value="0">Đang Xử Lý</option>
                    <option value="1">Thành Công</option>
                    <option value="2">Thất Bại</option>
                </select>
            </div>
            <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Kích Thước Trang</label>
                <select asp-for="PageSize" class="w-full h-11 bg-slate-50 border border-slate-100 rounded-xl px-4 text-xs font-bold text-slate-700 focus:bg-white focus:border-indigo-400 transition-all outline-none">
                    <option value="10">10 kết quả hiển thị</option>
                    <option value="20">20 kết quả hiển thị</option>
                    <option value="50">50 kết quả hiển thị</option>
                </select>
            </div>
            <div class="flex gap-2">
                <button type="submit" class="flex-1 h-11 bg-indigo-600 text-white text-xs font-black uppercase tracking-widest rounded-xl shadow-lg shadow-indigo-100 hover:bg-indigo-700 transition-all">
                    Lọc Kết Quả
                </button>
                <a asp-page="/Account/TransactionList" class="w-11 h-11 flex items-center justify-center bg-slate-100 text-slate-500 rounded-xl hover:bg-slate-200 transition-all">
                    <i class="fas fa-undo-alt"></i>
                </a>
            </div>
        </form>
    </div>

    <!-- Transactions Table -->
    <div class="overflow-hidden bg-white border border-slate-200 rounded-[2rem] shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-slate-50 border-b border-slate-200">
                    <tr>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Giao Dịch</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Thời Gian</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Trạng Thái</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Loại</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-right">Số Tiền</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-center">Hành Động</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (Model.Transactions == null || !Model.Transactions.Data.Any())
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-20 text-center">
                                <div class="flex flex-col items-center gap-3">
                                    <div class="w-16 h-16 rounded-3xl bg-slate-50 flex items-center justify-center text-slate-200 text-2xl">
                                        <i class="fas fa-receipt"></i>
                                    </div>
                                    <p class="text-slate-400 font-bold">Không tìm thấy giao dịch nào phù hợp với bộ lọc.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var tx in Model.Transactions.Data)
                        {
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center gap-3">
                                        @{
                                            var deductionTypes = new[] { "JOB_POST", "BOOST", "VIP", "OTHER" };
                                            var isActuallyDeduction = deductionTypes.Contains(tx.Type?.ToUpper());
                                            var displayAmount = isActuallyDeduction && tx.Amount > 0 ? -tx.Amount : tx.Amount;
                                            var isVisualTopUp = displayAmount >= 0;
                                        }
                                        <div class="w-9 h-9 rounded-full flex items-center justify-center text-xs shadow-sm @(isVisualTopUp ? "bg-green-100 text-green-600" : "bg-red-50 text-red-500")">
                                            <i class="fas @(isVisualTopUp ? "fa-arrow-down" : "fa-arrow-up")"></i>
                                        </div>
                                        <span class="text-sm font-bold text-slate-700 truncate max-w-[200px]" title="@tx.Description">@tx.Description</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 font-medium">
                                    @tx.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    @switch (tx.Status?.ToUpper())
                                    {
                                        case "SUCCESS":
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-black uppercase bg-green-100 text-green-800">THÀNH CÔNG</span>
                                            break;
                                        case "FAILED":
                                        case "CANCELLED":
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-black uppercase bg-red-100 text-red-800">THẤT BẠI</span>
                                            break;
                                        default:
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-black uppercase bg-amber-100 text-amber-800">@(string.IsNullOrEmpty(tx.Status) || tx.Status == "PENDING" ? "ĐANG XỬ LÝ" : tx.Status)</span>
                                            break;
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="text-[10px] font-black uppercase text-slate-400">
                                        @(tx.Type == "TOPUP" ? "Nạp Tiền" : tx.Type == "JOB_POST" ? "Đăng Tin" : tx.Type == "BOOST" ? "Đẩy Tin" : tx.Type == "VIP" ? "Nâng Cấp VIP" : tx.Type)
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-black text-right @(isVisualTopUp ? "text-green-600" : "text-slate-800")">
                                    @(isVisualTopUp ? "+" : "")@displayAmount.ToString("N0") VNĐ
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-center">
                                    @if (tx.Status?.ToUpper() == "PENDING" || string.IsNullOrEmpty(tx.Status))
                                    {
                                        @if (tx.OrderCode.HasValue && tx.Type == "TOPUP")
                                        {
                                            <button onclick="resumePayment(event, @tx.OrderCode)" class="px-4 py-1.5 bg-indigo-600 text-white text-[10px] font-black rounded-lg hover:bg-indigo-700 transition-all shadow-md shadow-indigo-100">THANH TOÁN</button>
                                        }
                                        else
                                        {
                                            <span class="text-slate-300">-</span>
                                        }
                                    }
                                    else
                                    {
                                        <button onclick='showTxDetails(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(tx)))' class="px-4 py-1.5 bg-slate-100 text-slate-600 text-[10px] font-black rounded-lg hover:bg-slate-200 transition-all">CHI TIẾT</button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.Transactions != null && Model.Transactions.TotalPages > 1)
        {
            <div class="px-6 py-6 bg-slate-50 border-t border-slate-200 flex items-center justify-between">
                <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest">
                    Trang @Model.Transactions.Page / @Model.Transactions.TotalPages
                </div>
                <div class="flex gap-2">
                    @if (Model.Transactions.Page > 1)
                    {
                        <a asp-page="/Account/TransactionList" 
                           asp-route-PageNumber="@(Model.Transactions.Page - 1)" 
                           asp-route-PageSize="@Model.PageSize"
                           asp-route-Type="@Model.Type"
                           asp-route-Status="@Model.Status"
                           class="px-4 py-2 bg-white border border-slate-200 rounded-xl text-xs font-bold text-slate-600 hover:border-indigo-400 hover:text-indigo-600 transition-all shadow-sm">
                            Trang Trước
                        </a>
                    }
                    else
                    {
                        <button disabled class="px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-xs font-bold text-slate-300 cursor-not-allowed">Trang Trước</button>
                    }

                    @if (Model.Transactions.Page < Model.Transactions.TotalPages)
                    {
                        <a asp-page="/Account/TransactionList" 
                           asp-route-PageNumber="@(Model.Transactions.Page + 1)" 
                           asp-route-PageSize="@Model.PageSize"
                           asp-route-Type="@Model.Type"
                           asp-route-Status="@Model.Status"
                           class="px-4 py-2 bg-white border border-slate-200 rounded-xl text-xs font-bold text-slate-600 hover:border-indigo-400 hover:text-indigo-600 transition-all shadow-sm">
                            Trang Sau
                        </a>
                    }
                    else
                    {
                        <button disabled class="px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-xs font-bold text-slate-300 cursor-not-allowed">Trang Sau</button>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- Transaction Detail Modal (Reused from Wallet) -->
<div id="txModal" class="fixed inset-0 z-[300] hidden items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm animate-in fade-in duration-300">
    <div class="bg-white w-full max-w-md rounded-[2.5rem] shadow-2xl border border-slate-100 overflow-hidden animate-in zoom-in-95 duration-300">
        <div class="p-8 bg-gradient-to-br from-slate-50 to-white border-b border-slate-50">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl font-black text-slate-900 uppercase tracking-wider">Chi Tiết Giao Dịch</h3>
                <button onclick="closeTxModal()" class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 hover:text-slate-600 transition-all">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <div id="txDetailsContent" class="space-y-4">
            </div>
        </div>
        <div class="p-6 bg-slate-50 flex justify-center">
            <button onclick="closeTxModal()" class="px-10 py-3 bg-slate-900 text-white rounded-2xl text-xs font-black uppercase tracking-[0.2em] hover:bg-slate-800 transition-all">Đóng</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function resumePayment(event, orderCode) {
            const btn = event.currentTarget;
            const originalContent = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            btn.disabled = true;

            try {
                // Determine root from current location
                const apiBase = window.appConfig?.apiBaseUrl || '/api/';
                const token = window.appConfig?.accessToken || '';

                const response = await fetch(`${apiBase}payment/${orderCode}/link`, {
                    headers: {
                        'Authorization': 'Bearer ' + token
                    }
                });
                
                if (response.ok) {
                    const json = await response.json();
                    if (json.data && json.data.paymentUrl) {
                        window.location.href = json.data.paymentUrl;
                    } else {
                        showToast('Lỗi', 'Đường dẫn thanh toán không tồn tại hoặc đã hết hạn.', 'warning');
                    }
                } else {
                    const errorJson = await response.json();
                    showToast('Lỗi', errorJson.message || 'Lấy đường dẫn thanh toán thất bại.', 'warning');
                }
            } catch (e) {
                showToast('Lỗi', 'Kết nối thất bại.', 'warning');
            } finally {
                btn.innerHTML = originalContent;
                btn.disabled = false;
            }
        }

        function showTxDetails(tx) {
            const content = document.getElementById('txDetailsContent');
            const date = new Date(tx.CreatedAt).toLocaleString('vi-VN', { 
                day: '2-digit', month: '2-digit', year: 'numeric', 
                hour: '2-digit', minute: '2-digit' 
            });
            
            const deductionTypes = ['JOB_POST', 'BOOST', 'VIP', 'OTHER'];
            const isActuallyDeduction = deductionTypes.includes(tx.Type?.toUpperCase());
            const displayAmount = (isActuallyDeduction && tx.Amount > 0) ? -tx.Amount : tx.Amount;
            const isVisualTopUp = displayAmount >= 0;

            const statusColor = tx.Status?.toUpperCase() === 'SUCCESS' ? 'text-green-600 bg-green-50' : 
                              (tx.Status?.toUpperCase() === 'FAILED' || tx.Status?.toUpperCase() === 'CANCELLED' ? 'text-red-600 bg-red-50' : 'text-amber-600 bg-amber-50');

            content.innerHTML = `
                <div class="flex flex-col items-center py-4 mb-2">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Tổng Số Tiền</p>
                    <h4 class="text-3xl font-black ${isVisualTopUp ? 'text-green-600' : 'text-slate-900'}">
                        ${isVisualTopUp ? '+' : ''}${displayAmount.toLocaleString()} VNĐ
                    </h4>
                </div>
                <div class="grid grid-cols-1 gap-3">
                    <div class="flex justify-between items-center p-4 bg-white rounded-2xl border border-slate-100">
                        <span class="text-[10px] font-black text-slate-400 uppercase">Phân Loại</span>
                        <span class="text-xs font-black text-slate-700 font-mono">${tx.Type}</span>
                    </div>
                    <div class="flex justify-between items-center p-4 bg-white rounded-2xl border border-slate-100">
                        <span class="text-[10px] font-black text-slate-400 uppercase">Trạng Thái</span>
                        <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase ${statusColor}">${tx.Status === 'SUCCESS' ? 'THÀNH CÔNG' : (tx.Status === 'FAILED' || tx.Status === 'CANCELLED' ? 'THẤT BẠI' : 'ĐANG XỬ LÝ')}</span>
                    </div>
                    <div class="flex justify-between items-center p-4 bg-white rounded-2xl border border-slate-100">
                        <span class="text-[10px] font-black text-slate-400 uppercase">Mã Thanh Toán</span>
                        <span class="text-xs font-bold text-slate-600 font-mono">${tx.OrderCode || 'N/A'}</span>
                    </div>
                    <div class="flex justify-between items-center p-4 bg-white rounded-2xl border border-slate-100">
                        <span class="text-[10px] font-black text-slate-400 uppercase">Thời Gian</span>
                        <span class="text-xs font-bold text-slate-600">${date}</span>
                    </div>
                    <div class="p-4 bg-white rounded-2xl border border-slate-100">
                        <span class="text-[10px] font-black text-slate-400 uppercase block mb-2">Mô Tả Tiết</span>
                        <p class="text-xs font-medium text-slate-600 leading-relaxed">${tx.Description || 'Không có mô tả chi tiết giao dịch.'}</p>
                    </div>
                </div>
            `;
            
            const modal = document.getElementById('txModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeTxModal() {
            document.getElementById('txModal').classList.add('hidden');
            document.getElementById('txModal').classList.remove('flex');
        }

        function showToast(title, msg, type) {
            const toast = document.createElement('div');
            toast.className = `fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-[200] p-8 rounded-[2rem] shadow-2xl border animate-in zoom-in-95 fade-in duration-500 flex flex-col items-center text-center gap-4 max-w-sm w-full bg-white mx-4 ${
                type === 'success' ? 'border-green-100' : 'border-yellow-100'
            }`;
            
            const icon = type === 'success' ? 'fa-check-circle text-green-500' : 'fa-exclamation-triangle text-yellow-500';
            
            toast.innerHTML = `
                <div class="w-16 h-16 rounded-3xl flex items-center justify-center bg-slate-50 mb-2">
                    <i class="fas ${icon} text-3xl"></i>
                </div>
                <div class="space-y-1">
                    <h4 class="text-lg font-black uppercase tracking-widest text-slate-900">${title}</h4>
                    <p class="text-xs text-slate-500 font-medium">${msg}</p>
                </div>
                <button onclick="this.parentElement.remove()" class="mt-2 px-8 py-2 bg-slate-100 hover:bg-slate-200 rounded-xl text-[10px] font-black uppercase tracking-widest text-slate-600">Đóng</button>
            `;
            
            document.body.appendChild(toast);
        }
    </script>
}
