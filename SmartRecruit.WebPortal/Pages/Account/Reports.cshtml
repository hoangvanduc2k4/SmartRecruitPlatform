@page "/Reports"
@model WebPortal.Pages.ReportsModel
@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="space-y-8 animate-in fade-in duration-700 pb-20">
    <div class="flex justify-between items-center bg-white p-8 rounded-[2rem] border border-slate-200 shadow-sm">
        <div>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest bg-emerald-50 text-emerald-600 mb-2">Insights Terminal</span>
            <h2 class="text-3xl font-black text-slate-800 tracking-tighter">Reports & Analytics</h2>
            <p class="text-slate-500 font-medium">Analyze your recruitment performance and export candidate data.</p>
        </div>
        <button onclick="alert('Exporting data as CSV... Done!')" class="h-12 px-6 bg-slate-900 text-white font-bold rounded-2xl hover:bg-slate-800 shadow-xl shadow-slate-200/50 transition flex items-center gap-2">
            <i class="fas fa-file-excel"></i> Export All Data
        </button>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="p-6 bg-white rounded-2xl border border-slate-200 shadow-sm">
            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Hiring Speed</p>
            <div class="flex items-end justify-between">
                <h3 class="text-3xl font-black text-slate-800 tracking-tighter">12 Days</h3>
                <span class="text-xs font-bold text-indigo-500">-2d</span>
            </div>
        </div>
        <div class="p-6 bg-white rounded-2xl border border-slate-200 shadow-sm">
            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Avg Match Score</p>
            <div class="flex items-end justify-between">
                <h3 class="text-3xl font-black text-slate-800 tracking-tighter">78.4%</h3>
                <span class="text-xs font-bold text-green-500">+5%</span>
            </div>
        </div>
        <div class="p-6 bg-white rounded-2xl border border-slate-200 shadow-sm">
            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Offer Rate</p>
            <div class="flex items-end justify-between">
                <h3 class="text-3xl font-black text-slate-800 tracking-tighter">4.2%</h3>
                <span class="text-xs font-bold text-green-500">+1.2%</span>
            </div>
        </div>
        <div class="p-6 bg-white rounded-2xl border border-slate-200 shadow-sm">
            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Cost Per Hire</p>
            <div class="flex items-end justify-between">
                <h3 class="text-3xl font-black text-slate-800 tracking-tighter">$450</h3>
                <span class="text-xs font-bold text-indigo-500">-$50</span>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Pipeline Conversion -->
        <div class="p-8 bg-white rounded-[2rem] border border-slate-200 shadow-sm">
            <h3 class="font-bold text-slate-800 mb-6 flex items-center justify-between">
                Pipeline Conversion
                <span class="text-xs text-slate-400">Past 30 Days</span>
            </h3>
            <div class="space-y-6">
                <div>
                    <div class="flex justify-between text-xs font-bold mb-2">
                        <span class="text-slate-600">Applications</span>
                        <span class="text-slate-400">450 (100%)</span>
                    </div>
                    <div class="w-full h-2 bg-slate-100 rounded-full overflow-hidden">
                        <div class="h-full bg-indigo-500 rounded-full" style="width: 100%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between text-xs font-bold mb-2">
                        <span class="text-slate-600">Screening</span>
                        <span class="text-slate-400">120 (26%)</span>
                    </div>
                    <div class="w-full h-2 bg-slate-100 rounded-full overflow-hidden">
                        <div class="h-full bg-indigo-500 rounded-full" style="width: 26%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between text-xs font-bold mb-2">
                        <span class="text-slate-600">Interview</span>
                        <span class="text-slate-400">45 (10%)</span>
                    </div>
                    <div class="w-full h-2 bg-slate-100 rounded-full overflow-hidden">
                        <div class="h-full bg-indigo-500 rounded-full" style="width: 10%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between text-xs font-bold mb-2">
                        <span class="text-slate-600">Offered</span>
                        <span class="text-slate-400">12 (2.6%)</span>
                    </div>
                    <div class="w-full h-2 bg-slate-100 rounded-full overflow-hidden">
                        <div class="h-full bg-indigo-500 rounded-full" style="width: 2.6%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="p-8 bg-white rounded-[2rem] border border-slate-200 shadow-sm flex flex-col justify-center items-center text-center">
            <div class="w-24 h-24 border-8 border-indigo-600 border-t-slate-100 rounded-full flex items-center justify-center mb-6">
                <span class="text-xl font-black text-slate-800">82%</span>
            </div>
            <h4 class="font-bold text-slate-800 mb-2">ROI Efficiency</h4>
            <p class="text-sm text-slate-500 max-w-xs mb-6">Your recruitment ROI is in the top 10% of tech companies this quarter.</p>
            <button class="w-full h-12 bg-slate-100 text-slate-700 font-bold rounded-2xl hover:bg-slate-200 transition">View Detailed Insights</button>
        </div>
    </div>
</div>
