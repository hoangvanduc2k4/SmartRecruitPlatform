@page "/JobPipeline/{id}"
@model WebPortal.Pages.Recruiter.JobPipelineModel
@using WebPortal.Models
@{
    ViewData["Title"] = "Job Pipeline";
    var statuses = new[]
    {
        new { Status = ApplicationStatus.REVIEWING, Label = "Đang Xem Xét", Icon = "fa-search", Color = "bg-indigo-400 shadow-indigo-400/30" },
        new { Status = ApplicationStatus.INTERVIEWING, Label = "Phỏng Vấn", Icon = "fa-comments", Color = "bg-amber-400 shadow-amber-400/30" },
        new { Status = ApplicationStatus.OFFERED, Label = "Đề Nghị Trúng Tuyển", Icon = "fa-gift", Color = "bg-green-400 shadow-green-400/30" },
        new { Status = ApplicationStatus.REJECTED, Label = "Đã Từ Chối", Icon = "fa-circle-xmark", Color = "bg-red-400 shadow-red-400/30" }
    };
}

<!-- Modal Backdrop -->
<div id="statusModal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 hidden items-center justify-center p-4 animate-in fade-in duration-300">
    <!-- Modal Content -->
    <div class="bg-white rounded-[2rem] shadow-2xl w-full max-w-md overflow-hidden transform transition-all animate-in zoom-in-95 duration-300">
        <div class="p-8">
            <div id="modalIconContainer" class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
                <i id="modalIcon" class="fas text-2xl text-white"></i>
            </div>
            <h3 id="modalTitle" class="text-2xl font-black text-slate-800 tracking-tight uppercase mb-2">Cập Nhật Trạng Thái</h3>
            <p id="modalDescription" class="text-slate-500 text-sm font-medium mb-8">Vui lòng cung cấp thông tin cần thiết để tiếp tục.</p>

            <form id="modalForm" method="post" asp-page-handler="UpdateStatus">
                <input type="hidden" name="applicationId" id="modalAppId" />
                <input type="hidden" name="jobId" id="modalJobId" />
                <input type="hidden" name="status" id="modalStatus" />

                <div id="dateField" class="hidden space-y-2 mb-8">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Ngày Phỏng Vấn</label>
                    <input type="datetime-local" id="interviewDateInput" name="interviewDate" class="w-full h-14 px-6 bg-slate-50 border border-slate-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition-all font-bold text-slate-700" />
                    <p id="dateError" class="text-red-500 text-[10px] font-bold uppercase tracking-widest px-1 hidden">Vui lòng chọn ngày trong tương lai</p>
                </div>

                <div id="reasonField" class="hidden space-y-2 mb-8">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Lý Do Từ Chối</label>
                    <textarea name="rejectionReason" rows="3" class="w-full p-6 bg-slate-50 border border-slate-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition-all font-medium text-slate-700 placeholder:text-slate-300" placeholder="vd: Không đủ kinh nghiệm..."></textarea>
                </div>

                <div class="flex gap-4 pt-4">
                    <button type="button" onclick="closeModal()" class="flex-1 h-14 rounded-2xl border border-slate-200 text-slate-500 font-black text-[11px] uppercase tracking-widest hover:bg-slate-50 transition-all">Hủy</button>
                    <button type="submit" class="flex-1 h-14 rounded-2xl bg-indigo-600 text-white font-black text-[11px] uppercase tracking-widest shadow-lg shadow-indigo-100 hover:bg-indigo-700 transition-all">Xác Nhận</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="space-y-8 animate-in fade-in duration-700 pb-32">
    @if (Model.SuccessMessage != null)
    {
        <div class="p-4 mb-4 text-sm text-green-800 rounded-2xl bg-green-50 border border-green-100 animate-in slide-in-from-top-4 duration-300">
            <i class="fas fa-check-circle mr-2"></i> @Model.SuccessMessage
        </div>
    }
    @if (Model.ErrorMessage != null)
    {
        <div class="p-4 mb-4 text-sm text-red-800 rounded-2xl bg-red-50 border border-red-100 animate-in slide-in-from-top-4 duration-300">
            <i class="fas fa-exclamation-circle mr-2"></i> @Model.ErrorMessage
        </div>
    }

    <div class="flex flex-col gap-4">
        <div class="flex items-center gap-3">
            <a href="/RecruiterJobs" class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-slate-200 rounded-xl text-[11px] font-black uppercase tracking-widest text-slate-600 hover:text-indigo-600 hover:border-indigo-100 transition-all shadow-sm">
                <i class="fas fa-arrow-left"></i> Quay lại Job Hub
            </a>
            <a href="/Jobs/JobDetail?Id=@Model.Job?.Id" class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-50 border border-indigo-100 rounded-xl text-[11px] font-black uppercase tracking-widest text-indigo-600 hover:bg-indigo-100 transition-all shadow-sm">
                <i class="fas fa-info-circle"></i> Chi tiết Job
            </a>
        </div>
        <div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight uppercase">Sơ Đồ Tuyển Dụng</h2>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-1">Sắp xếp tình trạng ứng viên qua các giai đoạn tuyển dụng</p>
        </div>
    </div>

    <div class="flex gap-8 overflow-x-auto pb-16 snap-x custom-scrollbar min-h-[700px] items-start">
        @foreach (var col in statuses)
        {
            var appsInColumn = Model.Applications.Where(a => a.Status == col.Status).ToList();
            
            <div class="flex-shrink-0 w-80 snap-start flex flex-col gap-6 group/col">
                <!-- Column Header -->
                <div class="flex items-center justify-between px-4">
                    <div class="flex items-center gap-4">
                        <div class="w-3 h-3 rounded-full @col.Color shadow-lg ring-4 ring-white"></div>
                        <span class="font-black text-slate-900 text-[10px] uppercase tracking-[0.3em]">@col.Label</span>
                    </div>
                    <span class="inline-flex items-center justify-center px-2 py-1 text-xs font-bold leading-none @(col.Status == ApplicationStatus.REJECTED ? "text-red-100 bg-red-600" : "text-indigo-100 bg-indigo-600") rounded-full">
                        @appsInColumn.Count
                    </span>
                </div>

                <!-- Column Body -->
                <div class="rounded-[2.5rem] p-4 flex-1 border min-h-[600px] space-y-6 transition-all duration-300 @(col.Status == ApplicationStatus.REJECTED ? "bg-red-50/20 border-red-100/30 shadow-inner" : "bg-slate-100/40 border-slate-200/50 group-hover/col:bg-indigo-50/20 group-hover/col:border-indigo-100/50")">
                    @if (appsInColumn.Count == 0)
                    {
                        <div class="py-32 text-center text-slate-400/20 flex flex-col items-center gap-4">
                            <i class="fas @col.Icon text-5xl opacity-10"></i>
                            <p class="text-[9px] font-black uppercase tracking-widest opacity-30 italic">Chưa Có Ứng Viên</p>
                        </div>
                    }
                    
                    @foreach (var app in appsInColumn)
                    {
                        <div class="p-6 transition-all duration-300 group/card bg-white relative border border-slate-200 shadow-sm rounded-2xl overflow-hidden cursor-grab active:cursor-grabbing hover:translate-y-[-4px] hover:shadow-2xl hover:shadow-indigo-100/50">
                            <div class="mb-6">
                                <div class="flex justify-between items-start mb-2">
                                    <h4 class="font-black text-slate-900 text-lg group-hover/card:text-indigo-600 transition-colors truncate mb-1 pr-4">@app.CandidateName</h4>
                                    <span class="text-[10px] font-black tabular-nums @(app.MatchScore > 85 ? "text-green-600" : "text-indigo-500")">@(app.MatchScore.ToString("0"))%</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <div class="w-full h-1 bg-slate-100 rounded-full overflow-hidden">
                                        <div class="h-full @(app.MatchScore > 85 ? "bg-green-500" : "bg-indigo-400")" style="width: @app.MatchScore%"></div>
                                    </div>
                                </div>
                            </div>

                            <div class="flex gap-2">
                                <a href="/CandidatePreview/@app.Id" class="flex-1">
                                    <button class="text-[9px] font-black h-10 w-full rounded-xl bg-white border border-slate-200 text-slate-600 hover:border-indigo-500 hover:text-indigo-600 transition-all uppercase tracking-widest">
                                        Chi Tiết
                                    </button>
                                </a>

                                <div class="flex gap-2">
                                    <input type="hidden" name="applicationId" value="@app.Id" />
                                    <input type="hidden" name="jobId" value="@Model.Job?.Id" />
                                    @if (col.Status != ApplicationStatus.REJECTED)
                                    {
                                        <button type="button" onclick="openModal(@app.Id, @Model.Job?.Id, '@ApplicationStatus.REJECTED', 'REJECT')" class="h-10 w-11 p-0 rounded-xl flex-shrink-0 bg-red-50 text-red-600 border border-red-100 hover:bg-red-100 transition-colors ml-2 flex items-center justify-center">
                                            <i class="fas fa-times text-xs"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="Restore" class="flex">
                                            <input type="hidden" name="applicationId" value="@app.Id" />
                                            <input type="hidden" name="jobId" value="@Model.Job?.Id" />
                                            <button type="submit" class="h-10 px-4 text-[9px] rounded-xl bg-green-600 text-white font-bold border-0 hover:bg-green-700 ml-2 uppercase tracking-widest whitespace-nowrap">
                                                Khôi Phục
                                            </button>
                                        </form>
                                    }
                                </div>

                                @if (col.Status != ApplicationStatus.OFFERED && col.Status != ApplicationStatus.REJECTED)
                                {
                                    var possibleStatuses = new[] { ApplicationStatus.REVIEWING, ApplicationStatus.INTERVIEWING, ApplicationStatus.OFFERED };
                                    var idx = System.Array.IndexOf(possibleStatuses, col.Status);
                                    var nextStatus = possibleStatuses[idx + 1];
                                    
                                    if (nextStatus == ApplicationStatus.INTERVIEWING)
                                    {
                                        <button type="button" onclick="openModal(@app.Id, @Model.Job?.Id, '@nextStatus', 'INTERVIEW')" class="h-10 w-11 p-0 rounded-xl bg-indigo-600 text-white border-0 shadow-lg shadow-indigo-100 hover:bg-indigo-700 flex items-center justify-center ml-2">
                                            <i class="fas fa-arrow-right text-xs"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="UpdateStatus" class="flex">
                                            <input type="hidden" name="applicationId" value="@app.Id" />
                                            <input type="hidden" name="jobId" value="@Model.Job?.Id" />
                                            <input type="hidden" name="status" value="@nextStatus.ToString()" />
                                            <button type="submit" class="h-10 w-11 p-0 rounded-xl bg-indigo-600 text-white border-0 shadow-lg shadow-indigo-100 hover:bg-indigo-700 flex items-center justify-center ml-2">
                                                <i class="fas fa-arrow-right text-xs"></i>
                                            </button>
                                        </form>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        const modal = document.getElementById('statusModal');
        const modalAppId = document.getElementById('modalAppId');
        const modalJobId = document.getElementById('modalJobId');
        const modalStatus = document.getElementById('modalStatus');
        const dateField = document.getElementById('dateField');
        const reasonField = document.getElementById('reasonField');
        const modalIconContainer = document.getElementById('modalIconContainer');
        const modalIcon = document.getElementById('modalIcon');
        const modalTitle = document.getElementById('modalTitle');
        const modalDescription = document.getElementById('modalDescription');

        function openModal(appId, jobId, status, type) {
            modalAppId.value = appId;
            modalJobId.value = jobId;
            modalStatus.value = status;

            // Reset fields
            dateField.classList.add('hidden');
            reasonField.classList.add('hidden');

            if (type === 'INTERVIEW') {
                modalTitle.innerText = "Lên Lịch Phỏng Vấn";
                modalDescription.innerText = "Chọn ngày giờ cho đợt phỏng vấn của ứng viên.";
                modalIconContainer.className = "w-16 h-16 rounded-2xl flex items-center justify-center mb-6 shadow-lg bg-indigo-500 shadow-indigo-200";
                modalIcon.className = "fas fa-calendar-alt text-2xl text-white";
                dateField.classList.remove('hidden');

                // Set min date to current time
                const now = new Date();
                now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
                const minDateTime = now.toISOString().slice(0, 16);
                const dateInput = document.getElementById('interviewDateInput');
                dateInput.min = minDateTime;
                dateInput.value = minDateTime;
                document.getElementById('dateError').classList.add('hidden');
            } else if (type === 'REJECT') {
                modalTitle.innerText = "Từ Chối Ứng Viên";
                modalDescription.innerText = "Vui lòng cung cấp lý do ngắn gọn để từ chối ứng viên.";
                modalIconContainer.className = "w-16 h-16 rounded-2xl flex items-center justify-center mb-6 shadow-lg bg-red-500 shadow-red-200";
                modalIcon.className = "fas fa-user-times text-2xl text-white";
                reasonField.classList.remove('hidden');
            }

            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeModal() {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        // Close on backdrop click
        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeModal();
        });

        document.getElementById('modalForm').addEventListener('submit', function(e) {
            const status = modalStatus.value;
            if (status === 'INTERVIEWING') {
                const dateInput = document.getElementById('interviewDateInput');
                const selectedDate = new Date(dateInput.value);
                const now = new Date();
                
                if (selectedDate < now) {
                    e.preventDefault();
                    document.getElementById('dateError').classList.remove('hidden');
                    dateInput.classList.add('border-red-500');
                    return false;
                }
            }
        });
    </script>
}
