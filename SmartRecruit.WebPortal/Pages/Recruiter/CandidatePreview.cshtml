@page "/CandidatePreview/{id}"
@model WebPortal.Pages.CandidatePreviewModel
@using WebPortal.Models
@{
    ViewData["Title"] = "Review Application";
}

<div class="space-y-6">
    <div class="flex items-center gap-4 mb-8">
        <button onclick="history.back()" class="p-2 w-10 h-10 rounded-full bg-white border border-slate-200 hover:bg-slate-50 flex items-center justify-center transition text-slate-600 hover:text-indigo-600">
            <i class="fas fa-arrow-left"></i>
        </button>
        <h2 class="text-2xl font-bold text-slate-800">Review Application</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-6">
            <div class="p-8 bg-white border border-slate-200 rounded-3xl shadow-sm">
                <div class="flex gap-6 mb-8 border-b border-slate-100 pb-8">
                    <img src="https://i.pravatar.cc/150?u=@Model.Application.Id" class="w-24 h-24 rounded-2xl shadow-sm" alt="Avatar"/>
                    <div class="flex-1">
                        <div class="flex justify-between items-start">
                            <div>
                                <h3 class="text-2xl font-bold text-slate-800">@Model.Application.CandidateName</h3>
                                <p class="text-indigo-600 font-bold">@Model.Job.Title</p>
                            </div>
                            <div class="text-right">
                                <p class="text-xs text-slate-400 font-bold uppercase mb-1">Match Score</p>
                                <span class="text-3xl font-black text-indigo-600">@(Model.Application.MatchScore.ToString("0"))%</span>
                            </div>
                        </div>
                        <div class="flex gap-4 mt-4 text-sm text-slate-500">
                            <span><i class="fas fa-map-marker-alt text-slate-300 mr-2"></i>Ho Chi Minh, VN</span>
                            <span><i class="fas fa-envelope text-slate-300 mr-2"></i>@(Model.Application.CandidateName.ToLower().Replace(" ", "."))@($"@email.com")</span>
                        </div>
                    </div>
                </div>

                <section class="mb-8">
                    <h4 class="font-bold text-slate-800 mb-4">Extracted CV Summary</h4>
                    <div class="bg-slate-50 p-4 rounded-xl text-sm text-slate-600 leading-relaxed border border-slate-100 italic">
                        "Candidate has strong background in relevant skills with recent transition. Demonstrated leadership in agile teams. Missing: Kubernetes experience required by job posting."
                    </div>
                </section>

                <section>
                    <h4 class="font-bold text-slate-800 mb-4">Education & Experience</h4>
                    <div class="space-y-4">
                        <div class="flex gap-4">
                            <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 flex-shrink-0">
                                <i class="fas fa-briefcase"></i>
                            </div>
                            <div>
                                <p class="font-bold text-slate-800">Senior Dev @("TechCorp")</p>
                                <p class="text-sm text-slate-500">2019 - Present (5 years)</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-10 h-10 bg-indigo-100 rounded-full flex items-center justify-center text-indigo-600 flex-shrink-0">
                                <i class="fas fa-graduation-cap"></i>
                            </div>
                            <div>
                                <p class="font-bold text-slate-800">B.S. Computer Science @("HCMUT")</p>
                                <p class="text-sm text-slate-500">2014 - 2018</p>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        <div class="space-y-6">
            <div class="p-6 bg-white border border-slate-200 rounded-3xl shadow-sm">
                <h4 class="font-bold text-slate-800 mb-4">Pipeline Status</h4>
                <div class="space-y-3">
                    @{
                        var pipelineSteps = new[]
                        {
                            new { S = ApplicationStatus.REVIEWING, Icon = "fa-search" },
                            new { S = ApplicationStatus.INTERVIEWING, Icon = "fa-comments" },
                            new { S = ApplicationStatus.OFFERED, Icon = "fa-gift" },
                            new { S = ApplicationStatus.REJECTED, Icon = "fa-times-circle" }
                        };
                    }

                    @foreach (var step in pipelineSteps)
                    {
                        <form method="post" asp-page-handler="UpdateStatus" class="m-0">
                            <input type="hidden" name="id" value="@Model.Application.Id" />
                            <input type="hidden" name="status" value="@step.S.ToString()" />
                            <button type="submit" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl border transition-all @(Model.Application.Status == step.S ? "bg-indigo-600 border-indigo-600 text-white shadow-lg" : "bg-white border-slate-100 text-slate-600 hover:border-indigo-200")">
                                <i class="fas @step.Icon w-5"></i>
                                <span class="font-bold text-sm">@step.S</span>
                            </button>
                        </form>
                    }
                </div>
            </div>

            <div class="p-6 bg-slate-900 text-white rounded-3xl shadow-sm">
                <h4 class="font-bold mb-4 flex items-center gap-2">
                    <i class="fas fa-comment-dots text-indigo-400"></i>
                    Internal Notes
                </h4>
                <textarea class="w-full bg-slate-800 border-0 rounded-lg p-3 text-sm focus:ring-1 focus:ring-indigo-500 min-h-[100px] mb-4 text-white outline-none" placeholder="Add a private note for other HRs..."></textarea>
                <button class="w-full h-10 bg-indigo-500 hover:bg-indigo-600 font-bold rounded-xl transition">Save Note</button>
            </div>
        </div>
    </div>
</div>
