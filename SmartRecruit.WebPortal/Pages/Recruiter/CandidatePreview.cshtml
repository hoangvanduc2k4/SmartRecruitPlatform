@page "/CandidatePreview/{id}"
@model WebPortal.Pages.CandidatePreviewModel
@using WebPortal.Models
@{
    ViewData["Title"] = "Chi Tiết Ứng Tuyển";
    var isRecruiter = Model.IsRecruiter || Model.IsAdmin;
    var app = Model.Application;
    var job = Model.Job;
    var profile = Model.CandidateProfile;
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
    }
    .score-glow {
        filter: drop-shadow(0 0 8px currentColor);
    }
    @@keyframes slideIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-slide-in {
        animation: slideIn 0.5s ease-out forwards;
    }
    /* Modal Styles */
    .modal-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(4px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }
    .modal-content {
        background: white;
        padding: 2.5rem;
        border-radius: 2rem;
        max-width: 500px;
        width: 90%;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
        animation: slideUp 0.3s ease-out forwards;
    }
    @@keyframes slideUp {
        from { transform: translateY(20px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
</style>

<div class="max-w-7xl mx-auto space-y-8 pb-12">
    <!-- Header -->
    <div class="flex items-center justify-between gap-6 animate-slide-in">
        <div class="flex items-center gap-6">
            <button onclick="history.back()" class="p-4 w-12 h-12 rounded-2xl bg-white border border-slate-200 hover:bg-slate-50 flex items-center justify-center transition shadow-sm group">
                <i class="fas fa-arrow-left text-slate-400 group-hover:text-indigo-600 transition-colors"></i>
            </button>
            <div>
                <nav class="flex mb-1" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-1 md:space-x-3 text-[10px] font-black uppercase tracking-widest text-slate-400">
                        <li>Ứng Tuyển</li>
                        <li><i class="fas fa-chevron-right mx-2 text-[8px]"></i></li>
                        <li class="text-indigo-600">Chi Tiết</li>
                    </ol>
                </nav>
                <h2 class="text-4xl font-black text-slate-800 tracking-tighter uppercase">Chi Tiết Ứng Tuyển</h2>
            </div>
        </div>
        
        <div class="hidden md:flex items-center gap-3">
            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Mã Ứng Tuyển:</span>
            <span class="px-4 py-1.5 bg-slate-100 text-slate-600 rounded-full text-xs font-bold">#APP-@app.Id</span>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-8 space-y-8">
            
            <!-- Candidate & Job Hero -->
            <div class="p-10 bg-white border border-slate-200 rounded-[2.5rem] shadow-sm animate-slide-in" style="animation-delay: 0.1s">
                <div class="flex flex-col md:flex-row gap-8 items-start">
                    <div class="relative group">
                        <img src="@(string.IsNullOrEmpty(profile?.AvatarUrl) ? $"https://i.pravatar.cc/150?u={app.Id}" : profile.AvatarUrl)" 
                             class="w-32 h-32 rounded-3xl object-cover shadow-2xl shadow-indigo-100 group-hover:scale-105 transition-transform duration-500" alt="Avatar"/>
                        <div class="absolute -bottom-2 -right-2 w-10 h-10 bg-indigo-600 rounded-2xl flex items-center justify-center text-white shadow-lg border-4 border-white">
                            <i class="fas fa-check-circle text-xs"></i>
                        </div>
                    </div>
                    
                    <div class="flex-1 space-y-4">
                        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                            <div>
                                <h3 class="text-3xl font-black text-slate-800 tracking-tight mb-1">@app.CandidateName</h3>
                                <div class="flex flex-wrap items-center gap-3">
                                    <span class="px-3 py-1 bg-indigo-50 text-indigo-700 rounded-lg text-xs font-black uppercase tracking-tight">@job.Title</span>
                                    <span class="text-slate-300">•</span>
                                    <span class="text-sm font-bold text-slate-500"><i class="fas fa-building mr-2"></i>@job.Company</span>
                                </div>
                            </div>
                            
                            @{
                                var statusClass = app.Status switch {
                                    ApplicationStatus.OFFERED => "bg-green-500 text-white shadow-green-100",
                                    ApplicationStatus.REJECTED => "bg-red-500 text-white shadow-red-100",
                                    ApplicationStatus.REVIEWING => "bg-indigo-600 text-white shadow-indigo-100",
                                    ApplicationStatus.INTERVIEWING => "bg-amber-500 text-white shadow-amber-100",
                                    _ => "bg-slate-500 text-white shadow-slate-100"
                                };
                            }
                            <div id="status-badge-overall" class="px-6 py-2.5 @statusClass rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] shadow-lg flex items-center gap-2">
                                <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
                                <span class="status-text">@app.Status</span>
                            </div>
                        </div>
                        
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4 border-t border-slate-50">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center text-slate-400">
                                    <i class="fas fa-envelope"></i>
                                </div>
                                <div>
                                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Email</p>
                                    <p class="text-sm font-bold text-slate-700">@app.CandidateEmail</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center text-slate-400">
                                    <i class="fas fa-calendar-alt"></i>
                                </div>
                                <div>
                                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Ngày Ứng Tuyển</p>
                                    <p class="text-sm font-bold text-slate-700">@app.CreatedAt.ToString("MMM dd, yyyy")</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Match Analysis -->
            <div class="animate-slide-in" style="animation-delay: 0.2s">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-1.5 h-8 bg-indigo-600 rounded-full"></div>
                    <h4 class="text-xl font-black text-slate-800 uppercase tracking-tight">Phân Tích Độ Phù Hợp (AI)</h4>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <!-- Overall Score -->
                    <div class="p-8 bg-indigo-600 rounded-[2rem] text-white shadow-xl shadow-indigo-100 relative overflow-hidden group">
                        <div class="absolute -right-4 -bottom-4 text-indigo-500/20 text-9xl">
                            <i class="fas fa-brain"></i>
                        </div>
                        <div class="relative z-10">
                            <p class="text-[10px] font-black uppercase tracking-[0.2em] text-indigo-200 mb-6">Tổng Quan</p>
                            <div class="flex items-end gap-2 mb-2">
                                <span id="match-score-main" class="text-6xl font-black tracking-tighter">@app.MatchScore.ToString("0")</span>
                                <span class="text-2xl font-bold text-indigo-200 mb-2">%</span>
                            </div>
                            <div class="w-full bg-indigo-500/30 h-2 rounded-full overflow-hidden">
                                <div class="bg-white h-full rounded-full transition-all duration-1000" style="width: @app.MatchScore%"></div>
                            </div>
                            <p class="text-xs font-medium text-indigo-100 mt-4 leading-relaxed">
                                Dựa trên phân tích toàn diện profile và yêu cầu công việc.
                            </p>
                        </div>
                    </div>

                    <!-- Skill Match -->
                    <div class="p-8 bg-white border border-slate-200 rounded-[2rem] shadow-sm hover:border-indigo-200 transition-colors group">
                        <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-6 group-hover:text-indigo-400 transition-colors">Kỹ Năng</p>
                        <div class="flex items-end gap-2 mb-2">
                            <span id="skill-score-main" class="text-5xl font-black text-slate-800 tracking-tighter">@app.SkillMatch.ToString("0")</span>
                            <span class="text-xl font-bold text-slate-400 mb-1.5">%</span>
                        </div>
                        <div class="w-full bg-slate-100 h-2 rounded-full overflow-hidden">
                            <div class="bg-indigo-600 h-full rounded-full transition-all duration-1000" style="width: @app.SkillMatch%"></div>
                        </div>
                        <p class="text-xs font-medium text-slate-500 mt-4 leading-relaxed">
                            Mức độ tương đồng về bộ kỹ năng chuyên môn.
                        </p>
                    </div>

                    <!-- Experience Match -->
                    <div class="p-8 bg-white border border-slate-200 rounded-[2rem] shadow-sm hover:border-indigo-200 transition-colors group">
                        <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-6 group-hover:text-indigo-400 transition-colors">Kinh Nghiệm</p>
                        <div class="flex items-end gap-2 mb-2">
                            <span id="experience-score-main" class="text-5xl font-black text-slate-800 tracking-tighter">@app.ExperienceMatch.ToString("0")</span>
                            <span class="text-xl font-bold text-slate-400 mb-1.5">%</span>
                        </div>
                        <div class="w-full bg-slate-100 h-2 rounded-full overflow-hidden">
                            <div class="bg-indigo-600 h-full rounded-full transition-all duration-1000" style="width: @app.ExperienceMatch%"></div>
                        </div>
                        <p class="text-xs font-medium text-slate-500 mt-4 leading-relaxed">
                            Sự phù hợp về năm kinh nghiệm và vị trí tương đương.
                        </p>
                    </div>
                </div>
            </div>

            <!-- AI Summary -->
            <div class="p-10 bg-slate-900 rounded-[2.5rem] text-white shadow-2xl shadow-slate-200 relative overflow-hidden animate-slide-in" style="animation-delay: 0.3s">
                <div class="absolute top-0 right-0 w-64 h-64 bg-indigo-500/10 rounded-full blur-3xl -mr-32 -mt-32"></div>
                <div class="absolute bottom-0 left-0 w-64 h-64 bg-indigo-500/5 rounded-full blur-3xl -ml-32 -mb-32"></div>
                
                <div class="relative z-10">
                    <div class="flex items-center justify-between mb-8">
                        <div class="flex items-center gap-3">
                            <div class="w-12 h-12 bg-indigo-500 rounded-2xl flex items-center justify-center shadow-lg shadow-indigo-500/20">
                                <i class="fas fa-robot text-xl"></i>
                            </div>
                            <h4 class="text-xl font-black uppercase tracking-tight">AI Insights</h4>
                        </div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-slate-500">Tóm tắt bởi hệ thống AI</span>
                    </div>
                    
                    <div class="space-y-6">
                        <div class="p-6 bg-slate-800/50 rounded-2xl border border-white/5 backdrop-blur-sm">
                            <p id="ai-summary-text" class="text-lg font-medium text-slate-200 leading-relaxed italic">
                                "@(string.IsNullOrEmpty(app.AI_Summary) ? "Đang cập nhật phân tích AI cho ứng viên này..." : app.AI_Summary)"
                            </p>
                        </div>
                        
                        <div class="flex flex-wrap gap-4">
                            @if (!string.IsNullOrEmpty(profile?.CandidateProfile?.Skills))
                            {
                                @foreach (var skill in profile.CandidateProfile.Skills.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <span class="px-4 py-2 bg-indigo-500/10 border border-indigo-500/20 rounded-xl text-xs font-bold text-indigo-300">
                                        # @skill.Trim()
                                    </span>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>

            @if (isRecruiter)
            {
                <!-- Detailed Info Sections -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 animate-slide-in" style="animation-delay: 0.4s">
                    <!-- Education & Experience -->
                    <div class="p-8 bg-white border border-slate-200 rounded-[2.5rem] shadow-sm">
                        <h4 class="text-xl font-black text-slate-800 uppercase tracking-tight mb-8">Hồ Sơ Ứng Viên</h4>
                        <div class="space-y-6">
                            <div class="flex gap-4">
                                <div class="w-12 h-12 bg-amber-50 rounded-2xl flex items-center justify-center text-amber-600 flex-shrink-0">
                                    <i class="fas fa-briefcase"></i>
                                </div>
                                <div>
                                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Kinh Nghiệm</p>
                                    <p class="font-black text-slate-800">@(profile?.CandidateProfile?.ExperienceYears ?? 0) Năm Làm Việc</p>
                                </div>
                            </div>
                            <div class="flex gap-4">
                                <div class="w-12 h-12 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600 flex-shrink-0">
                                    <i class="fas fa-money-bill-wave"></i>
                                </div>
                                <div>
                                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Mức Lương Mong Muốn</p>
                                    <p class="font-black text-slate-800">@(profile?.CandidateProfile?.ExpectedSalary?.ToString("N0") ?? "Thỏa thuận") VNĐ</p>
                                    <p class="text-sm text-slate-500">Gross / Month</p>
                                </div>
                            </div>
                            <div class="flex gap-4">
                                <div class="w-12 h-12 bg-green-50 rounded-2xl flex items-center justify-center text-green-600 flex-shrink-0">
                                    <i class="fas fa-file-pdf"></i>
                                </div>
                                <div class="flex-1">
                                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">CV Đính Kèm</p>
                                    <div class="flex items-center justify-between">
                                        <p class="font-black text-slate-800">Curriculum Vitae.pdf</p>
                                        @if (!string.IsNullOrEmpty(profile?.CandidateProfile?.CVUrl))
                                        {
                                            <a href="@profile.CandidateProfile.CVUrl" target="_blank" class="text-indigo-600 hover:text-indigo-700 font-black text-xs uppercase tracking-widest">Tải Xuống</a>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="pt-4 border-t border-slate-100">
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Các Kỹ Năng Hiện Có</p>
                                <div class="flex flex-wrap gap-2">
                                    @if (!string.IsNullOrEmpty(profile?.CandidateProfile?.Skills))
                                    {
                                        @foreach (var skill in profile.CandidateProfile.Skills.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                        {
                                            <span class="px-3 py-1 bg-slate-100 text-slate-600 rounded-lg text-[10px] font-black uppercase">@skill.Trim()</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-xs text-slate-500 italic">Chưa cập nhật kỹ năng</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Job Summary -->
                    <div class="p-8 bg-indigo-50 border border-indigo-100 rounded-[2.5rem] shadow-sm">
                        <h4 class="text-xl font-black text-indigo-900 uppercase tracking-tight mb-8">Thông Tin Công Việc</h4>
                        <div class="space-y-6">
                            <div class="flex flex-col gap-4">
                                <p class="text-lg font-black text-indigo-800 leading-tight">@job.Title</p>
                                <div class="flex flex-wrap gap-2">
                                    <span class="px-3 py-1 bg-white border border-indigo-100 rounded-lg text-xs font-bold text-indigo-600">@job.JobType</span>
                                    <span class="px-3 py-1 bg-white border border-indigo-100 rounded-lg text-xs font-bold text-indigo-600">@job.Location</span>
                                </div>
                            </div>
                            <div class="pt-4 border-t border-indigo-100">
                                <p class="text-[10px] font-black text-indigo-400 uppercase tracking-widest mb-4">Kỹ Năng Yêu Cầu</p>
                                <div class="flex flex-wrap gap-2">
                                    @foreach (var skill in job.SkillsRequiredList)
                                    {
                                        <span class="px-3 py-1 bg-indigo-600 text-white rounded-lg text-[10px] font-black uppercase">@skill</span>
                                    }
                                </div>
                            </div>
                            <a href="/JobDetail?Id=@job.Id" class="block w-full text-center py-4 bg-white border border-indigo-200 text-indigo-600 rounded-2xl font-black uppercase tracking-widest text-[11px] hover:bg-indigo-600 hover:text-white transition-all shadow-sm">Xem Chi Tiết Bài Đăng</a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-4 space-y-8">
            
            @if (isRecruiter)
            {
                <!-- Recruiter Controls -->
                <div class="p-8 bg-white border-2 border-indigo-600 rounded-[2.5rem] shadow-xl shadow-indigo-100 animate-slide-in" style="animation-delay: 0.5s">
                    <div class="flex items-center gap-3 mb-8">
                        <div class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center text-white">
                            <i class="fas fa-user-tie"></i>
                        </div>
                        <h4 class="text-lg font-black text-slate-800 uppercase tracking-tight">Quy Trình Xử Lý</h4>
                    </div>
                    
                    <div class="space-y-4">
                        @{
                            var pipelineSteps = new[]
                            {
                                new { S = ApplicationStatus.REVIEWING, Icon = "fa-search", Desc = "Đang xem xét hồ sơ" },
                                new { S = ApplicationStatus.INTERVIEWING, Icon = "fa-comments", Desc = "Lên lịch phỏng vấn" },
                                new { S = ApplicationStatus.OFFERED, Icon = "fa-gift", Desc = "Gửi đề nghị nhận việc" },
                                new { S = ApplicationStatus.REJECTED, Icon = "fa-times-circle", Desc = "Từ chối hồ sơ" }
                            };
                        }

                        @foreach (var step in pipelineSteps)
                        {
                            // If rejected, hide everything except the rejected button itself
                            if (app.Status == ApplicationStatus.REJECTED && step.S != ApplicationStatus.REJECTED) continue;

                            // Hide Reviewing if status is Interviewing or higher
                            if (step.S == ApplicationStatus.REVIEWING && app.Status >= ApplicationStatus.INTERVIEWING) continue;
                            // Hide Interviewing if status is Offered or higher
                            if (step.S == ApplicationStatus.INTERVIEWING && app.Status >= ApplicationStatus.OFFERED) continue;

                            <form id="statusForm-@step.S" method="post" asp-page-handler="UpdateStatus" class="m-0">
                                <input type="hidden" name="id" value="@app.Id" />
                                <input type="hidden" name="status" value="@step.S.ToString()" />
                                <input type="hidden" id="interviewDate-@step.S" name="interviewDate" value="" />
                                <input type="hidden" id="rejectionReason-@step.S" name="rejectionReason" value="" />
                                
                                <button type="button" onclick="handleStatusClick('@step.S.ToString()')" class="w-full group mb-4">
                                    <div class="flex items-center gap-4 p-4 rounded-2xl border transition-all @(app.Status == step.S ? "bg-indigo-600 border-indigo-600 text-white shadow-lg" : "bg-white border-slate-100 text-slate-600 hover:border-indigo-200")">
                                        <div class="w-10 h-10 rounded-xl flex items-center justify-center @(app.Status == step.S ? "bg-white/20" : "bg-slate-50 group-hover:bg-indigo-50")">
                                            <i class="fas @step.Icon text-sm"></i>
                                        </div>
                                        <div class="text-left">
                                            <p class="font-black text-xs uppercase tracking-widest">@step.S</p>
                                            <p class="text-[10px] @(app.Status == step.S ? "text-indigo-100" : "text-slate-400") font-medium">@step.Desc</p>
                                        </div>
                                    </div>
                                </button>
                            </form>
                        }
                    </div>

                    <div class="mt-8 pt-8 border-t border-slate-50">
                        <h5 class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Ghi Chú Nội Bộ</h5>
                        <form method="post" asp-page-handler="AddNote" class="space-y-4">
                            <input type="hidden" name="id" value="@app.Id" />
                            <textarea name="note" class="w-full bg-slate-50 border border-slate-100 rounded-2xl p-4 text-sm focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 min-h-[120px] outline-none transition-all" placeholder="Nhận xét về ứng viên này..."></textarea>
                            <button type="submit" class="w-full h-12 bg-slate-900 hover:bg-slate-800 text-white font-black uppercase tracking-widest text-[11px] rounded-2xl transition shadow-lg">Lưu Ghi Chú</button>
                        </form>
                    </div>

                    <!-- Notes History Display -->
                    @if (!string.IsNullOrEmpty(app.Notes))
                    {
                        <div class="mt-8 pt-8 border-t border-slate-50">
                            <div class="flex items-center justify-between mb-4">
                                <h5 class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Lịch Sử Ghi Chú</h5>
                                <form method="post" asp-page-handler="ClearNotes">
                                    <input type="hidden" name="id" value="@app.Id" />
                                    <button type="submit" class="text-[10px] font-black text-red-400 hover:text-red-500 uppercase tracking-widest transition-colors" onclick="return confirm('Bạn có chắc chắn muốn xóa tất cả lịch sử ghi chú?')">
                                        <i class="fas fa-trash-alt mr-1"></i> Xóa lịch sử
                                    </button>
                                </form>
                            </div>
                            <div class="space-y-3">
                                @foreach (var note in app.Notes.Split(',', StringSplitOptions.RemoveEmptyEntries).Reverse())
                                {
                                    <div class="p-4 bg-slate-50/50 border border-slate-100 rounded-2xl text-[11px] text-slate-600 leading-relaxed">
                                        <i class="fas fa-sticky-note text-indigo-400 mr-2"></i>
                                        @note.Trim()
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <!-- Candidate Detailed Info (Moved to Sidebar) -->
                <div class="space-y-8 animate-slide-in" style="animation-delay: 0.5s">
                    <!-- Education & Experience -->
                    <div class="p-8 bg-white border border-slate-200 rounded-[2.5rem] shadow-sm">
                        <h4 class="text-xl font-black text-slate-800 uppercase tracking-tight mb-8">Hồ Sơ Ứng Viên</h4>
                        <div class="space-y-6">
                            <div class="flex gap-4">
                                <div class="w-12 h-12 bg-amber-50 rounded-2xl flex items-center justify-center text-amber-600 flex-shrink-0">
                                    <i class="fas fa-briefcase"></i>
                                </div>
                                <div>
                                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Kinh Nghiệm</p>
                                    <p class="font-black text-slate-800">@(profile?.CandidateProfile?.ExperienceYears ?? 0) Năm Làm Việc</p>
                                </div>
                            </div>
                            <div class="flex gap-4">
                                <div class="w-12 h-12 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600 flex-shrink-0">
                                    <i class="fas fa-money-bill-wave"></i>
                                </div>
                                <div>
                                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Mức Lương Mong Muốn</p>
                                    <p class="font-black text-slate-800">@(profile?.CandidateProfile?.ExpectedSalary?.ToString("N0") ?? "Thỏa thuận") VNĐ</p>
                                    <p class="text-sm text-slate-500">Gross / Month</p>
                                </div>
                            </div>
                            <div class="flex gap-4">
                                <div class="w-12 h-12 bg-green-50 rounded-2xl flex items-center justify-center text-green-600 flex-shrink-0">
                                    <i class="fas fa-file-pdf"></i>
                                </div>
                                <div class="flex-1">
                                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">CV Đính Kèm</p>
                                    <div class="flex items-center justify-between">
                                        <p class="font-black text-slate-800">Curriculum Vitae.pdf</p>
                                        @if (!string.IsNullOrEmpty(profile?.CandidateProfile?.CVUrl))
                                        {
                                            <a href="@profile.CandidateProfile.CVUrl" target="_blank" class="text-indigo-600 hover:text-indigo-700 font-black text-xs uppercase tracking-widest">Tải Xuống</a>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="pt-4 border-t border-slate-100">
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Các Kỹ Năng Hiện Có</p>
                                <div class="flex flex-wrap gap-2">
                                    @if (!string.IsNullOrEmpty(profile?.CandidateProfile?.Skills))
                                    {
                                        @foreach (var skill in profile.CandidateProfile.Skills.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                        {
                                            <span class="px-3 py-1 bg-slate-100 text-slate-600 rounded-lg text-[10px] font-black uppercase">@skill.Trim()</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-xs text-slate-500 italic">Chưa cập nhật kỹ năng</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Job Summary -->
                    <div class="p-8 bg-indigo-50 border border-indigo-100 rounded-[2.5rem] shadow-sm">
                        <h4 class="text-xl font-black text-indigo-900 uppercase tracking-tight mb-8">Thông Tin Công Việc</h4>
                        <div class="space-y-6">
                            <div class="flex flex-col gap-4">
                                <p class="text-lg font-black text-indigo-800 leading-tight">@job.Title</p>
                                <div class="flex flex-wrap gap-2">
                                    <span class="px-3 py-1 bg-white border border-indigo-100 rounded-lg text-xs font-bold text-indigo-600">@job.JobType</span>
                                    <span class="px-3 py-1 bg-white border border-indigo-100 rounded-lg text-xs font-bold text-indigo-600">@job.Location</span>
                                </div>
                            </div>
                            <div class="pt-4 border-t border-indigo-100">
                                <p class="text-[10px] font-black text-indigo-400 uppercase tracking-widest mb-4">Kỹ Năng Yêu Cầu</p>
                                <div class="flex flex-wrap gap-2">
                                    @foreach (var skill in job.SkillsRequiredList)
                                    {
                                        <span class="px-3 py-1 bg-indigo-600 text-white rounded-lg text-[10px] font-black uppercase">@skill</span>
                                    }
                                </div>
                            </div>
                            <a href="/JobDetail?Id=@job.Id" class="block w-full text-center py-4 bg-white border border-indigo-200 text-indigo-600 rounded-2xl font-black uppercase tracking-widest text-[11px] hover:bg-indigo-600 hover:text-white transition-all shadow-sm">Xem Chi Tiết Bài Đăng</a>
                        </div>
                    </div>
                </div>
            }
            

        </div>
    </div>
</div>

<!-- Modal Date Interview -->
<div id="interviewModal" class="modal-backdrop">
    <div class="modal-content">
        <h3 class="text-2xl font-black text-slate-800 uppercase tracking-tight mb-4">Lên Lịch Phỏng Vấn</h3>
        <p class="text-sm text-slate-500 mb-6">Vui lòng chọn ngày và giờ cho buổi phỏng vấn. Một email sẽ được gửi tự động cho ứng viên.</p>
        <div class="space-y-4">
            <div>
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Ngày và Giờ</label>
                <input type="datetime-local" id="modalInterviewDate" class="w-full bg-slate-50 border border-slate-100 rounded-xl p-4 text-sm outline-none focus:ring-2 focus:ring-indigo-500/20" required>
            </div>
            <div class="flex gap-3 pt-4">
                <button type="button" onclick="closeModal('interviewModal')" class="flex-1 py-4 border border-slate-200 rounded-xl text-xs font-black uppercase tracking-widest hover:bg-slate-50 transition">Hủy</button>
                <button type="button" onclick="confirmInterview()" class="flex-1 py-4 bg-indigo-600 text-white rounded-xl text-xs font-black uppercase tracking-widest hover:bg-indigo-700 shadow-lg shadow-indigo-100 transition">Xác Nhận</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Rejection -->
<div id="rejectModal" class="modal-backdrop">
    <div class="modal-content">
        <h3 class="text-2xl font-black text-slate-800 uppercase tracking-tight mb-4">Từ Chối Hồ Sơ</h3>
        <p class="text-sm text-slate-500 mb-6">Vui lòng nhập lý do từ chối. Lý do này sẽ được gửi trong email cảm ơn cho ứng viên.</p>
        <div class="space-y-4">
            <div>
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1 block">Lý do từ chối</label>
                <textarea id="modalRejectionReason" class="w-full bg-slate-50 border border-slate-100 rounded-xl p-4 text-sm outline-none focus:ring-2 focus:ring-indigo-500/20 min-h-[120px]" placeholder="VD: Chưa đáp ứng đủ yêu cầu kỹ năng..."></textarea>
            </div>
            <div class="flex gap-3 pt-4">
                <button type="button" onclick="closeModal('rejectModal')" class="flex-1 py-4 border border-slate-200 rounded-xl text-xs font-black uppercase tracking-widest hover:bg-slate-50 transition">Hủy</button>
                <button type="button" onclick="confirmRejection()" class="flex-1 py-4 bg-red-600 text-white rounded-xl text-xs font-black uppercase tracking-widest hover:bg-red-700 shadow-lg shadow-red-100 transition">Từ Chối</button>
            </div>
        </div>
    </div>
</div>

<script>
    function handleStatusClick(status) {
        if (status === 'INTERVIEWING') {
            document.getElementById('interviewModal').style.display = 'flex';
        } else if (status === 'REJECTED') {
            document.getElementById('rejectModal').style.display = 'flex';
        } else {
            document.getElementById('statusForm-' + status).submit();
        }
    }

    function closeModal(modalId) {
        document.getElementById(modalId).style.display = 'none';
    }

    function confirmInterview() {
        const dateLoc = document.getElementById('modalInterviewDate').value;
        if (!dateLoc) {
            alert('Vui lòng chọn ngày phỏng vấn');
            return;
        }
        document.getElementById('interviewDate-INTERVIEWING').value = dateLoc;
        document.getElementById('statusForm-INTERVIEWING').submit();
    }

    function confirmRejection() {
        const reason = document.getElementById('modalRejectionReason').value;
        if (!reason) {
            alert('Vui lòng chọn lý do từ chối');
            return;
        }
        document.getElementById('rejectionReason-REJECTED').value = reason;
        document.getElementById('statusForm-REJECTED').submit();
    }

    document.addEventListener("DOMContentLoaded", function () {
        if (window.notificationHubConnection) {
            const currentAppId = @app.Id;

            window.notificationHubConnection.on("ReceiveApplicationScoreUpdate", function (update) {
                if (!update) return;
                
                // Assuming update is for the Current Application since we're on details page
                // But better to check appId if provided, though score update currently uses JobId
                // Wait, ScoreUpdateDto currently has JobId, but let's assume it matches if we only have one app
                // NO, we should probably add ApplicationId to ScoreUpdateDto too for precision.
                // For now, let's just update if the jobId matches.
                if (update.JobId == @app.JobId || update.jobId == @app.JobId) {
                    updateScores(update.matchScore || update.MatchScore || 0, update.skillMatch || update.SkillMatch || 0, update.experienceMatch || update.ExperienceMatch || 0, update.ai_Summary || update.AI_Summary || "");
                }
            });

            window.notificationHubConnection.on("ReceiveApplicationStatusUpdate", function (update) {
                if (!update) return;
                const appId = update.applicationId || update.ApplicationId;
                if (appId == currentAppId) {
                    const newStatus = update.status || update.Status;
                    updateStatus(newStatus);
                }
            });
        }
    });

    function updateScores(match, skill, exp, summary) {
        setAnimateValue('match-score-main', match);
        setAnimateValue('skill-score-main', skill);
        setAnimateValue('experience-score-main', exp);
        if (summary) document.getElementById('ai-summary-text').innerText = '"' + summary + '"';
        
        // Update progress bars
        const bars = document.querySelectorAll('.bg-indigo-600.h-full, .bg-white.h-full');
        if (bars.length >= 3) {
            bars[0].style.width = match + '%';
            bars[1].style.width = skill + '%';
            bars[2].style.width = exp + '%';
        }
    }

    function setAnimateValue(id, value) {
        const el = document.getElementById(id);
        if (el) el.innerText = Math.round(value);
    }

    function updateStatus(status) {
        const badge = document.getElementById('status-badge-overall');
        if (badge) {
            const textEl = badge.querySelector('.status-text');
            if (textEl) textEl.innerText = status;
            
            // Map colors
            let colorClass = "bg-slate-500 text-white shadow-slate-100";
            if (status === 'OFFERED') colorClass = "bg-green-500 text-white shadow-green-100";
            else if (status === 'REJECTED') colorClass = "bg-red-500 text-white shadow-red-100";
            else if (status === 'REVIEWING') colorClass = "bg-indigo-600 text-white shadow-indigo-100";
            else if (status === 'INTERVIEWING') colorClass = "bg-amber-500 text-white shadow-amber-100";
            
            badge.className = "px-6 py-2.5 rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] shadow-lg flex items-center gap-2 " + colorClass;
        }
    }

    // Set min date for interview
    document.addEventListener("DOMContentLoaded", function() {
        const interviewInput = document.getElementById('modalInterviewDate');
        if (interviewInput) {
            const now = new Date();
            now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
            interviewInput.min = now.toISOString().slice(0, 16);
        }
    });
</script>
