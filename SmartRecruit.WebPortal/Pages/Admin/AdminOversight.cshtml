
@page "/AdminOversight"
@model WebPortal.Pages.AdminOversightModel
@{
    ViewData["Title"] = "Giám Sát Hệ Thống";
}

<div class="space-y-12 animate-in fade-in duration-700 pb-20">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div class="space-y-2">
            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-indigo-50 border border-indigo-100 text-indigo-700 shadow-sm">Kiểm Toán AI</span>
            <h2 class="text-5xl font-black text-slate-900 tracking-tighter uppercase">Giám Sát AI</h2>
            <p class="text-slate-500 font-medium">Theo dõi các quyết định và nhật ký hoạt động của trí tuệ nhân tạo trong hệ thống.</p>
        </div>

        <div class="flex items-center gap-4 bg-white px-5 py-2.5 rounded-2xl border border-slate-200 shadow-sm transition-all hover:border-indigo-200 group">
            <span class="text-[10px] font-black uppercase tracking-widest text-slate-400 group-hover:text-indigo-400">Dòng hiển thị:</span>
            <select onchange="window.location.href='?page=1&pageSize=' + this.value" 
                    class="bg-transparent border-none text-xs font-black text-slate-700 focus:ring-0 cursor-pointer uppercase tracking-wider pr-8">
                <option value="5" selected="@(Model.PageSize == 5)">5 dòng</option>
                <option value="10" selected="@(Model.PageSize == 10)">10 dòng</option>
                <option value="12" selected="@(Model.PageSize == 12)">12 dòng</option>
                <option value="20" selected="@(Model.PageSize == 15)">15 dòng</option>
                <option value="50" selected="@(Model.PageSize == 20)">20 dòng</option>
            </select>
        </div>
    </div>

    <div class="overflow-hidden border border-slate-200/60 bg-white rounded-[3rem] animate-in slide-in-from-bottom-5 shadow-sm">
        <table class="w-full text-left">
            <thead class="bg-slate-50/50 border-b border-slate-100">
                <tr>
                    <th class="px-10 py-8 text-[10px] font-black text-slate-400 uppercase tracking-widest">ID / Công Việc</th>
                    <th class="px-8 py-8 text-[10px] font-black text-slate-400 uppercase tracking-widest">Quyết Định & Lý Do</th>
                    <th class="px-8 py-8 text-[10px] font-black text-slate-400 uppercase tracking-widest">Dữ Liệu Đầu Vào</th>
                    <th class="px-10 py-8 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Thời Gian</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
                @if (Model.AILogs != null && Model.AILogs.Data != null && Model.AILogs.Data.Any())
                {
                    foreach (var log in Model.AILogs.Data)
                    {
                        <tr class="hover:bg-slate-50 transition-all group">
                            <td class="px-10 py-8">
                                <p class="font-black text-slate-900 text-sm">#@log.Id</p>
                                <p class="text-[10px] font-bold text-indigo-600 uppercase tracking-widest mt-1">Mã Bài Đăng: @log.JobId</p>
                            </td>
                            <td class="px-8 py-8">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-black tracking-widest uppercase @(log.Decision == "BLOCK" ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800") mb-2">
                                    @(log.Decision == "BLOCK" ? "CHẶN" : (log.Decision == "ALLOW" ? "CHO PHÉP" : log.Decision))
                                </span>
                                <p class="text-sm font-medium text-slate-700">@log.Reason</p>
                            </td>
                            <td class="px-8 py-8">
                                <p class="text-[10px] text-slate-500 font-medium italic line-clamp-2" title="@log.InputText">"@log.InputText"</p>
                            </td>
                            <td class="px-10 py-8 text-right text-[10px] font-black text-slate-400 uppercase">@log.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="px-10 py-32 text-center text-slate-300 font-black uppercase tracking-widest">Chưa có nhật ký AI nào</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="flex flex-col md:flex-row justify-center items-center mt-12 gap-6 bg-slate-50/50 p-6 rounded-[2rem] border border-slate-100">

        @if (Model.AILogs != null && Model.AILogs.TotalPages > 1)
        {
            <div class="flex justify-center">
                 <partial name="_Pagination" model='(Model.AILogs.Page, Model.AILogs.TotalPages, $"?page={{0}}&pageSize={Model.PageSize}")' />
            </div>
        }
    </div>
</div>
