@page "/AdminUsers"
@model WebPortal.Pages.AdminUsersModel
@using WebPortal.Models
@{
    ViewData["Title"] = "User Management Terminal";
    
    // Data is now loaded from PageModel
}

<div class="space-y-12 animate-in fade-in duration-700 pb-20">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div class="space-y-2">
            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-red-50 border border-red-100 text-red-700 shadow-sm">Identity Protocol</span>
            <h2 class="text-5xl font-black text-slate-900 tracking-tighter uppercase">User Management Terminal</h2>
            <p class="text-slate-500 font-medium">Monitoring and managing @Model.TotalUsers authenticated identities.</p>
        </div>
        <div class="relative w-full md:w-96 group">
            <form method="get" class="m-0">
                <i class="fas fa-search absolute left-5 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-indigo-600 transition-colors"></i>
                <input type="text" name="SearchTerm" value="@Model.SearchTerm" placeholder="Search Identity or Email..." onchange="this.form.submit()" class="w-full h-14 pl-12 pr-6 bg-white border border-slate-200 rounded-[1.5rem] focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 outline-none font-medium transition-all shadow-sm" />
            </form>
        </div>
    </div>

    <div class="overflow-hidden border border-slate-200/60 shadow-2xl shadow-slate-200/20 bg-white rounded-[3rem]">
        <table class="w-full text-left">
            <thead class="bg-slate-50/50 border-b border-slate-100">
                <tr>
                    <th class="px-10 py-8 text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">Identity Details</th>
                    <th class="px-8 py-8 text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">Sector Role</th>
                    <th class="px-8 py-8 text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">System Status</th>
                    <th class="px-8 py-8 text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">Created At</th>
                    <th class="px-10 py-8 text-[10px] font-black text-slate-400 uppercase tracking-[0.3em] text-right">Action Protocol</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
                @foreach (var u in Model.Users)
                {
                    <tr class="hover:bg-slate-50/80 transition-all group @(!u.IsActive ? "opacity-60 grayscale" : "")">
                        <td class="px-10 py-8">
                            <a href="/Profile?userId=@u.Id" class="flex items-center gap-4 group/profile">
                                <img src="@(string.IsNullOrEmpty(u.AvatarUrl) ? $"https://i.pravatar.cc/150?u={u.Id}" : u.AvatarUrl)" class="w-12 h-12 rounded-2xl object-cover shadow-sm transition-all group-hover/profile:shadow-md group-hover/profile:scale-105" alt="" />
                                <div>
                                    <p class="font-black text-slate-900 text-base group-hover/profile:text-indigo-600 transition-colors">@u.FullName</p>
                                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-1">@u.Email</p>
                                </div>
                            </a>
                        </td>
                        <td class="px-8 py-8">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-black tracking-widest uppercase @(u.Role == "RECRUITER" ? "bg-indigo-100 text-indigo-800" : u.Role == "ADMIN" ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800")">@u.Role</span>
                        </td>
                        <td class="px-8 py-8">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-black tracking-widest uppercase @(!u.IsActive ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800")">@(u.IsActive ? "ACTIVE" : "LOCKED")</span>
                        </td>
                        <td class="px-8 py-8">
                            <span class="text-[12px] font-bold text-slate-400">@u.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </td>
                        <td class="px-10 py-8 text-right">
                            <button onclick="toggleLock(@u.Id, @u.IsActive.ToString().ToLower())" class="h-11 px-6 rounded-xl text-[10px] font-bold uppercase tracking-widest transition-colors @(!u.IsActive ? "bg-green-600 text-white hover:bg-green-700" : "bg-red-50 text-red-600 hover:bg-red-100")">
                                @if (!u.IsActive)
                                {
                                    <><i class="fas fa-unlock mr-2"></i> Unlock</>
                                }
                                else
                                {
                                    <><i class="fas fa-lock mr-2"></i> Lock Account</>
                                }
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model='(Model.CurrentPage, Model.TotalPages, $"?SearchTerm={Model.SearchTerm}&CurrentPage={{0}}")' />
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        async function toggleLock(userId, isActive) {
            let lockReason = "";
            
            if (isActive) {
                // User is currently ACTIVE -> we want to LOCK
                lockReason = prompt("Reason for protocol suspension (Account Lock):");
                if (lockReason === null) return; // User cancelled
            } else {
                // User is currently LOCKED -> we want to UNLOCK
                if (!confirm("Are you sure you want to RESTORE (Unlock) this identity?")) return;
            }

            try {
                const response = await fetch(`?handler=ToggleStatus&userId=${userId}&isActive=${isActive}&lockReason=${encodeURIComponent(lockReason || '')}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                const result = await response.json();
                if (result.success) {
                    window.location.reload();
                } else {
                    alert('Action protocol failed. Integrity check required.');
                }
            } catch (error) {
                console.error('Error toggling status:', error);
                alert('A system error occurred.');
            }
        }
    </script>
}
