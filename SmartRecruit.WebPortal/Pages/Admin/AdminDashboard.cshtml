@page "/AdminDashboard"
@model SmartRecruitWeb.Pages.AdminDashboardModel
@{
    ViewData["Title"] = "Nexus Command Center";
    var days = new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" };
}

<div class="space-y-12 animate-in fade-in duration-700 pb-20">
    <!-- HEADER SECTION -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div class="space-y-2">
            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-red-50 border border-red-100 text-red-600 shadow-sm">Root Access Level 0</span>
            <h2 class="text-5xl font-black text-slate-900 tracking-tighter uppercase">Nexus Command Center</h2>
            <p class="text-slate-500 font-medium">Monitoring global recruitment protocols and financial throughput.</p>
        </div>
        <div class="flex gap-3">
            <button class="h-12 px-6 bg-white border border-slate-200 text-slate-700 font-bold rounded-2xl hover:bg-slate-50 transition-colors shadow-sm text-sm">System Logs</button>
            <button class="h-12 px-6 bg-red-600 text-white font-bold rounded-2xl hover:bg-red-700 transition-colors shadow-lg shadow-red-200 text-sm">Emergency Stop</button>
        </div>
    </div>

    <!-- SYSTEM STATUS GRID -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="p-8 bg-white rounded-[2rem] border border-slate-200 shadow-xl group hover:scale-[1.02] transition-all duration-300">
            <div class="w-14 h-14 bg-indigo-600 rounded-2xl flex items-center justify-center text-white mb-6 shadow-xl group-hover:rotate-6 transition-transform">
                <i class="fas fa-vault text-xl"></i>
            </div>
            <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2">Total Ecosystem Revenue</p>
            <div class="flex items-baseline justify-between">
                <h3 class="text-2xl font-black text-slate-900 tracking-tighter">45,280,000</h3>
                <span class="text-[9px] font-black px-2 py-1 rounded-lg bg-green-50 text-green-600">+12.4%</span>
            </div>
        </div>

        <div class="p-8 bg-white rounded-[2rem] border border-slate-200 shadow-xl group hover:scale-[1.02] transition-all duration-300">
            <div class="w-14 h-14 bg-slate-900 rounded-2xl flex items-center justify-center text-white mb-6 shadow-xl group-hover:rotate-6 transition-transform">
                <i class="fas fa-fingerprint text-xl"></i>
            </div>
            <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2">Verified Identities</p>
            <div class="flex items-baseline justify-between">
                <h3 class="text-2xl font-black text-slate-900 tracking-tighter">@Model.TotalUsers.ToString("N0")</h3>
                <span class="text-[9px] font-black px-2 py-1 rounded-lg bg-green-50 text-green-600">+85 today</span>
            </div>
        </div>

        <div class="p-8 bg-white rounded-[2rem] border border-slate-200 shadow-xl group hover:scale-[1.02] transition-all duration-300">
            <div class="w-14 h-14 bg-amber-500 rounded-2xl flex items-center justify-center text-white mb-6 shadow-xl group-hover:rotate-6 transition-transform">
                <i class="fas fa-rocket text-xl"></i>
            </div>
            <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2">Active Missions</p>
            <div class="flex items-baseline justify-between">
                <h3 class="text-2xl font-black text-slate-900 tracking-tighter">@Model.TotalJobs</h3>
                <span class="text-[9px] font-black px-2 py-1 rounded-lg bg-slate-50 text-slate-500">12 pending</span>
            </div>
        </div>

        <div class="p-8 bg-white rounded-[2rem] border border-slate-200 shadow-xl group hover:scale-[1.02] transition-all duration-300">
            <div class="w-14 h-14 bg-green-500 rounded-2xl flex items-center justify-center text-white mb-6 shadow-xl group-hover:rotate-6 transition-transform">
                <i class="fas fa-microchip text-xl"></i>
            </div>
            <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2">System Health</p>
            <div class="flex items-baseline justify-between">
                <h3 class="text-2xl font-black text-slate-900 tracking-tighter">99.98%</h3>
                <span class="text-[9px] font-black px-2 py-1 rounded-lg bg-slate-50 text-slate-500">Operational</span>
            </div>
        </div>
    </div>

    <!-- SIMPLIFIED FINANCIAL MATRIX -->
    <div class="p-12 bg-white shadow-2xl rounded-[3rem] border border-slate-200/60">
        <div class="flex justify-between items-center mb-12">
            <div>
                <h4 class="text-[12px] font-black uppercase tracking-[0.3em] text-slate-900">Revenue Performance (7 Days)</h4>
                <p class="text-[10px] font-bold text-slate-400 mt-1 uppercase">Daily capital throughput across all sectors</p>
            </div>
            <div class="flex items-center gap-4">
                <div class="flex items-center gap-2">
                    <div class="w-3 h-3 bg-indigo-600 rounded-full"></div>
                    <span class="text-[9px] font-black text-slate-500 uppercase">Gross VND</span>
                </div>
                <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-indigo-50 border border-indigo-100 text-indigo-700 shadow-sm">Live Feed</span>
            </div>
        </div>

        <div class="h-64 flex items-end justify-between gap-4 md:gap-8 px-4">
            @for (int i = 0; i < Model.WeeklyRevenue.Count; i++)
            {
                var val = Model.WeeklyRevenue[i];
                var height = (double)val / Model.MaxRevenue * 100;
                <div class="flex-1 flex flex-col items-center gap-4 h-full group">
                    <div class="flex-1 w-full bg-slate-50 rounded-t-2xl relative overflow-hidden">
                        <div class="absolute bottom-0 left-0 w-full bg-indigo-600 rounded-t-2xl transition-all duration-700 group-hover:bg-indigo-400 group-hover:shadow-[0_0_20px_rgba(79,70,229,0.3)]"
                             style="height: @(height)%"></div>
                        <div class="absolute top-0 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-opacity bg-slate-900 text-white text-[9px] font-black px-2 py-1 rounded mt-2 z-10 whitespace-nowrap">
                            @val.ToString("N0") VND
                        </div>
                    </div>
                    <span class="text-[10px] font-black text-slate-300 uppercase tracking-widest">@days[i]</span>
                </div>
            }
        </div>
    </div>

    <!-- QUICK SYSTEM ACTIONS -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="p-10 bg-slate-900 text-white rounded-[2rem] border-0 shadow-2xl relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-10 opacity-5 text-8xl rotate-12 group-hover:rotate-45 transition-transform duration-1000"><i class="fas fa-file-invoice-dollar"></i></div>
            <div class="relative z-10 space-y-6">
                <h4 class="text-[11px] font-black uppercase tracking-[0.3em] text-indigo-400">Financial Audit Protocol</h4>
                <p class="text-sm text-slate-400 font-medium leading-relaxed">Generate a full encrypted report of all transactions, top-ups, and service fees within the global ecosystem.</p>
                <button class="w-full bg-indigo-600 border-0 h-14 rounded-2xl font-bold shadow-2xl shadow-indigo-900/40 text-[10px] uppercase hover:bg-indigo-700 transition">Download Audit History</button>
            </div>
        </div>
        <div class="p-10 bg-white rounded-[2rem] border border-slate-200/60 shadow-2xl shadow-slate-200/20 relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-10 opacity-5 text-8xl rotate-12 group-hover:scale-110 transition-transform duration-1000"><i class="fas fa-users-gear"></i></div>
            <div class="relative z-10 space-y-6">
                <h4 class="text-[11px] font-black uppercase tracking-[0.3em] text-indigo-600">Identity Registry Sync</h4>
                <p class="text-sm text-slate-500 font-medium leading-relaxed">Review recently authenticated identities and sector allocations. Ensure all nodes are verified.</p>
                <button class="w-full h-14 bg-white border border-slate-200 text-slate-700 font-bold rounded-2xl hover:bg-slate-50 transition-colors shadow-sm text-[10px] uppercase">Access User Registry</button>
            </div>
        </div>
    </div>
</div>
